{% comment %}
  StyleDrop Lifestyle Banners Section
  Converted from: src/sections/LifestyleBanners.tsx
  
  Features:
  - Two-column promotional banners
  - Image overlays with gradient
  - Configurable content and CTAs
  - Hover zoom effects
  - Links to collection pages
  
  Settings:
  - Left banner (Streetwear)
  - Right banner (Comfort)
  - Images, text, badges, CTAs all configurable
{% endcomment %}

<section class="bg-background py-14">
  <div class="container grid md:grid-cols-2 gap-6">
    
    {%- comment -%} Left Banner (Streetwear/Men's) {%- endcomment -%}
    <a 
      href="{{ section.settings.banner_1_link | default: '/collections/all' }}"
      class="relative rounded-2xl overflow-hidden group cursor-pointer h-[400px] block"
    >
      {%- comment -%} Background Image {%- endcomment -%}
      {%- if section.settings.banner_1_image != blank -%}
        <img
          src="{{ section.settings.banner_1_image | image_url: width: 800 }}"
          alt="{{ section.settings.banner_1_title }}"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      {%- else -%}
        <div class="w-full h-full bg-gray-300"></div>
      {%- endif -%}

      {%- comment -%} Gradient Overlay {%- endcomment -%}
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>

      {%- comment -%} Content - Bottom Left {%- endcomment -%}
      <div class="absolute bottom-8 left-8">
        {%- comment -%} Badge {%- endcomment -%}
        {%- if section.settings.banner_1_badge != blank -%}
          <span class="inline-block mb-3 px-3 py-1.5 bg-[#F5C800] rounded font-condensed text-[10px] font-extrabold uppercase tracking-[1.4px] text-[#0D0D0D]">
            {{ section.settings.banner_1_badge }}
          </span>
        {%- endif -%}

        {%- comment -%} Eyebrow Text {%- endcomment -%}
        {%- if section.settings.banner_1_eyebrow != blank -%}
          <p class="font-condensed text-[10px] font-bold tracking-[1.4px] uppercase text-white/60 mb-2">
            {{ section.settings.banner_1_eyebrow }}
          </p>
        {%- endif -%}

        {%- comment -%} Title {%- endcomment -%}
        <h3 class="font-display text-5xl font-normal text-white mb-4" style="letter-spacing: 0.02em;">
          {{ section.settings.banner_1_title | newline_to_br }}
        </h3>

        {%- comment -%} CTA Button {%- endcomment -%}
        {%- if section.settings.banner_1_button_text != blank -%}
          <span class="px-6 py-2.5 bg-white text-[#0D0D0D] rounded-full font-condensed text-xs font-bold tracking-wider uppercase hover:bg-white/90 transition-colors inline-block">
            {{ section.settings.banner_1_button_text }}
          </span>
        {%- endif -%}
      </div>
    </a>

    {%- comment -%} Right Banner (Comfort Redefined) {%- endcomment -%}
    <a
      href="{{ section.settings.banner_2_link | default: '/collections/all' }}"
      class="relative rounded-2xl overflow-hidden group cursor-pointer h-[400px] bg-black block"
    >
      {%- comment -%} Background Image {%- endcomment -%}
      {%- if section.settings.banner_2_image != blank -%}
        <img
          src="{{ section.settings.banner_2_image | image_url: width: 800 }}"
          alt="{{ section.settings.banner_2_title }}"
          class="w-full h-full object-cover opacity-90 group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      {%- else -%}
        <div class="w-full h-full bg-gray-400"></div>
      {%- endif -%}

      {%- comment -%} Overlay {%- endcomment -%}
      <div class="absolute inset-0 bg-black/30"></div>

      {%- comment -%} Content - Center {%- endcomment -%}
      <div class="absolute inset-0 flex flex-col items-center justify-center p-8">
        {%- comment -%} Badge - Top Left {%- endcomment -%}
        {%- if section.settings.banner_2_badge != blank -%}
          <div class="absolute top-8 left-8">
            <span class="inline-block px-3 py-1.5 bg-accent rounded font-condensed text-[10px] font-extrabold uppercase tracking-[1.4px] text-white">
              {{ section.settings.banner_2_badge }}
            </span>
          </div>
        {%- endif -%}

        {%- comment -%} Center Content {%- endcomment -%}
        <div class="text-center">
          {%- comment -%} Eyebrow {%- endcomment -%}
          {%- if section.settings.banner_2_eyebrow != blank -%}
            <p class="font-condensed text-[10px] font-bold tracking-[1.4px] uppercase text-white/70 mb-2">
              {{ section.settings.banner_2_eyebrow }}
            </p>
          {%- endif -%}

          {%- comment -%} Title {%- endcomment -%}
          <h3 class="font-display text-6xl font-normal text-white mb-2" style="letter-spacing: 0.02em;">
            {{ section.settings.banner_2_title_line1 | default: "COMFORT" }}
          </h3>
          <h3 class="font-display text-6xl font-normal text-accent mb-6" style="letter-spacing: 0.02em;">
            {{ section.settings.banner_2_title_line2 | default: "REDEFINED" }}
          </h3>

          {%- comment -%} Description {%- endcomment -%}
          {%- if section.settings.banner_2_description != blank -%}
            <div class="text-white/80 text-sm mb-6 max-w-xs mx-auto">
              {{ section.settings.banner_2_description }}
            </div>
          {%- endif -%}

          {%- comment -%} CTA Button {%- endcomment -%}
          {%- if section.settings.banner_2_button_text != blank -%}
            <span class="px-8 py-3 bg-accent text-white rounded-full font-condensed text-xs font-bold tracking-wider uppercase hover:bg-accent/90 transition-colors inline-block">
              {{ section.settings.banner_2_button_text }}
            </span>
          {%- endif -%}
        </div>
      </div>
    </a>

  </div>
</section>

{% schema %}
{
  "name": "Lifestyle Banners",
  "tag": "section",
  "class": "section-lifestyle-banners",
  "settings": [
    {
      "type": "header",
      "content": "Left Banner (Streetwear)"
    },
    {
      "type": "image_picker",
      "id": "banner_1_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "banner_1_badge",
      "label": "Badge Text",
      "default": "NEW DROP"
    },
    {
      "type": "text",
      "id": "banner_1_eyebrow",
      "label": "Eyebrow Text",
      "default": "MEN'S COLLECTION"
    },
    {
      "type": "textarea",
      "id": "banner_1_title",
      "label": "Title",
      "default": "EVERYDAY\nSTREETWEAR",
      "info": "Use line breaks for multi-line titles"
    },
    {
      "type": "text",
      "id": "banner_1_button_text",
      "label": "Button Text",
      "default": "SHOP MEN'S →"
    },
    {
      "type": "url",
      "id": "banner_1_link",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Right Banner (Comfort)"
    },
    {
      "type": "image_picker",
      "id": "banner_2_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "banner_2_badge",
      "label": "Badge Text",
      "default": "FIND YOUR FIT"
    },
    {
      "type": "text",
      "id": "banner_2_eyebrow",
      "label": "Eyebrow Text",
      "default": "YOUR EVERYDAY FAVORITES"
    },
    {
      "type": "text",
      "id": "banner_2_title_line1",
      "label": "Title Line 1",
      "default": "COMFORT"
    },
    {
      "type": "text",
      "id": "banner_2_title_line2",
      "label": "Title Line 2 (Accent Color)",
      "default": "REDEFINED"
    },
    {
      "type": "textarea",
      "id": "banner_2_description",
      "label": "Description",
      "default": "Fabrics that move with you. Styles that speak for you."
    },
    {
      "type": "text",
      "id": "banner_2_button_text",
      "label": "Button Text",
      "default": "EXPLORE STYLES →"
    },
    {
      "type": "url",
      "id": "banner_2_link",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "Lifestyle Banners"
    }
  ]
}
{% endschema %}
