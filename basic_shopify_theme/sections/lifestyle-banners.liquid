{% comment %}
  StyleDrop Lifestyle Banners Section
  Converted from: src/sections/LifestyleBanners.tsx
  
  Features:
  - Two-column promotional banners
  - Image overlays with gradient
  - Configurable content and CTAs
  - Hover zoom effects
  - Links to collection pages
  
  Settings:
  - Left banner (Streetwear)
  - Right banner (Comfort)
  - Images, text, badges, CTAs all configurable
{% endcomment %}

{{ 'styledrop-lifestyle-banners.css' | asset_url | stylesheet_tag }}

<section class="styledrop-lifestyle">
  <div class="container styledrop-lifestyle__grid">
    
    {%- comment -%} Left Banner (Streetwear/Men's) {%- endcomment -%}
    <a
      href="{{ section.settings.banner_1_link | default: '/collections/all' }}"
      class="styledrop-lifestyle__banner styledrop-lifestyle__banner--left"
    >
      {%- comment -%} Background Image {%- endcomment -%}
      {%- if section.settings.banner_1_image != blank -%}
        <img
          src="{{ section.settings.banner_1_image | image_url: width: 800 }}"
          alt="{{ section.settings.banner_1_title }}"
          class="styledrop-lifestyle__banner-img"
          width="800"
          height="400"
          loading="lazy"
        />
      {%- else -%}
        <div class="styledrop-lifestyle__placeholder"></div>
      {%- endif -%}

      {%- comment -%} Gradient Overlay {%- endcomment -%}
      <div class="styledrop-lifestyle__gradient-overlay"></div>

      {%- comment -%} Content - Bottom Left {%- endcomment -%}
      <div class="styledrop-lifestyle__content styledrop-lifestyle__content--bottom-left">
        {%- comment -%} Badge {%- endcomment -%}
        {%- if section.settings.banner_1_badge != blank -%}
          <span class="styledrop-lifestyle__badge-yellow">
            {{ section.settings.banner_1_badge }}
          </span>
        {%- endif -%}

        {%- comment -%} Eyebrow Text {%- endcomment -%}
        {%- if section.settings.banner_1_eyebrow != blank -%}
          <p class="styledrop-lifestyle__eyebrow">
            {{ section.settings.banner_1_eyebrow }}
          </p>
        {%- endif -%}

        {%- comment -%} Title {%- endcomment -%}
        <h3 class="styledrop-lifestyle__title-left">
          {{ section.settings.banner_1_title | newline_to_br }}
        </h3>

        {%- comment -%} CTA Button {%- endcomment -%}
        {%- if section.settings.banner_1_button_text != blank -%}
          <span class="styledrop-lifestyle__cta">
            {{ section.settings.banner_1_button_text }}
          </span>
        {%- endif -%}
      </div>
    </a>

    {%- comment -%} Right Banner (Comfort Redefined) {%- endcomment -%}
    <a
      href="{{ section.settings.banner_2_link | default: '/collections/all' }}"
      class="styledrop-lifestyle__banner styledrop-lifestyle__banner--right"
    >
      {%- comment -%} Background Image {%- endcomment -%}
      {%- if section.settings.banner_2_image != blank -%}
        <img
          src="{{ section.settings.banner_2_image | image_url: width: 800 }}"
          alt="{{ section.settings.banner_2_title }}"
          class="styledrop-lifestyle__banner-img styledrop-lifestyle__banner-img--muted"
          width="800"
          height="400"
          loading="lazy"
        />
      {%- else -%}
        <div class="styledrop-lifestyle__placeholder styledrop-lifestyle__placeholder--right"></div>
      {%- endif -%}

      {%- comment -%} Overlay {%- endcomment -%}
      <div class="styledrop-lifestyle__overlay"></div>

      {%- comment -%} Content - Center {%- endcomment -%}
      <div class="styledrop-lifestyle__content styledrop-lifestyle__content--center">
        {%- comment -%} Badge - Top Left {%- endcomment -%}
        {%- if section.settings.banner_2_badge != blank -%}
          <div class="styledrop-lifestyle__badge-top-left">
            <span class="styledrop-lifestyle__badge-accent">
              {{ section.settings.banner_2_badge }}
            </span>
          </div>
        {%- endif -%}

        {%- comment -%} Center Content {%- endcomment -%}
        <div class="styledrop-lifestyle__center-content">
          {%- comment -%} Eyebrow {%- endcomment -%}
          {%- if section.settings.banner_2_eyebrow != blank -%}
            <p class="styledrop-lifestyle__eyebrow">
              {{ section.settings.banner_2_eyebrow }}
            </p>
          {%- endif -%}

          {%- comment -%} Title {%- endcomment -%}
          <h3 class="styledrop-lifestyle__title-right-main">
            {{ section.settings.banner_2_title_line1 | default: "COMFORT" }}
          </h3>
          <h3 class="styledrop-lifestyle__title-right-accent">
            {{ section.settings.banner_2_title_line2 | default: "REDEFINED" }}
          </h3>

          {%- comment -%} Description {%- endcomment -%}
          {%- if section.settings.banner_2_description != blank -%}
            <div class="styledrop-lifestyle__banner-description">
              {{ section.settings.banner_2_description }}
            </div>
          {%- endif -%}

          {%- comment -%} CTA Button {%- endcomment -%}
          {%- if section.settings.banner_2_button_text != blank -%}
            <span class="styledrop-lifestyle__cta-btn">
              {{ section.settings.banner_2_button_text }}
            </span>
          {%- endif -%}
        </div>
      </div>
    </a>

  </div>
</section>

{% schema %}
{
  "name": "StyleDrop - Lifestyle Banners",
  "tag": "section",
  "class": "section-lifestyle-banners",
  "settings": [
    {
      "type": "header",
      "content": "Left Banner (Streetwear)"
    },
    {
      "type": "image_picker",
      "id": "banner_1_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "banner_1_badge",
      "label": "Badge Text",
      "default": "NEW DROP"
    },
    {
      "type": "text",
      "id": "banner_1_eyebrow",
      "label": "Eyebrow Text",
      "default": "MEN'S COLLECTION"
    },
    {
      "type": "textarea",
      "id": "banner_1_title",
      "label": "Title",
      "default": "EVERYDAY\nSTREETWEAR",
      "info": "Use line breaks for multi-line titles"
    },
    {
      "type": "text",
      "id": "banner_1_button_text",
      "label": "Button Text",
      "default": "SHOP MEN'S →"
    },
    {
      "type": "url",
      "id": "banner_1_link",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Right Banner (Comfort)"
    },
    {
      "type": "image_picker",
      "id": "banner_2_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "banner_2_badge",
      "label": "Badge Text",
      "default": "FIND YOUR FIT"
    },
    {
      "type": "text",
      "id": "banner_2_eyebrow",
      "label": "Eyebrow Text",
      "default": "YOUR EVERYDAY FAVORITES"
    },
    {
      "type": "text",
      "id": "banner_2_title_line1",
      "label": "Title Line 1",
      "default": "COMFORT"
    },
    {
      "type": "text",
      "id": "banner_2_title_line2",
      "label": "Title Line 2 (Accent Color)",
      "default": "REDEFINED"
    },
    {
      "type": "textarea",
      "id": "banner_2_description",
      "label": "Description",
      "default": "Fabrics that move with you. Styles that speak for you."
    },
    {
      "type": "text",
      "id": "banner_2_button_text",
      "label": "Button Text",
      "default": "EXPLORE STYLES →"
    },
    {
      "type": "url",
      "id": "banner_2_link",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "StyleDrop - Lifestyle Banners"
    }
  ]
}
{% endschema %}
