      "default": 13
    },
    {
      "type": "range",
      "id": "link_font_desktop",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size (desktop)",
      "default": 14
    },
    {
      "type": "header",
      "content": "Brand cards"
    },
    {
      "type": "range",
