      "min": 36,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 56
    },
    {
      "type": "range",
      "id": "heading_line_height_desktop",
      "min": 32,
      "max": 96,
      "step": 1,
