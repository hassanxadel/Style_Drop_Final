{% comment %}
  StyleDrop Brands Section
  Converted from: src/sections/BrandsSection.tsx

  Features:
  - Featured brands horizontal scroll + visible scrollbar
  - Theme editor: heading, badge, cards, link sizes (mobile / desktop)
  - Dynamic brand loading from product vendors
{% endcomment %}

{{ 'styledrop-brands-section.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign hs_m = s.heading_size_mobile | default: 42
  assign hs_d = s.heading_size_desktop | default: 56
  assign hlh_m = s.heading_line_height_mobile | default: 38
  assign hlh_d = s.heading_line_height_desktop | default: 50
  assign hfw = s.heading_font_weight | default: 400
  assign bf_m = s.badge_font_mobile | default: 11
  assign bf_d = s.badge_font_desktop | default: 11
  assign bpy = s.badge_pad_y | default: 3
  assign bpx = s.badge_pad_x | default: 10
  assign lf_m = s.link_font_mobile | default: 13
  assign lf_d = s.link_font_desktop | default: 14
  assign cw_m = s.card_width_mobile | default: 160
  assign cw_d = s.card_width_desktop | default: 160
  assign ch_m = s.card_height_mobile | default: 160
  assign ch_d = s.card_height_desktop | default: 160
  assign cpad = s.card_padding | default: 20
  assign cgap = s.card_gap | default: 16
  assign lb_m = s.logo_box_mobile | default: 64
  assign lb_d = s.logo_box_desktop | default: 64
  assign limg = s.logo_img_size | default: 40
  assign llet = s.logo_letter_size | default: 22
  assign nm_m = s.name_font_mobile | default: 14
  assign nm_d = s.name_font_desktop | default: 14
  assign sb_h = s.scrollbar_height | default: 8
  assign show_sb = s.show_scrollbar
  if show_sb == nil
    assign show_sb = true
  endif
-%}

<section
  class="styledrop-brands{% unless show_sb %} styledrop-brands--hide-scrollbar{% endunless %}"
  style="
    --sb-heading-fs-mobile: {{ hs_m }}px;
    --sb-heading-fs-desktop: {{ hs_d }}px;
    --sb-heading-lh-mobile: {{ hlh_m }}px;
    --sb-heading-lh-desktop: {{ hlh_d }}px;
    --sb-heading-fw: {{ hfw }};
    --sb-badge-fs-mobile: {{ bf_m }}px;
    --sb-badge-fs-desktop: {{ bf_d }}px;
    --sb-badge-py: {{ bpy }}px;
    --sb-badge-px: {{ bpx }}px;
    --sb-link-fs-mobile: {{ lf_m }}px;
    --sb-link-fs-desktop: {{ lf_d }}px;
    --sb-card-w-mobile: {{ cw_m }}px;
    --sb-card-w-desktop: {{ cw_d }}px;
    --sb-card-h-mobile: {{ ch_m }}px;
    --sb-card-h-desktop: {{ ch_d }}px;
    --sb-card-pad: {{ cpad }}px;
    --sb-card-gap: {{ cgap }}px;
    --sb-logo-box-mobile: {{ lb_m }}px;
    --sb-logo-box-desktop: {{ lb_d }}px;
    --sb-logo-img: {{ limg }}px;
    --sb-logo-letter: {{ llet }}px;
    --sb-name-fs-mobile: {{ nm_m }}px;
    --sb-name-fs-desktop: {{ nm_d }}px;
    --sb-scrollbar-h: {{ sb_h }}px;
  "
>
  <div class="styledrop-brands__container">

    {%- comment -%} Section Header {%- endcomment -%}
    <div class="styledrop-brands__header">
      <div>
        {%- comment -%} Badge {%- endcomment -%}
        {%- if section.settings.badge_text != blank -%}
          <span class="styledrop-brands__badge">
            {{ section.settings.badge_text }}
          </span>
        {%- endif -%}

        {%- comment -%} Heading {%- endcomment -%}
        <h2 class="styledrop-brands__heading">
          {{ section.settings.heading_line_1 | default: "200+ BRANDS" }}
          <br />
          {{ section.settings.heading_line_2 | default: "ONE PLATFORM" }}
        </h2>
      </div>

      {%- comment -%} All Brands Link {%- endcomment -%}
      {%- if section.settings.all_brands_link != blank -%}
        <a
          href="{{ section.settings.all_brands_link }}"
          class="styledrop-brands__all-link"
        >
          {{ section.settings.all_brands_text | default: "All brands" }}
          <span aria-hidden>→</span>
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Brand Cards — Horizontal Scroll {%- endcomment -%}
    <div class="styledrop-brands__scroll">
      {%- assign all_vendors = '' -%}
      {%- assign brand_count = 0 -%}
      {%- assign max_brands = section.settings.brand_limit | default: 12 -%}

      {%- if section.settings.collection != blank -%}
        {%- assign brand_collection = collections[section.settings.collection] -%}
        {%- for product in brand_collection.products limit: 50 -%}
          {%- unless all_vendors contains product.vendor -%}
            {%- if brand_count < max_brands -%}
              {%- assign vendor_slug = product.vendor | handleize -%}
              {%- assign color_index = product.vendor | size | modulo: 6 -%}
              {%- assign brand_color = '#DC2626' -%}
              {%- case color_index -%}
                {%- when 0 -%}{%- assign brand_color = '#DC2626' -%}
                {%- when 1 -%}{%- assign brand_color = '#0D0D0D' -%}
                {%- when 2 -%}{%- assign brand_color = '#2563EB' -%}
                {%- when 3 -%}{%- assign brand_color = '#059669' -%}
                {%- when 4 -%}{%- assign brand_color = '#7C3AED' -%}
                {%- when 5 -%}{%- assign brand_color = '#EA580C' -%}
              {%- endcase -%}

              <a href="/collections/{{ vendor_slug }}" class="styledrop-brands__card">
                <div class="styledrop-brands__logo" style="background-color: {{ brand_color }};">
                  {%- if product.featured_image -%}
                    {%- assign img_w = limg | times: 2 -%}
                    {%- if img_w > 256 -%}{%- assign img_w = 256 -%}{%- endif -%}
                    <img
                      src="{{ product.featured_image | image_url: width: img_w }}"
                      alt="{{ product.vendor }}"
                      class="styledrop-brands__logo-img"
                      width="{{ limg }}"
                      height="{{ limg }}"
                      loading="lazy"
                    />
                  {%- else -%}
                    <span>{{ product.vendor | slice: 0 }}</span>
                  {%- endif -%}
                </div>
                <div class="styledrop-brands__name-wrap">
                  <p class="styledrop-brands__name">{{ product.vendor | upcase }}</p>
                </div>
              </a>

              {%- assign all_vendors = all_vendors | append: product.vendor | append: ',' -%}
              {%- assign brand_count = brand_count | plus: 1 -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}

      {%- else -%}
        {%- comment -%} Fallback: all products {%- endcomment -%}
        {%- for product in collections.all.products limit: 50 -%}
          {%- unless all_vendors contains product.vendor -%}
            {%- if brand_count < max_brands -%}
              {%- assign vendor_slug = product.vendor | handleize -%}
              {%- assign color_index = product.vendor | size | modulo: 6 -%}
              {%- assign brand_color = '#DC2626' -%}
              {%- case color_index -%}
                {%- when 0 -%}{%- assign brand_color = '#DC2626' -%}
                {%- when 1 -%}{%- assign brand_color = '#0D0D0D' -%}
                {%- when 2 -%}{%- assign brand_color = '#2563EB' -%}
                {%- when 3 -%}{%- assign brand_color = '#059669' -%}
                {%- when 4 -%}{%- assign brand_color = '#7C3AED' -%}
                {%- when 5 -%}{%- assign brand_color = '#EA580C' -%}
              {%- endcase -%}

              <a href="/collections/{{ vendor_slug }}" class="styledrop-brands__card">
                <div class="styledrop-brands__logo" style="background-color: {{ brand_color }};">
                  <span>{{ product.vendor | slice: 0 }}</span>
                </div>
                <div class="styledrop-brands__name-wrap">
                  <p class="styledrop-brands__name">{{ product.vendor | upcase }}</p>
                </div>
              </a>

              {%- assign all_vendors = all_vendors | append: product.vendor | append: ',' -%}
              {%- assign brand_count = brand_count | plus: 1 -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "StyleDrop - Brands",
  "tag": "section",
  "class": "section-brands",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "FEATURED BRANDS"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading Line 1",
      "default": "200+ BRANDS"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading Line 2",
      "default": "ONE PLATFORM"
    },
    {
      "type": "header",
      "content": "Brands Settings"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Source Collection",
      "info": "Select a collection to pull brands from (uses all products if empty)"
    },
    {
      "type": "range",
      "id": "brand_limit",
      "min": 4,
      "max": 20,
      "step": 1,
      "label": "Number of Brands",
      "default": 12
    },
    {
      "type": "header",
      "content": "All Brands Link"
    },
    {
      "type": "text",
      "id": "all_brands_text",
      "label": "Link Text",
      "default": "All brands"
    },
    {
      "type": "url",
      "id": "all_brands_link",
      "label": "Link URL",
      "info": "Link to your brands page"
    },
    {
      "type": "header",
      "content": "Typography — heading (mobile)"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 28,
      "max": 80,
      "step": 1,
      "unit": "px",
