      "id": "cta_secondary_link",
      "label": "Secondary Link URL",
      "default": "/collections/new-arrivals"
    },
    {
      "type": "header",
      "content": "Hero Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "checkbox",
      "id": "show_fast_drop_badge",
      "label": "Show 'Fast Drop' Badge",
      "default": true
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product Card (Desktop only)"
    },
    {
      "type": "header",
      "content": "Trust Features"
    },
    {
      "type": "text",
      "id": "feature_1_title",
      "label": "Feature 1 Title",
      "default": "Fast Delivery"
    },
    {
      "type": "text",
      "id": "feature_1_desc",
      "label": "Feature 1 Description",
      "default": "Same-day & next-day options"
    },
    {
      "type": "text",
      "id": "feature_2_title",
      "label": "Feature 2 Title",
      "default": "Easy Returns"
    },
    {
      "type": "text",
      "id": "feature_2_desc",
      "label": "Feature 2 Description",
      "default": "Free 30-day hassle-free returns"
    },
    {
      "type": "text",
      "id": "feature_3_title",
      "label": "Feature 3 Title",
      "default": "Secure Checkout"
    },
    {
      "type": "text",
      "id": "feature_3_desc",
      "label": "Feature 3 Description",
      "default": "256-bit SSL encrypted payments"
    },
    {
      "type": "text",
      "id": "feature_4_title",
      "label": "Feature 4 Title",
      "default": "Trusted Brands"
    },
    {
      "type": "text",
      "id": "feature_4_desc",
      "label": "Feature 4 Description",
      "default": "200+ verified fashion brands"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}

{% comment %}
  CONVERSION NOTES:
  
  React → Liquid Conversions:
  - Removed all React imports (Link, icons)
  - Converted <Link> to <a> tags
  - Icons converted to inline SVGs
  - Removed trustFeatures array → hardcoded 4 features
  - Made all content configurable via schema
  
  Features:
  - ✅ Fully responsive (mobile/desktop)
  - ✅ "MOVE FREELY" text hidden on mobile (CSS class)
  - ✅ Product card hidden on mobile (CSS class)
  - ✅ CTAs stack vertically on mobile
  - ✅ Trust features: 2 cols mobile, 4 cols desktop
  - ✅ All text editable in Theme Editor
  - ✅ Image upload support
  - ✅ Featured product selector
  
  Shopify Integration:
  - Uses img_url filter for image optimization
  - Product data from all_products array
  - Money filter for price formatting
  - Fully configurable schema
  
  Usage:
  1. Add section to homepage in Theme Editor
  2. Upload hero image
  3. Select featured product (optional)
  4. Customize text and links
{% endcomment %}
