{% comment %}
  StyleDrop Hero Section
  Section name: "style-drop-hero section"
  Converted from: src/sections/HeroSection.tsx

  Layout (mirrors React exactly):
  - Outer section bg: #F5F0EB, min-height 702px
  - Top row: MOVE FREELY | LIVE BOLDLY | FEEL ICONIC (h=82px, space-between, desktop only)
  - Content row: Left col (text, max-w 480px) + Right col (image + overlays, h=620px)
  - Left: Red pill badge → Bebas Neue 99px headline WEAR WHAT / DROPS(red) / TODAY. → 15px description → 2 CTAs
  - Right: hero image (object-cover, rounded-t-20px) + FAST DROP badge (absolute -left-15px top-5) + product card (absolute left-340 top-367px)
  - Trust bar: #0D0D0D bg, 4 features with icon circles

  Valgara Protocol:
  - Zero Tailwind. BEM: styledrop-hero__[element]--[modifier]
  - CSS in assets/styledrop-hero-section.css
  - Schema at bottom, presets defined
{% endcomment %}

{{ 'styledrop-hero-section.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign tm = s.tagline_size_mobile | default: 12
  assign td = s.tagline_size_desktop | default: 12
  assign btm = s.badge_text_size_mobile | default: 9
  assign btd = s.badge_text_size_desktop | default: 11
  assign bim = s.badge_icon_size_mobile | default: 9
  assign bid = s.badge_icon_size_desktop | default: 11
  assign bhm = s.badge_height_mobile | default: 22
  assign bhd = s.badge_height_desktop | default: 29
  assign hdm = s.headline_size_mobile | default: 56
  assign hdd = s.headline_size_desktop | default: 99
  assign hlm = s.headline_line_height_mobile | default: 50
  assign hld = s.headline_line_height_desktop | default: 87
  assign dsm = s.description_size_mobile | default: 13
  assign dsd = s.description_size_desktop | default: 15
  assign pfm = s.cta_primary_font_mobile | default: 13
  assign pfd = s.cta_primary_font_desktop | default: 16
  assign phm = s.cta_primary_height_mobile | default: 44
  assign phd = s.cta_primary_height_desktop | default: 52
  assign sfm = s.cta_secondary_font_mobile | default: 12
  assign sfd = s.cta_secondary_font_desktop | default: 14
  assign cw = s.hero_col_max_width | default: 570
  assign ch = s.hero_col_height_desktop | default: 620
  assign aw = s.hero_aspect_w | default: 480
  assign ah = s.hero_aspect_h | default: 620
  assign flm = s.fast_drop_lightning_mobile | default: 16
  assign fld = s.fast_drop_lightning_desktop | default: 18
  assign ftm = s.fast_drop_label_mobile | default: 9
  assign ftd = s.fast_drop_label_desktop | default: 10
  assign fsm = s.fast_drop_sub_mobile | default: 8
  assign fsd = s.fast_drop_sub_desktop | default: 9
  assign pwm = s.card_width_mobile | default: 140
  assign pwd = s.card_width_desktop | default: 160
  assign chm = s.card_min_height_mobile | default: 168
  assign chd = s.card_min_height_desktop | default: 192
  assign cimw = s.card_img_width_mobile | default: 120
  assign cimd = s.card_img_width_desktop | default: 136
  assign cihm = s.card_img_height_mobile | default: 88
  assign cihd = s.card_img_height_desktop | default: 100
  assign cvm = s.card_vendor_font_mobile | default: 9
  assign cvd = s.card_vendor_font_desktop | default: 10
  assign ctm = s.card_title_font_mobile | default: 11
  assign ctd = s.card_title_font_desktop | default: 12
  assign cpm = s.card_price_font_mobile | default: 12
  assign cpd = s.card_price_font_desktop | default: 13
  assign crm = s.card_rtn_font_mobile | default: 8
  assign crd = s.card_rtn_font_desktop | default: 9
  assign cld = s.card_left_desktop | default: 340
  assign ctdp = s.card_top_desktop | default: 368
  assign ttm = s.trust_title_mobile | default: 13
  assign ttd = s.trust_title_desktop | default: 15
  assign tdm = s.trust_desc_mobile | default: 11
  assign tdd = s.trust_desc_desktop | default: 12
  assign tim = s.trust_icon_wrap_mobile | default: 36
  assign tid = s.trust_icon_wrap_desktop | default: 40
  assign tsm = s.trust_icon_svg_mobile | default: 18
  assign tsd = s.trust_icon_svg_desktop | default: 20
-%}

<section
  class="styledrop-hero"
  style="
    --sd-tagline-mobile: {{ tm }}px;
    --sd-tagline-desktop: {{ td }}px;
    --sd-badge-text-mobile: {{ btm }}px;
    --sd-badge-text-desktop: {{ btd }}px;
    --sd-badge-icon-mobile: {{ bim }}px;
    --sd-badge-icon-desktop: {{ bid }}px;
    --sd-badge-height-mobile: {{ bhm }}px;
    --sd-badge-height-desktop: {{ bhd }}px;
    --sd-headline-mobile: {{ hdm }}px;
    --sd-headline-desktop: {{ hdd }}px;
    --sd-headline-lh-mobile: {{ hlm }}px;
    --sd-headline-lh-desktop: {{ hld }}px;
    --sd-desc-mobile: {{ dsm }}px;
    --sd-desc-desktop: {{ dsd }}px;
    --sd-btn-p-fs-mobile: {{ pfm }}px;
    --sd-btn-p-fs-desktop: {{ pfd }}px;
    --sd-btn-p-h-mobile: {{ phm }}px;
    --sd-btn-p-h-desktop: {{ phd }}px;
    --sd-btn-s-fs-mobile: {{ sfm }}px;
    --sd-btn-s-fs-desktop: {{ sfd }}px;
    --sd-col-max-w: {{ cw }}px;
    --sd-col-h-desktop: {{ ch }}px;
    --sd-aspect-w: {{ aw }};
    --sd-aspect-h: {{ ah }};
    --sd-fast-light-mobile: {{ flm }}px;
    --sd-fast-light-desktop: {{ fld }}px;
    --sd-fast-label-mobile: {{ ftm }}px;
    --sd-fast-label-desktop: {{ ftd }}px;
    --sd-fast-sub-mobile: {{ fsm }}px;
    --sd-fast-sub-desktop: {{ fsd }}px;
    --sd-card-w-mobile: {{ pwm }}px;
    --sd-card-w-desktop: {{ pwd }}px;
    --sd-card-min-h-mobile: {{ chm }}px;
    --sd-card-min-h-desktop: {{ chd }}px;
    --sd-card-img-w-mobile: {{ cimw }}px;
    --sd-card-img-w-desktop: {{ cimd }}px;
    --sd-card-img-h-mobile: {{ cihm }}px;
    --sd-card-img-h-desktop: {{ cihd }}px;
    --sd-card-vendor-mobile: {{ cvm }}px;
    --sd-card-vendor-desktop: {{ cvd }}px;
    --sd-card-title-mobile: {{ ctm }}px;
    --sd-card-title-desktop: {{ ctd }}px;
    --sd-card-price-mobile: {{ cpm }}px;
    --sd-card-price-desktop: {{ cpd }}px;
    --sd-card-rtn-mobile: {{ crm }}px;
    --sd-card-rtn-desktop: {{ crd }}px;
    --sd-card-left: {{ cld }}px;
    --sd-card-top: {{ ctdp }}px;
    --sd-trust-title-mobile: {{ ttm }}px;
    --sd-trust-title-desktop: {{ ttd }}px;
    --sd-trust-desc-mobile: {{ tdm }}px;
    --sd-trust-desc-desktop: {{ tdd }}px;
    --sd-trust-icon-wrap-mobile: {{ tim }}px;
    --sd-trust-icon-wrap-desktop: {{ tid }}px;
    --sd-trust-icon-svg-mobile: {{ tsm }}px;
    --sd-trust-icon-svg-desktop: {{ tsd }}px;
  "
>

  {%- comment -%} HERO MAIN — bg #F5F0EB {%- endcomment -%}
  <div class="styledrop-hero__main">
    <div class="container styledrop-hero__wrap">

      {%- comment -%} Top tagline row — desktop only {%- endcomment -%}
      <div class="styledrop-hero__tagline-row">
        <p class="styledrop-hero__tagline">{{ section.settings.tagline_1 | default: 'MOVE FREELY' }}</p>
        <p class="styledrop-hero__tagline">{{ section.settings.tagline_2 | default: 'LIVE BOLDLY' }}</p>
        <p class="styledrop-hero__tagline">{{ section.settings.tagline_3 | default: 'FEEL ICONIC' }}</p>
      </div>

      {%- comment -%} Main content row — text left, image right {%- endcomment -%}
      <div class="styledrop-hero__content-row">

        {%- comment -%} LEFT COLUMN — text block {%- endcomment -%}
        <div class="styledrop-hero__left-col">

          {%- comment -%} SAME-DAY DELIVERY red pill badge {%- endcomment -%}
          <span class="styledrop-hero__delivery-badge">
            <svg class="styledrop-hero__delivery-badge-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
              <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/>
            </svg>
            <span class="styledrop-hero__delivery-badge-text">
              {{ section.settings.badge_text | default: 'SAME-DAY DELIVERY' }}
            </span>
          </span>

          {%- comment -%} Bebas Neue headline — 99px, line-height 87px, letter-spacing 3.6px {%- endcomment -%}
          <h1 class="styledrop-hero__headline">
            <span class="styledrop-hero__headline-line">{{ section.settings.headline_line_1 | default: 'WEAR WHAT' }}</span>
            <span class="styledrop-hero__headline-line styledrop-hero__headline-line--accent">{{ section.settings.headline_line_2 | default: 'DROPS' }}</span>
            <span class="styledrop-hero__headline-line">{{ section.settings.headline_line_3 | default: 'TODAY.' }}</span>
          </h1>

          {%- comment -%} Description — 15px/24px, opacity 0.55, max-width 320px {%- endcomment -%}
          <p class="styledrop-hero__description">
            {{ section.settings.description | default: 'Multi-brand fashion delivered fast. Discover trending styles from the brands you love — with full transparency on pricing and returns.' }}
          </p>

          {%- comment -%} CTA row — red filled button + text link {%- endcomment -%}
          <div class="styledrop-hero__cta-row">
            <a href="{{ section.settings.cta_primary_link | default: '/collections/all' }}" class="styledrop-hero__btn-primary">
              {{ section.settings.cta_primary_text | default: "SHOP WHAT'S TRENDING" }}
            </a>
            <a href="{{ section.settings.cta_secondary_link | default: '/collections/new-arrivals' }}" class="styledrop-hero__btn-secondary">
              {{ section.settings.cta_secondary_text | default: 'Explore New Arrivals' }}
              <span aria-hidden="true">→</span>
            </a>
          </div>

        </div>

        {%- comment -%} RIGHT COLUMN — image + overlays {%- endcomment -%}
        <div class="styledrop-hero__right-col">

          {%- comment -%} Hero image — object-cover, rounded-t-[20px] {%- endcomment -%}
          {%- if section.settings.hero_image != blank -%}
            <img
              src="{{ section.settings.hero_image | image_url: width: 800 }}"
              alt="{{ section.settings.hero_image.alt | default: 'Fashion model' }}"
              class="styledrop-hero__image"
              width="800"
              height="1033"
              loading="eager"
            />
          {%- else -%}
            <div class="styledrop-hero__image-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
              </svg>
              <p>Upload hero image in Theme Editor</p>
            </div>
          {%- endif -%}

          {%- comment -%} FAST DROP badge — absolute -left-15px, top-20px, dark pill {%- endcomment -%}
          {%- if section.settings.show_fast_drop_badge != false -%}
          <div class="styledrop-hero__fast-drop">
            <div class="styledrop-hero__fast-drop-row">
              <span class="styledrop-hero__fast-drop-lightning" aria-hidden="true">⚡</span>
              <span class="styledrop-hero__fast-drop-label">{{ section.settings.fast_drop_label | default: 'FAST DROP' }}</span>
            </div>
            <span class="styledrop-hero__fast-drop-sub">{{ section.settings.fast_drop_sub | default: 'Delivered today' }}</span>
          </div>
          {%- endif -%}

          {%- comment -%} Product card overlay — desktop only, absolute bottom-right {%- endcomment -%}
          <div class="styledrop-hero__product-card">
            {%- if section.settings.featured_product != blank -%}
              {%- assign fp = all_products[section.settings.featured_product] -%}
              {%- if fp != blank -%}
                {%- if fp.featured_image -%}
                  <img
                    src="{{ fp.featured_image | image_url: width: 272 }}"
                    alt="{{ fp.title }}"
                    class="styledrop-hero__product-card-img"
                    width="136"
                    height="100"
                    loading="lazy"
                  />
                {%- endif -%}
                <p class="styledrop-hero__product-card-vendor">{{ fp.vendor | upcase }}</p>
                <p class="styledrop-hero__product-card-title">{{ fp.title | truncate: 20 }}</p>
                <div class="styledrop-hero__product-card-footer">
                  <span class="styledrop-hero__product-card-price">{{ fp.price | money }}</span>
                  <span class="styledrop-hero__product-card-rtn">FREE RTN</span>
                </div>
              {%- else -%}
                {%- comment -%} Fallback card for preview / no product selected {%- endcomment -%}
                <div class="styledrop-hero__product-card-placeholder-img"></div>
                <p class="styledrop-hero__product-card-vendor">{{ section.settings.card_brand | default: 'ARITZIA' }}</p>
                <p class="styledrop-hero__product-card-title">{{ section.settings.card_title | default: 'Trench Coat' }}</p>
                <div class="styledrop-hero__product-card-footer">
                  <span class="styledrop-hero__product-card-price">{{ section.settings.card_price | default: 'EGP 1,124.00' }}</span>
                  <span class="styledrop-hero__product-card-rtn">FREE RTN</span>
                </div>
              {%- endif -%}
            {%- else -%}
              {%- comment -%} Static fallback card {%- endcomment -%}
              <div class="styledrop-hero__product-card-placeholder-img"></div>
              <p class="styledrop-hero__product-card-vendor">{{ section.settings.card_brand | default: 'ARITZIA' }}</p>
              <p class="styledrop-hero__product-card-title">{{ section.settings.card_title | default: 'Trench Coat' }}</p>
              <div class="styledrop-hero__product-card-footer">
                <span class="styledrop-hero__product-card-price">{{ section.settings.card_price | default: 'EGP 1,124.00' }}</span>
                <span class="styledrop-hero__product-card-rtn">FREE RTN</span>
              </div>
            {%- endif -%}
          </div>

        </div>
      </div>
    </div>
  </div>

  {%- comment -%} TRUST BAR — dark bg, 4 feature icons {%- endcomment -%}
  <div class="styledrop-hero__trust-bar">
    <div class="container styledrop-hero__trust-wrap">
      <div class="styledrop-hero__trust-grid">

        {%- comment -%} Feature 1 — Fast Delivery (Zap icon) {%- endcomment -%}
        <div class="styledrop-hero__trust-item">
          <div class="styledrop-hero__trust-icon-wrap">
            <svg class="styledrop-hero__trust-icon-svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/>
            </svg>
          </div>
          <div>
            <p class="styledrop-hero__trust-title">{{ section.settings.feature_1_title | default: 'Fast Delivery' }}</p>
            <p class="styledrop-hero__trust-desc">{{ section.settings.feature_1_desc | default: 'Same-day & next-day options' }}</p>
          </div>
        </div>

        {%- comment -%} Feature 2 — Easy Returns (RotateCcw icon) {%- endcomment -%}
        <div class="styledrop-hero__trust-item">
          <div class="styledrop-hero__trust-icon-wrap">
            <svg class="styledrop-hero__trust-icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.67" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
            </svg>
          </div>
          <div>
            <p class="styledrop-hero__trust-title">{{ section.settings.feature_2_title | default: 'Easy Returns' }}</p>
            <p class="styledrop-hero__trust-desc">{{ section.settings.feature_2_desc | default: 'Free 30-day hassle-free returns' }}</p>
          </div>
        </div>

        {%- comment -%} Feature 3 — Secure Checkout (ShieldCheck icon) {%- endcomment -%}
        <div class="styledrop-hero__trust-item">
          <div class="styledrop-hero__trust-icon-wrap">
            <svg class="styledrop-hero__trust-icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.67" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
            </svg>
          </div>
          <div>
            <p class="styledrop-hero__trust-title">{{ section.settings.feature_3_title | default: 'Secure Checkout' }}</p>
            <p class="styledrop-hero__trust-desc">{{ section.settings.feature_3_desc | default: '256-bit SSL encrypted payments' }}</p>
          </div>
        </div>

        {%- comment -%} Feature 4 — Trusted Brands (Star icon) {%- endcomment -%}
        <div class="styledrop-hero__trust-item">
          <div class="styledrop-hero__trust-icon-wrap">
            <svg class="styledrop-hero__trust-icon-svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2l2.39 4.84 5.34.78-3.87 3.77.91 5.32L12 14.77l-4.77 2.51.91-5.32L4.27 7.62l5.34-.78L12 2z"/>
            </svg>
          </div>
          <div>
            <p class="styledrop-hero__trust-title">{{ section.settings.feature_4_title | default: 'Trusted Brands' }}</p>
            <p class="styledrop-hero__trust-desc">{{ section.settings.feature_4_desc | default: '200+ verified fashion brands' }}</p>
          </div>
        </div>

      </div>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "style-drop-hero section",
  "tag": "section",
  "class": "styledrop-hero-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Tagline row — text"
    },
    {
      "type": "text",
      "id": "tagline_1",
      "label": "Tagline 1",
      "default": "MOVE FREELY"
    },
    {
      "type": "text",
      "id": "tagline_2",
      "label": "Tagline 2",
      "default": "LIVE BOLDLY"
    },
    {
      "type": "text",
      "id": "tagline_3",
      "label": "Tagline 3",
      "default": "FEEL ICONIC"
    },
    {
      "type": "header",
      "content": "Tagline row — font size"
    },
    {
      "type": "range",
      "id": "tagline_size_mobile",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Taglines (mobile)",
      "default": 12
    },
    {
      "type": "range",
      "id": "tagline_size_desktop",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Taglines (desktop)",
      "default": 12
    },
    {
      "type": "header",
      "content": "Same-day delivery badge — size"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "SAME-DAY DELIVERY"
    },
    {
      "type": "range",
      "id": "badge_text_size_mobile",
      "min": 7,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Badge text (mobile)",
      "default": 9
    },
    {
      "type": "range",
      "id": "badge_text_size_desktop",
      "min": 7,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Badge text (desktop)",
      "default": 11
    },
    {
      "type": "range",
      "id": "badge_icon_size_mobile",
      "min": 6,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Badge icon (mobile)",
      "default": 9
    },
    {
      "type": "range",
      "id": "badge_icon_size_desktop",
      "min": 6,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Badge icon (desktop)",
      "default": 11
    },
    {
      "type": "range",
      "id": "badge_height_mobile",
      "min": 18,
      "max": 44,
      "step": 1,
      "unit": "px",
      "label": "Badge min height (mobile)",
      "default": 22
    },
    {
      "type": "range",
      "id": "badge_height_desktop",
      "min": 18,
      "max": 44,
      "step": 1,
      "unit": "px",
      "label": "Badge min height (desktop)",
      "default": 29
    },
    {
      "type": "header",
      "content": "Headline — WEAR WHAT / DROPS / TODAY"
    },
    {
      "type": "text",
      "id": "headline_line_1",
      "label": "Headline line 1",
      "default": "WEAR WHAT"
    },
    {
      "type": "text",
      "id": "headline_line_2",
      "label": "Headline line 2 (red)",
      "default": "DROPS"
    },
    {
      "type": "text",
      "id": "headline_line_3",
      "label": "Headline line 3",
      "default": "TODAY."
    },
    {
      "type": "range",
      "id": "headline_size_mobile",
      "min": 32,
      "max": 120,
      "step": 1,
      "unit": "px",
      "label": "Headline font size (mobile)",
      "default": 56
    },
    {
      "type": "range",
      "id": "headline_size_desktop",
      "min": 48,
      "max": 140,
      "step": 1,
      "unit": "px",
      "label": "Headline font size (desktop)",
      "default": 99
    },
    {
      "type": "range",
      "id": "headline_line_height_mobile",
      "min": 28,
      "max": 120,
      "step": 1,
      "unit": "px",
      "label": "Headline line height (mobile)",
      "default": 50
    },
    {
      "type": "range",
      "id": "headline_line_height_desktop",
      "min": 40,
      "max": 130,
      "step": 1,
      "unit": "px",
      "label": "Headline line height (desktop)",
      "default": 87
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description text",
      "default": "Multi-brand fashion delivered fast. Discover trending styles from the brands you love — with full transparency on pricing and returns."
    },
    {
      "type": "range",
      "id": "description_size_mobile",
      "min": 11,
      "max": 22,
