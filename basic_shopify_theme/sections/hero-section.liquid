{% comment %}
  Hero Section
  
  Converts React HeroSection to Shopify section
  Source: src/sections/HeroSection.tsx
  
  Features:
  - Hero banner with headline and CTAs
  - "Same-day delivery" badge
  - Featured product card overlay (desktop only)
  - Trust features bar (4 features)
  - Fully responsive (mobile/desktop)
  - Configurable via Theme Editor
  
  Usage:
  Add to homepage template or use in Theme Editor
{% endcomment %}

{%- comment -%} Hero Section Container {%- endcomment -%}
<section class="hero-section">
  {%- comment -%} Main Hero Banner {%- endcomment -%}
  <div class="bg-[#F5F0EB] min-h-[702px] flex flex-col pt-6 md:pt-0">
    <div class="container px-8 flex flex-col flex-1">
      
      {%- comment -%} Top Row: MOVE FREELY | LIVE BOLDLY | FEEL ICONIC (Desktop only) {%- endcomment -%}
      <div class="hidden md:flex flex-row justify-between items-center h-[82px] shrink-0">
        <p class="font-condensed text-[12px] font-bold leading-[18px] tracking-[2.4px] text-[#0D0D0D]/40 uppercase">
          {{ section.settings.tagline_1 | default: 'MOVE FREELY' }}
        </p>
        <p class="font-condensed text-[12px] font-bold leading-[18px] tracking-[2.4px] text-[#0D0D0D]/40 uppercase">
          {{ section.settings.tagline_2 | default: 'LIVE BOLDLY' }}
        </p>
        <p class="font-condensed text-[12px] font-bold leading-[18px] tracking-[2.4px] text-[#0D0D0D]/40 uppercase">
          {{ section.settings.tagline_3 | default: 'FEEL ICONIC' }}
        </p>
      </div>

      {%- comment -%} Content Row: Text + Image {%- endcomment -%}
      <div class="flex flex-1 flex-col md:flex-row md:items-center justify-between gap-8 md:gap-12 pb-12 md:pb-0">
        
        {%- comment -%} Left Column: Text Content {%- endcomment -%}
        <div class="flex flex-col max-w-[480px]">
          {%- comment -%} SAME-DAY DELIVERY Badge {%- endcomment -%}
          <span class="badge-accent h-[22px] md:h-[28.5px] inline-flex items-center gap-1.5 md:gap-2 rounded-full w-fit px-2 md:px-3 mb-0">
            <svg class="w-[9px] h-[9px] md:w-[11px] md:h-[11px] fill-white shrink-0" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/>
            </svg>
            <span class="font-sans text-[9px] md:text-[11px] font-bold leading-4 tracking-[0.72px] md:tracking-[0.88px] text-white uppercase">
              {{ section.settings.badge_text | default: 'SAME-DAY DELIVERY' }}
            </span>
          </span>

          {%- comment -%} Main Headline {%- endcomment -%}
          <h1 class="font-display font-normal text-[56px] md:text-[99px] leading-[50px] md:leading-[87px] tracking-[2.8px] md:tracking-[3.6px] text-[#0D0D0D] mt-4 md:mt-6 mb-5 md:mb-8" style="font-family: 'Bebas Neue', sans-serif; font-weight: 400;">
            <span class="block">{{ section.settings.headline_line_1 | default: 'WEAR WHAT' }}</span>
            <span class="block text-[#DC2626]">{{ section.settings.headline_line_2 | default: 'DROPS' }}</span>
            <span class="block">{{ section.settings.headline_line_3 | default: 'TODAY.' }}</span>
          </h1>

          {%- comment -%} Description {%- endcomment -%}
          <p class="font-sans text-[13px] md:text-[15px] leading-5 md:leading-6 text-[#0D0D0D]/55 max-w-[320px] mb-6 md:mb-8">
            {{ section.settings.description | default: 'Multi-brand fashion delivered fast. Discover trending styles from the brands you love — with full transparency on pricing and returns.' }}
          </p>

          {%- comment -%} CTA Buttons {%- endcomment -%}
          <div class="flex flex-col md:flex-row gap-4 md:gap-6 items-start md:items-center mb-10">
            <a href="{{ section.settings.cta_primary_link | default: '/collections/all' }}">
              <button class="btn-accent font-condensed text-sm md:text-base font-bold uppercase tracking-[1.68px] md:tracking-[1.92px] h-[44px] md:h-[52px] px-5 md:px-7 rounded-full">
                {{ section.settings.cta_primary_text | default: "Shop What's Trending" }}
              </button>
            </a>
            <a href="{{ section.settings.cta_secondary_link | default: '/collections/new-arrivals' }}" class="font-sans text-xs md:text-sm font-semibold text-[#0D0D0D] border-b border-[#0D0D0D] pb-0.5 hover:opacity-80 inline-flex items-center gap-2">
              {{ section.settings.cta_secondary_text | default: 'Explore New Arrivals' }}
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        {%- comment -%} Right Column: Hero Image + Overlays {%- endcomment -%}
        <div class="relative w-full max-w-[570px] aspect-[480/620] md:aspect-auto md:h-[620px] shrink-0">
          {%- comment -%} Main Hero Image {%- endcomment -%}
          {%- if section.settings.hero_image -%}
            <img
              src="{{ section.settings.hero_image | img_url: '800x' }}"
              alt="{{ section.settings.hero_image.alt | default: 'Fashion model' }}"
              class="absolute inset-0 w-full h-full object-cover rounded-t-[20px]"
              loading="eager"
            />
          {%- else -%}
            <div class="absolute inset-0 w-full h-full bg-gray-200 rounded-t-[20px] flex items-center justify-center">
              <p class="text-gray-500">Upload hero image</p>
            </div>
          {%- endif -%}

          {%- comment -%} FAST DROP Badge Overlay {%- endcomment -%}
          {%- if section.settings.show_fast_drop_badge -%}
            <div class="absolute -left-[15px] top-5 pl-[14px] pr-4 py-2 flex flex-col gap-0.5 rounded-full bg-[#0D0D0D] shadow-[0px_8px_24px_rgba(0,0,0,0.2)] z-10">
              <div class="flex items-center gap-1.5">
                <span class="text-white text-lg leading-[27px]">⚡</span>
                <span class="font-sans text-[10px] font-bold leading-[15px] tracking-[0.6px] text-white uppercase">FAST DROP</span>
              </div>
              <span class="font-sans text-[9px] leading-[14px] text-white/60">Delivered today</span>
            </div>
          {%- endif -%}

          {%- comment -%} Product Card Overlay (Desktop only) {%- endcomment -%}
          {%- if section.settings.featured_product != blank -%}
            {%- assign featured_product = all_products[section.settings.featured_product] -%}
            {%- if featured_product -%}
              <div class="hidden md:block absolute left-[340px] top-[367.5px] w-[160px] min-h-[192px] bg-white rounded-2xl p-3 shadow-[0px_20px_60px_rgba(0,0,0,0.15)] z-10 flex flex-col">
                {%- if featured_product.featured_image -%}
                  <img 
                    src="{{ featured_product.featured_image | img_url: '200x' }}" 
                    alt="{{ featured_product.title }}" 
                    class="w-[136px] h-[100px] rounded-[10px] object-cover self-start"
                    loading="lazy"
                  />
                {%- endif -%}
                <p class="font-condensed text-[10px] font-bold leading-[15px] tracking-[1px] text-[#0D0D0D]/50 uppercase mt-2">
                  {{ featured_product.vendor | upcase }}
                </p>
                <p class="font-sans text-[12px] font-semibold leading-[18px] text-[#0D0D0D] mt-1">
                  {{ featured_product.title | truncate: 20 }}
                </p>
                <div class="flex flex-row justify-between items-center gap-2 mt-3">
                  <span class="font-sans text-[13px] font-bold leading-5 text-[#0D0D0D]">
                    {{ featured_product.price | money }}
                  </span>
                  <span class="font-sans text-[9px] font-bold leading-[14px] tracking-[0.45px] text-[#0D0D0D] px-[6px] py-[1.8px] rounded-full bg-[#F5F0EB] uppercase">
                    FREE RTN
                  </span>
                </div>
              </div>
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Trust Features Bar {%- endcomment -%}
  <div class="bg-[#0D0D0D] text-white">
    <div class="container flex justify-center py-8">
      <div class="w-full max-w-[1141px] grid grid-cols-2 md:grid-cols-4 gap-6 items-center">
        
        {%- comment -%} Feature 1: Fast Delivery {%- endcomment -%}
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: rgba(232, 76, 30, 0.12);">
            <svg class="w-5 h-5 text-[#DC2626]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/>
            </svg>
          </div>
          <div>
            <p class="font-condensed text-[15px] font-bold leading-[22px] tracking-[0.9px] uppercase text-white">
              {{ section.settings.feature_1_title | default: 'Fast Delivery' }}
            </p>
            <p class="font-sans text-[12px] font-normal leading-[17px] text-white/45 mt-0.5">
              {{ section.settings.feature_1_desc | default: 'Same-day & next-day options' }}
            </p>
          </div>
        </div>

        {%- comment -%} Feature 2: Easy Returns {%- endcomment -%}
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: rgba(232, 76, 30, 0.12);">
            <svg class="w-5 h-5 text-[#DC2626]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.67">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
            </svg>
          </div>
          <div>
            <p class="font-condensed text-[15px] font-bold leading-[22px] tracking-[0.9px] uppercase text-white">
              {{ section.settings.feature_2_title | default: 'Easy Returns' }}
            </p>
            <p class="font-sans text-[12px] font-normal leading-[17px] text-white/45 mt-0.5">
              {{ section.settings.feature_2_desc | default: 'Free 30-day hassle-free returns' }}
            </p>
          </div>
        </div>

        {%- comment -%} Feature 3: Secure Checkout {%- endcomment -%}
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: rgba(232, 76, 30, 0.12);">
            <svg class="w-5 h-5 text-[#DC2626]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.67">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
            </svg>
          </div>
          <div>
            <p class="font-condensed text-[15px] font-bold leading-[22px] tracking-[0.9px] uppercase text-white">
              {{ section.settings.feature_3_title | default: 'Secure Checkout' }}
            </p>
            <p class="font-sans text-[12px] font-normal leading-[17px] text-white/45 mt-0.5">
              {{ section.settings.feature_3_desc | default: '256-bit SSL encrypted payments' }}
            </p>
          </div>
        </div>

        {%- comment -%} Feature 4: Trusted Brands {%- endcomment -%}
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: rgba(232, 76, 30, 0.12);">
            <svg class="w-5 h-5 text-[#DC2626]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2l2.39 4.84 5.34.78-3.87 3.77.91 5.32L12 14.77l-4.77 2.51.91-5.32L4.27 7.62l5.34-.78L12 2z"/>
            </svg>
          </div>
          <div>
            <p class="font-condensed text-[15px] font-bold leading-[22px] tracking-[0.9px] uppercase text-white">
              {{ section.settings.feature_4_title | default: 'Trusted Brands' }}
            </p>
            <p class="font-sans text-[12px] font-normal leading-[17px] text-white/45 mt-0.5">
              {{ section.settings.feature_4_desc | default: '200+ verified fashion brands' }}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
