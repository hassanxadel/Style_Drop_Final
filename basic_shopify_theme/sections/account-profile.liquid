{% comment %}
  StyleDrop — Account hub (Overview, Orders, Addresses, Settings, Liked).
  Create five pages with handles account-overview, account-orders, account-addresses, account-settings, account-liked
  and assign the matching templates. Accent: #DC2626.
{% endcomment %}

{{ 'styledrop-account.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign tab = section.settings.active_tab
  assign wishlist_url = section.settings.wishlist_page
  if wishlist_url == blank
    assign wishlist_url = '/pages/wishlist'
  endif

  assign u_overview = section.settings.url_overview
  if u_overview == blank
    if pages['account-overview'] != blank
      assign u_overview = pages['account-overview'].url
    else
      assign u_overview = '/pages/account-overview'
    endif
  endif

  assign u_orders = section.settings.url_orders
  if u_orders == blank
    if pages['account-orders'] != blank
      assign u_orders = pages['account-orders'].url
    else
      assign u_orders = '/pages/account-orders'
    endif
  endif

  assign u_addresses = section.settings.url_addresses
  if u_addresses == blank
    if pages['account-addresses'] != blank
      assign u_addresses = pages['account-addresses'].url
    else
      assign u_addresses = '/pages/account-addresses'
    endif
  endif

  assign u_settings = section.settings.url_settings
  if u_settings == blank
    if pages['account-settings'] != blank
      assign u_settings = pages['account-settings'].url
    else
      assign u_settings = '/pages/account-settings'
    endif
  endif

  assign u_liked = section.settings.url_liked
  if u_liked == blank
    if pages['account-liked'] != blank
      assign u_liked = pages['account-liked'].url
    else
      assign u_liked = '/pages/account-liked'
    endif
  endif

  if customer
    assign display_name = customer.name
    assign display_email = customer.email
    assign fn = customer.first_name | default: '' | slice: 0, 1
    assign ln = customer.last_name | default: '' | slice: 0, 1
    assign initials = fn | append: ln | upcase
    if initials == blank
      assign initials = section.settings.demo_initials
    endif
  else
    assign display_name = section.settings.demo_name
    assign display_email = section.settings.demo_email
    assign initials = section.settings.demo_initials
  endif

  assign thumb_a = 'https://placehold.co/160x160/e8e4df/0d0d0d?text=SD'
  assign thumb_b = thumb_a
  if collections.all.products.size > 0
    assign p0 = collections.all.products.first
    if p0.featured_image
      assign thumb_a = p0.featured_image | image_url: width: 200
    endif
  endif
  if collections.all.products.size > 1
    assign p1 = collections.all.products[1]
    if p1.featured_image
      assign thumb_b = p1.featured_image | image_url: width: 200
    endif
  endif
-%}

{%- if tab == 'liked' -%}
  {{ 'styledrop-wishlist.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<section class="sd-account" data-account-tab="{{ tab }}">
  <div class="sd-account__container">
    <div class="sd-account__banner">
      <div class="sd-account__banner-bg" aria-hidden="true"></div>
      <div class="sd-account__banner-inner">
        <div class="sd-account__avatar-wrap">
          <div class="sd-account__avatar">{{ initials | escape }}</div>
          <span class="sd-account__avatar-cam" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>
            </svg>
          </span>
        </div>
        <div class="sd-account__banner-text">
          <p class="sd-account__name">{{ display_name | escape }}</p>
          <p class="sd-account__email">{{ display_email | escape }}</p>
        </div>
      </div>
    </div>

    <nav class="sd-account__tabs" aria-label="{{ section.settings.tabs_aria_label | escape }}">
      <a
        href="{{ u_overview }}"
        class="sd-account__tab{% if tab == 'overview' %} sd-account__tab--active{% endif %}"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        {{ section.settings.label_overview }}
      </a>
      <a
        href="{{ u_orders }}"
        class="sd-account__tab{% if tab == 'orders' %} sd-account__tab--active{% endif %}"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        {{ section.settings.label_orders }}
        <span class="sd-account__tab-badge">{{ section.settings.orders_badge_count }}</span>
      </a>
      <a
        href="{{ u_addresses }}"
        class="sd-account__tab{% if tab == 'addresses' %} sd-account__tab--active{% endif %}"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {{ section.settings.label_addresses }}
      </a>
      <a
        href="{{ u_settings }}"
        class="sd-account__tab{% if tab == 'settings' %} sd-account__tab--active{% endif %}"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        {{ section.settings.label_settings }}
      </a>
      <a
        href="{{ u_liked }}"
        class="sd-account__tab{% if tab == 'liked' %} sd-account__tab--active{% endif %}"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        {{ section.settings.label_liked }}
      </a>
    </nav>

    <div class="sd-account__main">
      {%- if tab == 'overview' -%}
        <div class="sd-account__stats">
          <div class="sd-account__stat-card">
            <div class="sd-account__stat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            </div>
            <p class="sd-account__stat-value">{{ section.settings.stat_orders }}</p>
            <p class="sd-account__stat-label">{{ section.settings.stat_orders_label }}</p>
          </div>
          <div class="sd-account__stat-card">
            <div class="sd-account__stat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </div>
            <p class="sd-account__stat-value">{{ section.settings.stat_liked }}</p>
            <p class="sd-account__stat-label">{{ section.settings.stat_liked_label }}</p>
          </div>
          <div class="sd-account__stat-card">
            <div class="sd-account__stat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <p class="sd-account__stat-value">{{ section.settings.stat_addresses }}</p>
            <p class="sd-account__stat-label">{{ section.settings.stat_addresses_label }}</p>
          </div>
          <div class="sd-account__stat-card">
            <div class="sd-account__stat-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            </div>
            <p class="sd-account__stat-value">{{ cart.item_count | default: section.settings.stat_cart_fallback }}</p>
            <p class="sd-account__stat-label">{{ section.settings.stat_cart_label }}</p>
          </div>
        </div>

        <div class="sd-account__card" style="margin-top: 1.5rem;">
          <div class="sd-account__card-head">
            <h2 class="sd-account__card-title">{{ section.settings.recent_orders_title }}</h2>
            <a href="{{ u_orders }}" class="sd-account__link">
              {{ section.settings.view_all_label }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div>
            <div class="sd-account__order-row">
              <div class="sd-account__thumb">
                <img src="{{ thumb_a }}" alt="" width="160" height="160" loading="lazy">
              </div>
              <div style="flex: 1; min-width: 0;">
                <p style="font-weight: 700; color: #0d0d0d; font-size: 0.875rem;">#{{ section.settings.demo_order_1_id }}</p>
                <p style="font-size: 0.75rem; color: rgba(13,13,13,0.5); margin-top: 0.125rem;">{{ section.settings.demo_order_1_meta }}</p>
              </div>
              <div style="text-align: right; flex-shrink: 0;">
                <span class="sd-account__badge sd-account__badge--delivered">{{ section.settings.status_delivered }}</span>
                <p style="font-weight: 700; margin-top: 0.35rem;">{{ section.settings.demo_order_1_price }}</p>
              </div>
            </div>
            <div class="sd-account__order-row">
              <div class="sd-account__thumb">
                <img src="{{ thumb_b }}" alt="" width="160" height="160" loading="lazy">
              </div>
              <div style="flex: 1; min-width: 0;">
                <p style="font-weight: 700; color: #0d0d0d; font-size: 0.875rem;">#{{ section.settings.demo_order_2_id }}</p>
                <p style="font-size: 0.75rem; color: rgba(13,13,13,0.5); margin-top: 0.125rem;">{{ section.settings.demo_order_2_meta }}</p>
              </div>
              <div style="text-align: right; flex-shrink: 0;">
                <span class="sd-account__badge sd-account__badge--shipped">{{ section.settings.status_shipped }}</span>
                <p style="font-weight: 700; margin-top: 0.35rem;">{{ section.settings.demo_order_2_price }}</p>
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- if tab == 'orders' -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'order_card' -%}
            <div class="sd-account__order-card" {{ block.shopify_attributes }}>
              <div class="sd-account__order-top">
                <div>
                  <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem;">
                    <span style="font-weight: 700; color: #0d0d0d;">#{{ block.settings.order_id }}</span>
                    <span class="sd-account__badge sd-account__badge--{{ block.settings.status_class }}">{{ block.settings.status_label }}</span>
                  </div>
                  <p style="font-size: 0.75rem; color: rgba(13,13,13,0.5); margin-top: 0.25rem;">{{ block.settings.meta }}</p>
                </div>
                <div style="text-align: right;">
                  <p style="font-weight: 700; font-size: 1.125rem;">{{ block.settings.total }}</p>
                  <p style="font-size: 10px; color: rgba(13,13,13,0.45); text-transform: uppercase;">{{ block.settings.currency }}</p>
                </div>
              </div>
              {%- if block.settings.line1_title != blank -%}
                <div class="sd-account__line">
                  <div class="sd-account__thumb">
                    <img src="{{ block.settings.line1_image | image_url: width: 200 }}" alt="" width="160" height="160" loading="lazy">
                  </div>
                  <div style="flex: 1; display: flex; justify-content: space-between; gap: 0.75rem;">
                    <div>
                      <p style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: rgba(13,13,13,0.45);">{{ block.settings.line1_brand }}</p>
                      <p style="font-weight: 600; color: #0d0d0d; font-size: 0.875rem;">{{ block.settings.line1_title }}</p>
                      <p style="font-size: 0.75rem; color: rgba(13,13,13,0.5);">{{ block.settings.line1_spec }}</p>
                    </div>
                    <p style="font-weight: 700; font-size: 0.875rem;">{{ block.settings.line1_price }}</p>
                  </div>
                </div>
              {%- endif -%}
              {%- if block.settings.line2_title != blank -%}
                <div class="sd-account__line">
                  <div class="sd-account__thumb">
                    {%- if block.settings.line2_image != blank -%}
                      <img src="{{ block.settings.line2_image | image_url: width: 200 }}" alt="" width="160" height="160" loading="lazy">
                    {%- else -%}
                      <img src="{{ thumb_b }}" alt="" width="160" height="160" loading="lazy">
                    {%- endif -%}
                  </div>
                  <div style="flex: 1; display: flex; justify-content: space-between; gap: 0.75rem;">
                    <div>
                      <p style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: rgba(13,13,13,0.45);">{{ block.settings.line2_brand }}</p>
                      <p style="font-weight: 600; color: #0d0d0d; font-size: 0.875rem;">{{ block.settings.line2_title }}</p>
                      <p style="font-size: 0.75rem; color: rgba(13,13,13,0.5);">{{ block.settings.line2_spec }}</p>
                    </div>
                    <p style="font-weight: 700; font-size: 0.875rem;">{{ block.settings.line2_price }}</p>
                  </div>
                </div>
              {%- endif -%}
              <div class="sd-account__actions">
                {%- if block.settings.show_track -%}
                  <button type="button" class="sd-account__btn sd-account__btn--track">{{ section.settings.btn_track }}</button>
                {%- endif -%}
                {%- if block.settings.show_buy_again -%}
                  <button type="button" class="sd-account__btn sd-account__btn--buy">{{ section.settings.btn_buy_again }}</button>
                {%- endif -%}
                <button type="button" class="sd-account__btn sd-account__btn--grey">{{ section.settings.btn_view_details }}</button>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if tab == 'addresses' -%}
        <div class="sd-account__addr-head">
          <p class="sd-account__addr-count">{{ section.settings.address_count_text }}</p>
          <a href="{{ routes.account_addresses_url }}" class="sd-account__btn-add">{{ section.settings.add_address_label }}</a>
        </div>
        <div class="sd-account__addr-card sd-account__addr-card--default">
          <div class="sd-account__addr-top">
            <div class="sd-account__addr-label-row">
              <div class="sd-account__addr-icon sd-account__addr-icon--dark">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <p class="sd-account__addr-title">{{ section.settings.addr_home_title }}</p>
            </div>
            <span class="sd-account__addr-default">{{ section.settings.addr_default_badge }}</span>
          </div>
          <div class="sd-account__addr-lines">{{ section.settings.addr_home_body | newline_to_br }}</div>
          <div class="sd-account__addr-actions">
            <button type="button" class="sd-account__btn-light">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              {{ section.settings.btn_edit }}
            </button>
            <button type="button" class="sd-account__btn-del">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              {{ section.settings.btn_delete }}
            </button>
          </div>
        </div>
        <div class="sd-account__addr-card">
          <div class="sd-account__addr-top">
            <div class="sd-account__addr-label-row">
              <div class="sd-account__addr-icon sd-account__addr-icon--light">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <p class="sd-account__addr-title">{{ section.settings.addr_work_title }}</p>
            </div>
          </div>
          <div class="sd-account__addr-lines">{{ section.settings.addr_work_body | newline_to_br }}</div>
          <div class="sd-account__addr-actions">
            <button type="button" class="sd-account__btn-light">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              {{ section.settings.btn_edit }}
            </button>
            <button type="button" class="sd-account__btn-light">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              {{ section.settings.btn_set_default }}
            </button>
            <button type="button" class="sd-account__btn-del">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              {{ section.settings.btn_delete }}
            </button>
          </div>
        </div>
      {%- endif -%}

      {%- if tab == 'settings' -%}
        <div class="sd-account__settings-stack">
          <div class="sd-account__settings-card">
            <div class="sd-account__settings-head">
              <h2 class="sd-account__settings-title">{{ section.settings.personal_title }}</h2>
              <button type="button" class="sd-account__btn-edit">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                {{ section.settings.btn_edit_small }}
              </button>
            </div>
            <div class="sd-account__form-grid">
              <div>
                <label class="sd-account__label">{{ section.settings.lbl_first }}</label>
                <input class="sd-account__input" type="text" value="{{ section.settings.demo_first | escape }}" readonly>
              </div>
              <div>
                <label class="sd-account__label">{{ section.settings.lbl_last }}</label>
                <input class="sd-account__input" type="text" value="{{ section.settings.demo_last | escape }}" readonly>
              </div>
              <div class="sd-account__field-full">
                <label class="sd-account__label">{{ section.settings.lbl_email }}</label>
                <input class="sd-account__input" type="email" value="{{ display_email | escape }}" readonly>
              </div>
              <div class="sd-account__field-full">
                <label class="sd-account__label">{{ section.settings.lbl_phone }}</label>
                <input class="sd-account__input" type="text" value="{{ section.settings.demo_phone | escape }}" readonly>
              </div>
              <div class="sd-account__field-full">
                <label class="sd-account__label">{{ section.settings.lbl_bio }}</label>
                <textarea class="sd-account__input sd-account__textarea" placeholder="{{ section.settings.bio_placeholder | escape }}" rows="4" readonly></textarea>
              </div>
            </div>
          </div>

          <div class="sd-account__settings-card">
            <h2 class="sd-account__settings-title" style="margin-bottom: 1.5rem;">{{ section.settings.password_title }}</h2>
            <div class="sd-account__form-grid" style="grid-template-columns: 1fr;">
              <div>
                <label class="sd-account__label">{{ section.settings.lbl_cur_pw }}</label>
                <div class="sd-account__pw-wrap">
                  <input class="sd-account__input" type="password" value="••••••••" readonly style="padding-right: 2.75rem;">
                  <button type="button" class="sd-account__pw-toggle" aria-label="Toggle password" tabindex="-1">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  </button>
                </div>
              </div>
              <div>
                <label class="sd-account__label">{{ section.settings.lbl_new_pw }}</label>
                <div class="sd-account__pw-wrap">
                  <input class="sd-account__input" type="password" value="••••••••" readonly style="padding-right: 2.75rem;">
                  <button type="button" class="sd-account__pw-toggle" aria-label="Toggle password" tabindex="-1">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  </button>
                </div>
              </div>
              <div>
                <label class="sd-account__label">{{ section.settings.lbl_confirm_pw }}</label>
                <div class="sd-account__pw-wrap">
                  <input class="sd-account__input" type="password" value="••••••••" readonly style="padding-right: 2.75rem;">
                  <button type="button" class="sd-account__pw-toggle" aria-label="Toggle password" tabindex="-1">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  </button>
                </div>
              </div>
            </div>
            <button type="button" class="sd-account__btn-black">{{ section.settings.btn_update_password }}</button>
          </div>

          <div class="sd-account__settings-card">
            <h2 class="sd-account__danger-title">{{ section.settings.danger_title }}</h2>
            <p class="sd-account__danger-sub">{{ section.settings.danger_sub }}</p>
            <div class="sd-account__danger-actions">
              <button type="button" class="sd-account__btn-del">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                {{ section.settings.btn_delete_account }}
              </button>
              <a href="{{ routes.account_logout_url }}" class="sd-account__btn-light" style="text-decoration: none;">{{ section.settings.btn_sign_out }}</a>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- if tab == 'liked' -%}
        {% render 'sd-account-wishlist-inline',
          shop_more_url: section.settings.wishlist_shop_more_url,
          eyebrow: section.settings.wishlist_eyebrow,
          title_1: section.settings.wishlist_title_1,
          title_2: section.settings.wishlist_title_2,
          items_label: section.settings.wishlist_items_label,
          shop_more_label: section.settings.wishlist_shop_more_label,
          loading_text: section.settings.wishlist_loading,
          empty_text: section.settings.wishlist_empty,
          empty_cta: section.settings.wishlist_empty_cta,
          cta_title: section.settings.wishlist_cta_title,
          cta_subtitle: section.settings.wishlist_cta_sub,
          add_all_label: section.settings.wishlist_add_all,
          view_cart_label: section.settings.wishlist_view_cart
        %}
      {%- endif -%}
    </div>
  </div>
</section>

