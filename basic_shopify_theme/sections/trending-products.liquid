{% comment %}
  Trending Products Section
  Converted from: src/sections/TrendingSection.tsx

  Features:
  - Dark background (#0D0D0D)
  - Section heading with yellow badge
  - 4-column grid (desktop) / 2 visible + horizontal scroll (mobile)
  - Product cards with badges
  - Wishlist button
  - "Free Returns" badge
  - Hover effects

  Usage:
  Add to homepage template or use in Theme Editor
{% endcomment %}

{{ 'styledrop-trending-products.css' | asset_url | stylesheet_tag }}

<section class="styledrop-trending">
  <div class="styledrop-trending__container">

    {%- comment -%} Section Header {%- endcomment -%}
    <div class="styledrop-trending__header">
      <div>
        {%- comment -%} Yellow Badge {%- endcomment -%}
        <span class="styledrop-trending__badge">
          {{ section.settings.badge_text | default: 'Trending Now' }}
        </span>

        {%- comment -%} Section Heading {%- endcomment -%}
        <h2 class="styledrop-trending__heading sub-heading-stretch-up">
          {{ section.settings.heading_line_1 | default: 'STYLES THE INTERNET' }}
          <br>
          <span class="styledrop-trending__heading-line--red">{{ section.settings.heading_line_2 | default: "CAN'T STOP" }}</span> {{ section.settings.heading_line_3 | default: 'WEARING' }}
        </h2>
      </div>

      {%- comment -%} View All Link {%- endcomment -%}
      <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="styledrop-trending__view-all">
        {{ section.settings.view_all_text | default: 'View all' }}
        <span aria-hidden="true" class="styledrop-trending__view-all-arrow">→</span>
      </a>
    </div>

    {%- comment -%} Product Grid: horizontal scroll mobile, 4-col desktop {%- endcomment -%}
    <div class="styledrop-trending__grid">

      {%- assign collection_handle = section.settings.collection | default: 'all' -%}
      {%- assign collection = collections[collection_handle] -%}
      {%- assign product_limit = section.settings.product_limit | default: 4 -%}

      {%- if collection and collection.products.size > 0 -%}
        {%- for product in collection.products limit: product_limit -%}
          <a
            href="{{ product.url }}"
            class="styledrop-trending__card"
          >
            {%- comment -%} Product Image {%- endcomment -%}
            <div class="styledrop-trending__card-media">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | img_url: '400x' }}"
                  alt="{{ product.title }}"
                  class="styledrop-trending__card-img"
                  width="400"
                  height="415"
                  loading="lazy"
                />
              {%- endif -%}

              {%- comment -%} Product Badges {%- endcomment -%}
              <div class="styledrop-trending__badge-wrap">
                {%- if product.tags contains 'sale' or product.compare_at_price > product.price -%}
                  <span class="styledrop-trending__status-badge styledrop-trending__status-badge--red">
                    ● SALE
                  </span>
                {%- elsif product.tags contains 'bestseller' or product.tags contains 'best seller' -%}
                  <span class="styledrop-trending__status-badge styledrop-trending__status-badge--red">
                    ● BEST SELLER
                  </span>
                {%- elsif product.tags contains 'new' -%}
                  <span class="styledrop-trending__status-badge styledrop-trending__status-badge--red">
                    ● NEW IN
                  </span>
                {%- elsif product.tags contains 'trending' -%}
                  <span class="styledrop-trending__status-badge styledrop-trending__status-badge--red">
                    ● TRENDING
                  </span>
                {%- endif -%}

                {%- if product.tags contains 'fast-drop' or product.tags contains 'fast drop' -%}
                  <span class="styledrop-trending__status-badge styledrop-trending__status-badge--dark">
                    <svg class="styledrop-trending__fast-icon" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/>
                    </svg>
                    FAST DROP
                  </span>
                {%- endif -%}
              </div>

              {%- comment -%} Wishlist Button {%- endcomment -%}
              <button
                class="styledrop-trending__wishlist-btn"
                aria-label="Add to wishlist"
                data-product-id="{{ product.id }}"
                onclick="event.preventDefault(); sdToggleWishlist({{ product.id }}, this);"
              >
                <svg class="styledrop-trending__wishlist-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.25">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                </svg>
              </button>
            </div>

            {%- comment -%} Product Info {%- endcomment -%}
            <div class="styledrop-trending__card-info">
              <p class="styledrop-trending__card-vendor">
                {{ product.vendor | upcase }}
              </p>
              <p class="styledrop-trending__card-title">
                {{ product.title }}
              </p>
              <div class="styledrop-trending__price-row">
                <span class="styledrop-trending__price">
                  {{ product.price | money }}
                </span>
                <span class="styledrop-trending__rtn-badge">
                  ↩ Free Returns
                </span>
              </div>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        <div class="styledrop-trending__empty">
          <p>No products available. Select a collection in Theme Editor.</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment -%} Wishlist JavaScript – Valgara-compliant: no Tailwind class names in JS {%- endcomment -%}
<script>
  function sdToggleWishlist(productId, btn) {
    let wishlist = JSON.parse(localStorage.getItem('sd_wishlist') || '[]');
    const index = wishlist.indexOf(productId);

    if (index > -1) {
      wishlist.splice(index, 1);
      btn.classList.remove('styledrop-trending__wishlist-btn--active');
    } else {
      wishlist.push(productId);
      btn.classList.add('styledrop-trending__wishlist-btn--active');
    }

    localStorage.setItem('sd_wishlist', JSON.stringify(wishlist));
  }

  // Restore wishlist button states on page load
  document.addEventListener('DOMContentLoaded', function() {
    const wishlist = JSON.parse(localStorage.getItem('sd_wishlist') || '[]');
    wishlist.forEach(function(productId) {
      const btn = document.querySelector('.styledrop-trending__wishlist-btn[data-product-id="' + productId + '"]');
      if (btn) btn.classList.add('styledrop-trending__wishlist-btn--active');
    });
  });
</script>

{% schema %}
{
  "name": "Trending Products",
  "tag": "section",
  "class": "section-trending",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Trending Now"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading Line 1",
      "default": "STYLES THE INTERNET"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading Line 2 (Red)",
      "default": "CAN'T STOP"
    },
    {
      "type": "text",
      "id": "heading_line_3",
      "label": "Heading Line 3",
      "default": "WEARING"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Text",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select which collection to show products from"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Number of Products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "info": "Maximum number of products to display"
    }
  ],
  "presets": [
    {
      "name": "Trending Products"
    }
  ]
}
{% endschema %}
