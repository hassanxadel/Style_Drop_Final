{% comment %}
  StyleDrop 404 Section
  Converted from: src/pages/NotFound.tsx
{% endcomment %}

{{ 'styledrop-404.css' | asset_url | stylesheet_tag }}

<div class="styledrop-404">
  <div class="container styledrop-404__container">
    <h1 class="styledrop-404__number">404</h1>
    <h2 class="styledrop-404__title">PAGE NOT FOUND</h2>
    <p class="styledrop-404__message">
      {{ section.settings.message | default: "The page you're looking for doesn't exist or has been moved." }}
    </p>
    <a href="{{ routes.root_url }}" class="styledrop-404__cta">
      {{ section.settings.button_text | default: 'Back to Home' }}
    </a>
  </div>
</div>

{% schema %}
{
  "name": "StyleDrop - 404 Page",
  "tag": "section",
  "class": "section-main-404",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Error message",
      "default": "The page you're looking for doesn't exist or has been moved."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Back to Home"
    }
  ],
  "presets": [{ "name": "StyleDrop - 404 Page" }]
}
{% endschema %}
