{% comment %}
  StyleDrop Brand Products Template
  Converted from: src/pages/BrandProducts.tsx
  Valgara Pattern: All Tailwind stripped. styledrop-collection-brand__* BEM classes only.
{% endcomment %}

{{ 'styledrop-collection-brand.css' | asset_url | stylesheet_tag }}

<div class="styledrop-collection-brand">

  {%- comment -%} Brand Hero {%- endcomment -%}
  <div class="styledrop-collection-brand__hero">
    {%- if collection.image -%}
      <img src="{{ collection.image | image_url: width: 1600 }}" alt="{{ collection.title }}"
        class="styledrop-collection-brand__hero-img" loading="eager"/>
    {%- else -%}
      <div class="styledrop-collection-brand__hero-placeholder"></div>
    {%- endif -%}

    <div class="styledrop-collection-brand__hero-overlay"></div>

    <div class="styledrop-collection-brand__hero-content">
      <span class="styledrop-collection-brand__official-badge">OFFICIAL BRAND PAGE</span>
      <h1 class="styledrop-collection-brand__hero-title">{{ collection.title | upcase }}</h1>
      <a href="#products" class="styledrop-collection-brand__hero-cta">
        VIEW ALL PRODUCTS
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </a>
    </div>
  </div>

  {%- comment -%} Brand Info Section {%- endcomment -%}
  {%- if collection.description != blank or collection.metafields.custom.brand_info != blank -%}
    <div class="styledrop-collection-brand__info-section">
      <div class="container">
        <div class="styledrop-collection-brand__info-inner">
          <h2 class="styledrop-collection-brand__info-title">About {{ collection.title }}</h2>
          {%- if collection.metafields.custom.brand_info != blank -%}
            <div class="styledrop-collection-brand__info-text">{{ collection.metafields.custom.brand_info }}</div>
          {%- elsif collection.description != blank -%}
            <div class="styledrop-collection-brand__info-text">{{ collection.description }}</div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Products Section {%- endcomment -%}
  <div id="products" class="styledrop-collection-brand__products">
    <div class="container">
      <div class="styledrop-collection-brand__products-header">
        <h2 class="styledrop-collection-brand__products-title">{{ collection.title }} Collection</h2>
        <p class="styledrop-collection-brand__products-count">
          {{ collection.products_count }} product{{ collection.products_count | pluralize: '', 's' }} available
        </p>
      </div>

      {% render 'collection-filters', collection: collection, product_count: collection.products_count %}

      <div class="product-grid-container">
        {% render 'product-grid', products: collection.products, columns: 4 %}
      </div>

      {%- comment -%} Pagination {%- endcomment -%}
      {%- if paginate.pages > 1 -%}
        <div class="styledrop-collection-brand__pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="styledrop-collection-brand__page-btn" aria-label="Previous page">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="styledrop-collection-brand__page-btn">{{ part.title }}</a>
            {%- else -%}
              <span class="styledrop-collection-brand__page-btn styledrop-collection-brand__page-btn--active">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="styledrop-collection-brand__page-btn" aria-label="Next page">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "StyleDrop - Brand Products",
  "tag": "section",
  "class": "section-brand-products",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "official_badge_text", "label": "Official Badge Text", "default": "OFFICIAL BRAND PAGE" },
    { "type": "header", "content": "Products" },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 48, "step": 4, "default": 24 }
  ],
  "presets": [{ "name": "StyleDrop - Brand Products" }]
}
{% endschema %}
