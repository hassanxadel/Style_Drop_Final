{% comment %}
  Testimonials Section
  
  Converts React TestimonialsSection to Shopify section
  Source: src/sections/TestimonialsSection.tsx
  Source: src/components/TestimonialCard.tsx
  
  Features:
  - Customer testimonial cards with star ratings
  - Dark background (#0D0D0D)
  - Yellow "TESTIMONIALS" badge
  - Responsive grid (3 cols desktop, 1 visible + scroll mobile)
  - Configurable via Theme Editor (up to 6 testimonials)
  
  Usage:
  Add to homepage template or use in Theme Editor
{% endcomment %}

{%- comment -%} Testimonials Section {%- endcomment -%}
{{ 'styledrop-testimonials.css' | asset_url | stylesheet_tag }}
<section class="styledrop-testimonials">
  <div class="container">
    
    {%- comment -%} Section Header {%- endcomment -%}
    <div class="styledrop-testimonials__header">
      <div>
        {%- comment -%} Yellow Badge {%- endcomment -%}
        <span class="styledrop-testimonials__badge">
          {{ section.settings.badge_text | default: 'TESTIMONIALS' }}
        </span>

        {%- comment -%} Section Heading {%- endcomment -%}
        <h2 class="styledrop-testimonials__heading">
          {{ section.settings.heading_line_1 | default: 'FROM HAPPY' }}
          <br>
          <span class="styledrop-testimonials__heading-line--accent">{{ section.settings.heading_line_2 | default: 'SHOPPERS' }}</span>
        </h2>
      </div>
    </div>

    {%- comment -%} Testimonials Grid (3 cols desktop, 1 visible + scroll mobile) {%- endcomment -%}
    <div class="styledrop-testimonials__grid">
      
      {%- comment -%} Testimonial 1 {%- endcomment -%}
      {%- if section.settings.testimonial_1_name != blank -%}
        <div class="styledrop-testimonials__card-wrap">
          <div class="styledrop-testimonials__card">
            {%- comment -%} Star Rating {%- endcomment -%}
            <div class="styledrop-testimonials__stars">
              {%- assign rating_1 = section.settings.testimonial_1_rating | default: 5 -%}
              {%- for i in (1..5) -%}
                <svg class="styledrop-testimonials__star {% if i <= rating_1 %}styledrop-testimonials__star--filled{% else %}styledrop-testimonials__star--empty{% endif %}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                </svg>
              {%- endfor -%}
            </div>

            {%- comment -%} Testimonial Text {%- endcomment -%}
            <p class="styledrop-testimonials__review">
              "{{ section.settings.testimonial_1_text }}"
            </p>

            {%- comment -%} Customer Info {%- endcomment -%}
            <div class="styledrop-testimonials__customer">
              {%- if section.settings.testimonial_1_avatar -%}
                <img
                  src="{{ section.settings.testimonial_1_avatar | img_url: '80x80' }}"
                  alt="{{ section.settings.testimonial_1_name }}"
                  class="styledrop-testimonials__avatar"
                  width="80"
                  height="80"
                  loading="lazy"
                />
              {%- endif -%}
              <p class="styledrop-testimonials__name">
                {{ section.settings.testimonial_1_name }}
              </p>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Testimonial 2 {%- endcomment -%}
      {%- if section.settings.testimonial_2_name != blank -%}
        <div class="styledrop-testimonials__card-wrap">
          <div class="styledrop-testimonials__card">
            {%- comment -%} Star Rating {%- endcomment -%}
            <div class="styledrop-testimonials__stars">
              {%- assign rating_2 = section.settings.testimonial_2_rating | default: 5 -%}
              {%- for i in (1..5) -%}
                <svg class="styledrop-testimonials__star {% if i <= rating_2 %}styledrop-testimonials__star--filled{% else %}styledrop-testimonials__star--empty{% endif %}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                </svg>
              {%- endfor -%}
            </div>

            {%- comment -%} Testimonial Text {%- endcomment -%}
            <p class="styledrop-testimonials__review">
              "{{ section.settings.testimonial_2_text }}"
            </p>

            {%- comment -%} Customer Info {%- endcomment -%}
            <div class="styledrop-testimonials__customer">
              {%- if section.settings.testimonial_2_avatar -%}
                <img
                  src="{{ section.settings.testimonial_2_avatar | img_url: '80x80' }}"
                  alt="{{ section.settings.testimonial_2_name }}"
                  class="styledrop-testimonials__avatar"
                  width="80"
                  height="80"
                  loading="lazy"
                />
              {%- endif -%}
              <p class="styledrop-testimonials__name">
                {{ section.settings.testimonial_2_name }}
              </p>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Testimonial 3 {%- endcomment -%}
      {%- if section.settings.testimonial_3_name != blank -%}
        <div class="styledrop-testimonials__card-wrap">
          <div class="styledrop-testimonials__card">
            {%- comment -%} Star Rating {%- endcomment -%}
            <div class="styledrop-testimonials__stars">
              {%- assign rating_3 = section.settings.testimonial_3_rating | default: 5 -%}
              {%- for i in (1..5) -%}
                <svg class="styledrop-testimonials__star {% if i <= rating_3 %}styledrop-testimonials__star--filled{% else %}styledrop-testimonials__star--empty{% endif %}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                </svg>
              {%- endfor -%}
            </div>

            {%- comment -%} Testimonial Text {%- endcomment -%}
            <p class="styledrop-testimonials__review">
              "{{ section.settings.testimonial_3_text }}"
            </p>

            {%- comment -%} Customer Info {%- endcomment -%}
            <div class="styledrop-testimonials__customer">
              {%- if section.settings.testimonial_3_avatar -%}
                <img
                  src="{{ section.settings.testimonial_3_avatar | img_url: '80x80' }}"
                  alt="{{ section.settings.testimonial_3_name }}"
                  class="styledrop-testimonials__avatar"
                  width="80"
                  height="80"
                  loading="lazy"
                />
              {%- endif -%}
              <p class="styledrop-testimonials__name">
                {{ section.settings.testimonial_3_name }}
              </p>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "TESTIMONIALS"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading Line 1",
      "default": "FROM HAPPY"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading Line 2 (Red)",
      "default": "SHOPPERS"
    },
    {
      "type": "header",
      "content": "Testimonial 1"
    },
    {
      "type": "text",
      "id": "testimonial_1_name",
      "label": "Customer Name",
      "default": "Katelyn Brooks"
    },
    {
      "type": "textarea",
      "id": "testimonial_1_text",
      "label": "Review Text",
      "default": "Impressive haul, loved the curation! Fast shipping too. Quality on everything was amazing - it's now my go-to for casual and seasonal picks."
    },
    {
      "type": "range",
      "id": "testimonial_1_rating",
      "label": "Star Rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "image_picker",
      "id": "testimonial_1_avatar",
      "label": "Avatar (Optional)"
    },
    {
      "type": "header",
      "content": "Testimonial 2"
    },
    {
      "type": "text",
      "id": "testimonial_2_name",
      "label": "Customer Name",
      "default": "Ruby Cross"
    },
    {
      "type": "textarea",
      "id": "testimonial_2_text",
      "label": "Review Text",
      "default": "DROP changed the game. I no longer need to browse 10+ sites. The app makes everything easy and the selection is incredible."
    },
    {
      "type": "range",
      "id": "testimonial_2_rating",
      "label": "Star Rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "image_picker",
      "id": "testimonial_2_avatar",
      "label": "Avatar (Optional)"
    },
    {
      "type": "header",
      "content": "Testimonial 3"
    },
    {
      "type": "text",
      "id": "testimonial_3_name",
      "label": "Customer Name",
      "default": "Jordan Miles"
    },
    {
      "type": "textarea",
      "id": "testimonial_3_text",
      "label": "Review Text",
      "default": "Finally a fashion site that curates for real people. Everything fits true to size and the returns process is seamless."
    },
    {
      "type": "range",
      "id": "testimonial_3_rating",
      "label": "Star Rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "image_picker",
      "id": "testimonial_3_avatar",
      "label": "Avatar (Optional)"
    }
  ],
  "presets": [
    {
      "name": "Testimonials"
    }
  ]
}
{% endschema %}

{% comment %}
  CONVERSION NOTES:
  
  React → Liquid Conversions:
  - Removed React imports (Testimonial type, TestimonialCard component)
  - Converted testimonials array → 3 individual testimonial blocks
  - Star component → inline SVG with conditional fill
  - Made all content configurable via schema
  
  Star Rating Logic:
  - Loop through 1..5
  - If i <= rating: filled red star
  - Else: outline gray star
  - Uses SVG with conditional classes
  
  Mobile Optimization:
  - Grid: `md:grid md:grid-cols-3 md:gap-6`
  - Scroll: `flex overflow-x-auto snap-x snap-mandatory scrollbar-hide`
  - Cards: `w-full flex-shrink-0 snap-start md:w-auto`
  - Shows 1 testimonial at a time on mobile
  - Smooth snap scrolling
  
  Features:
  - ✅ Dark background (#0D0D0D)
  - ✅ Yellow badge
  - ✅ 2-line heading (second line red)
  - ✅ Star ratings (1-5, configurable)
  - ✅ Customer avatars (optional)
  - ✅ 3-column grid (desktop)
  - ✅ 1 visible + scroll (mobile)
  - ✅ White cards with gray border
  - ✅ Fully configurable in Theme Editor
  
  Schema Structure:
  - Badge text
  - Heading (2 lines)
  - 3 testimonials, each with:
    - Customer name
    - Review text (textarea)
    - Star rating (1-5 range)
    - Avatar image (optional)
  
  Usage:
  1. Add section to homepage in Theme Editor
  2. Configure badge and heading
  3. Add up to 3 testimonials:
     - Enter customer name
     - Write review text
     - Set star rating (1-5)
     - Upload avatar (optional)
  
  Optional Enhancements:
  - Could add blocks for dynamic testimonial count
  - Could integrate with review apps (Yotpo, Judge.me)
  - Could add navigation arrows (currently removed for simplicity)
  - Could add automatic rotation/carousel
  
  Review App Integration:
  If using Shopify review apps, replace static testimonials with:
  {% render 'yotpo-reviews' %} or similar
{% endcomment %}
