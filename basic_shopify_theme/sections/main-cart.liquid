{% comment %}
  StyleDrop Cart Template
  Converted from: src/pages/Cart.tsx + src/components/CartItemCard.tsx
  Valgara Pattern: All Tailwind stripped. styledrop-cart__* BEM classes only.
{% endcomment %}

{{ 'styledrop-cart.css' | asset_url | stylesheet_tag }}

{%- comment -%} Back Navigation {%- endcomment -%}
<div class="styledrop-cart__backbar">
  <div class="container">
    <a href="/collections/all" class="styledrop-cart__back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
      Continue Shopping
    </a>
  </div>
</div>

{%- comment -%} Page Header {%- endcomment -%}
<div class="styledrop-cart__header-bar">
  <div class="container">
    <div class="styledrop-cart__header-row">
      <h1 class="styledrop-cart__title">
        SHOPPING<br />
        <span class="styledrop-cart__title-accent">CART</span>
      </h1>
      <span class="styledrop-cart__item-count">
        ({{ cart.item_count }} item{{ cart.item_count | pluralize: '', 's' }})
      </span>
    </div>
  </div>
</div>

{%- comment -%} Main Content {%- endcomment -%}
<div class="styledrop-cart">
  <div class="container">
    {%- if cart.item_count > 0 -%}
      <div class="styledrop-cart__layout">

        {%- comment -%} Left: Cart Items {%- endcomment -%}
        <div class="styledrop-cart__left">

          {%- comment -%} Card 1: Cart Items {%- endcomment -%}
          <div class="styledrop-cart__items-card">

            {%- comment -%} Desktop Table Header {%- endcomment -%}
            <div class="styledrop-cart__table-header">
              <div class="styledrop-cart__col-label">PRODUCT</div>
              <div class="styledrop-cart__col-label">PRICE</div>
              <div class="styledrop-cart__col-label">QUANTITY</div>
              <div class="styledrop-cart__col-label styledrop-cart__col-label--right">TOTAL</div>
            </div>

            {%- comment -%} Cart Items {%- endcomment -%}
            <div class="styledrop-cart__items-list">
              {%- for item in cart.items -%}
                <div class="styledrop-cart__item-row">

                  {%- comment -%} Mobile: Compact Card Layout {%- endcomment -%}
                  <div class="styledrop-cart__item-mobile">
                    <div class="styledrop-cart__item-img-wrap">
                      {%- if item.image -%}
                        <img
                          src="{{ item.image | image_url: width: 200 }}"
                          alt="{{ item.product.title | escape }}"
                          class="styledrop-cart__item-img"
                          width="200" height="233" loading="lazy"
                        />
                      {%- else -%}
                        {{ 'product-1' | placeholder_svg_tag: 'styledrop-cart__item-img' }}
                      {%- endif -%}
                    </div>

                    <div class="styledrop-cart__item-details">
                      <div>
                        <p class="styledrop-cart__item-vendor">{{ item.vendor }}</p>
                        <h3 class="styledrop-cart__item-title">{{ item.product.title }}</h3>
                        {%- if item.variant.title != 'Default Title' -%}
                          <span class="styledrop-cart__item-variant">{{ item.variant.title }}</span>
                        {%- endif -%}
                      </div>

                      <div class="styledrop-cart__item-bottom">
                        <div class="styledrop-cart__item-prices">
                          <p class="styledrop-cart__item-price">{{ item.price | money }}</p>
                          {%- if item.original_price > item.price -%}
                            <p class="styledrop-cart__item-compare">{{ item.original_price | money }}</p>
                          {%- endif -%}
                        </div>

                        <div class="styledrop-cart__item-controls">
                          <div class="styledrop-cart__qty">
                            <button type="button" class="styledrop-cart__qty-btn styledrop-cart__qty-btn--minus cart-qty-btn"
                              data-line="{{ forloop.index }}" data-qty="{{ item.quantity | minus: 1 }}" aria-label="Decrease quantity">
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </button>
                            <span class="styledrop-cart__qty-value">{{ item.quantity }}</span>
                            <button type="button" class="styledrop-cart__qty-btn styledrop-cart__qty-btn--plus cart-qty-btn"
                              data-line="{{ forloop.index }}" data-qty="{{ item.quantity | plus: 1 }}" aria-label="Increase quantity">
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            </button>
                          </div>

                          <button type="button" class="styledrop-cart__remove-btn cart-remove-btn"
                            data-line="{{ forloop.index }}" aria-label="Remove item">
                            <svg class="styledrop-cart__remove-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                            Remove
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>

                  {%- comment -%} Desktop: Table Row Layout {%- endcomment -%}
                  <div class="styledrop-cart__item-desktop">
                    <div class="styledrop-cart__item-product-col">
                      <div class="styledrop-cart__item-img-wrap">
                        {%- if item.image -%}
                          <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.product.title | escape }}"
                            class="styledrop-cart__item-img" width="200" height="233" loading="lazy"/>
                        {%- else -%}
                          {{ 'product-1' | placeholder_svg_tag: 'styledrop-cart__item-img' }}
                        {%- endif -%}
                      </div>
                      <div class="styledrop-cart__item-meta">
                        <p class="styledrop-cart__item-vendor">{{ item.vendor }}</p>
                        <h3 class="styledrop-cart__item-title">{{ item.product.title }}</h3>
                        {%- if item.variant.title != 'Default Title' -%}
                          <span class="styledrop-cart__item-variant">{{ item.variant.title }}</span>
                        {%- endif -%}
                        {%- if item.product.tags contains 'fast-drop' -%}
                          <span class="styledrop-cart__fast-drop-badge">⚡ FAST DROP</span>
                        {%- endif -%}
                        <button type="button" class="styledrop-cart__remove-btn cart-remove-btn" data-line="{{ forloop.index }}">
                          <svg class="styledrop-cart__remove-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                          </svg>
                          Remove
                        </button>
                      </div>
                    </div>

                    <div class="styledrop-cart__item-price-col">
                      <p class="styledrop-cart__item-price">{{ item.price | money }}</p>
                      {%- if item.original_price > item.price -%}
                        <p class="styledrop-cart__item-compare">{{ item.original_price | money }}</p>
                      {%- endif -%}
                    </div>

                    <div class="styledrop-cart__qty">
                      <button type="button" class="styledrop-cart__qty-btn styledrop-cart__qty-btn--minus cart-qty-btn"
                        data-line="{{ forloop.index }}" data-qty="{{ item.quantity | minus: 1 }}" aria-label="Decrease quantity">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                      </button>
                      <span class="styledrop-cart__qty-value">{{ item.quantity }}</span>
                      <button type="button" class="styledrop-cart__qty-btn styledrop-cart__qty-btn--plus cart-qty-btn"
                        data-line="{{ forloop.index }}" data-qty="{{ item.quantity | plus: 1 }}" aria-label="Increase quantity">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                      </button>
                    </div>

                    <div class="styledrop-cart__item-total-col">
                      <p class="styledrop-cart__item-total">{{ item.line_price | money }}</p>
                    </div>
                  </div>

                </div>
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} Card 2: Promo Code {%- endcomment -%}
          <div class="styledrop-cart__promo-card">
            <form method="post" action="/cart" class="styledrop-cart__promo-form">
              <div class="styledrop-cart__promo-input-wrap">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="styledrop-cart__promo-icon" aria-hidden="true">
                  <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                  <line x1="7" y1="7" x2="7.01" y2="7"></line>
                </svg>
                <input type="text" name="note" placeholder="Promo code (try: DROP10)"
                  value="{{ cart.note }}" class="styledrop-cart__promo-input"/>
              </div>
              <button type="submit" name="update" class="styledrop-cart__promo-btn">APPLY CODE</button>
            </form>
          </div>

          {%- comment -%} Card 3: Order Notes {%- endcomment -%}
          <div class="styledrop-cart__notes-card">
            <form method="post" action="/cart">
              <label class="styledrop-cart__notes-label">
                Order notes <span class="styledrop-cart__notes-label-opt">(Optional)</span>
              </label>
              <textarea name="note" placeholder="Any special instructions..." class="styledrop-cart__notes-textarea" rows="4">{{ cart.note }}</textarea>
              <button type="submit" name="update" class="styledrop-cart__notes-update">Update notes</button>
            </form>
          </div>
        </div>

        {%- comment -%} Right: Order Summary {%- endcomment -%}
        <div>
          <div class="styledrop-cart__sidebar">
            {%- comment -%} Free Shipping Progress {%- endcomment -%}
            {%- assign free_shipping_threshold = 97500 -%}
            {%- assign shipping_progress = cart.total_price | times: 100 | divided_by: free_shipping_threshold -%}
            {%- if shipping_progress > 100 -%}{%- assign shipping_progress = 100 -%}{%- endif -%}
            {%- assign amount_until_free = free_shipping_threshold | minus: cart.total_price -%}
            {%- assign is_free_shipping = false -%}
            {%- if cart.total_price >= free_shipping_threshold -%}{%- assign is_free_shipping = true -%}{%- endif -%}

            <div class="styledrop-cart__progress-section">
              {%- if is_free_shipping -%}
                <p class="styledrop-cart__progress-label styledrop-cart__progress-label--unlocked">🎉 You've unlocked Free Shipping!</p>
              {%- else -%}
                <p class="styledrop-cart__progress-label">You're {{ amount_until_free | money }} away from Free Shipping!</p>
              {%- endif -%}
              <div class="styledrop-cart__progress">
                <div class="styledrop-cart__progress-bar" style="width: {{ shipping_progress }}%;"></div>
              </div>
            </div>

            {%- comment -%} Subtotal {%- endcomment -%}
            <div class="styledrop-cart__subtotal-section">
              <div class="styledrop-cart__subtotal-row">
                <span class="styledrop-cart__subtotal-label">SUBTOTAL</span>
                <span class="styledrop-cart__subtotal-price">{{ cart.total_price | money }}</span>
              </div>
              <p class="styledrop-cart__subtotal-note">Taxes and shipping calculated at checkout</p>
            </div>

            {%- comment -%} Checkout Button {%- endcomment -%}
            <form action="/cart" method="post" novalidate>
              <button type="submit" name="checkout" class="styledrop-cart__checkout-btn">
                CHECKOUT
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </button>
            </form>
          </div>
        </div>
      </div>

    {%- else -%}
      {%- comment -%} Empty Cart {%- endcomment -%}
      <div class="styledrop-cart__empty">
        <h2 class="styledrop-cart__empty-title">Your cart is empty</h2>
        <p class="styledrop-cart__empty-text">Start shopping to add items to your cart.</p>
        <a href="/collections/all" class="styledrop-cart__empty-cta">Continue Shopping</a>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
document.querySelectorAll('.cart-qty-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    const line = this.dataset.line;
    const qty = parseInt(this.dataset.qty);
    if (qty < 1) return;
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: qty })
    }).then(() => window.location.reload());
  });
});

document.querySelectorAll('.cart-remove-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    const line = this.dataset.line;
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: 0 })
    }).then(() => window.location.reload());
  });
});
</script>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section-cart"
}
{% endschema %}
