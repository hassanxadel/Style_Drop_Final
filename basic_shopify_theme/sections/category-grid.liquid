{% comment %}
  StyleDrop Category Grid Section
  Converted from: src/sections/CategoryGridSection.tsx

  Features:
  - Masonry-style category grid
  - Section heading with badge
  - Configurable categories via blocks
  - Integrated sale banner option
  - Responsive layout

  Settings:
  - Section heading
  - Badge text
  - Category blocks (up to 6)
  - Sale banner (optional)

  Note on grid_span schema values:
  - Changed from Tailwind class strings ("col-span-1 row-span-2") to semantic
    values ("small", "tall", "wide") which are translated to BEM modifiers in
    category-card.liquid and styledrop-category-card.css.
{% endcomment %}

{{ 'styledrop-category-grid.css' | asset_url | stylesheet_tag }}

<section class="styledrop-category-grid">
  <div class="container styledrop-category-grid__inner">

    {%- comment -%} Section Header {%- endcomment -%}
    <div class="styledrop-category-grid__header">
      {%- if section.settings.badge_text != blank -%}
        <span class="styledrop-category-grid__badge">
          {{ section.settings.badge_text }}
        </span>
      {%- endif -%}
      <h2 class="styledrop-category-grid__heading">
        {{ section.settings.heading_line_1 | default: "CLOTHES THAT FIT" }}
        <br />
        <span class="styledrop-category-grid__heading-line--accent">{{ section.settings.heading_line_2 | default: "YOUR LIFE" }}</span>
      </h2>
    </div>

    {%- comment -%} Category Grid – Masonry Layout {%- endcomment -%}
    <div class="styledrop-category-grid__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'category' -%}
            {% render 'category-card',
              category_name: block.settings.category_name,
              category_url: block.settings.category_url,
              category_image: block.settings.category_image,
              grid_span: block.settings.grid_span
            %}
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Integrated Sale Banner (optional) {%- endcomment -%}
    {%- if section.settings.show_sale_banner -%}
      <a href="{{ section.settings.sale_banner_link | default: '/collections/sale' }}" class="styledrop-category-grid__sale-banner-link">
        <div class="styledrop-category-grid__sale-banner">
          {%- if section.settings.sale_banner_image != blank -%}
            <img
              src="{{ section.settings.sale_banner_image | image_url: width: 1600 }}"
              alt="{{ section.settings.sale_banner_title }}"
              class="styledrop-category-grid__sale-banner-img"
              width="1600"
              height="240"
              loading="lazy"
            />
          {%- else -%}
            <div class="styledrop-category-grid__sale-banner-placeholder"></div>
          {%- endif -%}

          <div class="styledrop-category-grid__sale-overlay">
            <div class="styledrop-category-grid__sale-content">
              <h3 class="styledrop-category-grid__sale-title">
                {{ section.settings.sale_banner_title | default: "SALE — UP TO 50% OFF" }}
              </h3>
              {%- if section.settings.sale_banner_subtitle != blank -%}
                <p class="styledrop-category-grid__sale-subtitle">
                  {{ section.settings.sale_banner_subtitle }}
                </p>
              {%- endif -%}
              <span class="styledrop-category-grid__sale-cta">
                {{ section.settings.sale_banner_button | default: "SHOP SALE" }}
              </span>
            </div>
          </div>
        </div>
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "StyleDrop - Category Grid",
  "tag": "section",
  "class": "section-category-grid",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "SHOP BY CATEGORY"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading Line 1",
      "default": "CLOTHES THAT FIT"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading Line 2 (Accent Color)",
      "default": "YOUR LIFE"
    },
    {
      "type": "header",
      "content": "Sale Banner (Optional)"
    },
    {
      "type": "checkbox",
      "id": "show_sale_banner",
      "label": "Show Sale Banner",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "sale_banner_image",
      "label": "Sale Banner Image"
    },
    {
      "type": "text",
      "id": "sale_banner_title",
      "label": "Sale Banner Title",
      "default": "SALE — UP TO 50% OFF"
    },
    {
      "type": "text",
      "id": "sale_banner_subtitle",
      "label": "Sale Banner Subtitle",
      "default": "Limited time · While stocks last"
    },
    {
      "type": "text",
      "id": "sale_banner_button",
      "label": "Sale Banner Button Text",
      "default": "SHOP SALE"
    },
    {
      "type": "url",
      "id": "sale_banner_link",
      "label": "Sale Banner Link"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "category_name",
          "label": "Category Name",
          "default": "CATEGORY"
        },
        {
          "type": "url",
          "id": "category_url",
          "label": "Category Link"
        },
        {
          "type": "image_picker",
          "id": "category_image",
          "label": "Category Image"
        },
        {
          "type": "select",
          "id": "grid_span",
          "label": "Grid Size",
          "options": [
            {
              "value": "small",
              "label": "Small (1x1)"
            },
            {
              "value": "tall",
              "label": "Tall (1x2)"
            },
            {
              "value": "wide",
              "label": "Wide (2x1)"
            }
          ],
          "default": "small"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "StyleDrop - Category Grid",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "category_name": "WOMEN",
            "grid_span": "tall"
          }
        },
        {
          "type": "category",
          "settings": {
            "category_name": "MEN",
            "grid_span": "small"
          }
        },
        {
          "type": "category",
          "settings": {
            "category_name": "SHOES",
            "grid_span": "small"
          }
        },
        {
          "type": "category",
          "settings": {
            "category_name": "ACCESSORIES",
            "grid_span": "small"
          }
        },
        {
          "type": "category",
          "settings": {
            "category_name": "NEW IN",
            "grid_span": "small"
          }
        }
      ]
    }
  ]
}
{% endschema %}
