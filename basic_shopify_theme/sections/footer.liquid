{% comment %}
  StyleDrop Footer Section
  Converted from: src/components/Footer.tsx
  
  Features:
  - Logo and brand description
  - 4-column layout (Brand + 3 link columns)
  - Configurable link columns via Theme Editor
  - Copyright notice
  - Dark styling (primary color background)
  
  Settings:
  - Logo image
  - Brand description
  - 3 link columns (Shop, Support, Quick Links)
{% endcomment %}

{{ 'styledrop-footer.css' | asset_url | stylesheet_tag }}

<footer class="styledrop-footer">
  <div class="container">
    {%- comment -%} Main Footer Content {%- endcomment -%}
    <div class="styledrop-footer__grid">
      
      {%- comment -%} Brand Column {%- endcomment -%}
      <div>
        {%- comment -%} Logo {%- endcomment -%}
        <a href="{{ routes.root_url }}" class="styledrop-footer__logo-link">
          {%- if section.settings.footer_logo != blank -%}
            <img 
              src="{{ section.settings.footer_logo | image_url: width: 150 }}" 
              alt="{{ shop.name }}" 
              class="styledrop-footer__logo-img"
              width="150"
              height="64"
            />
          {%- else -%}
            <span class="styledrop-footer__logo-text">
              {{ shop.name }}
            </span>
          {%- endif -%}
        </a>

        {%- comment -%} Brand Description {%- endcomment -%}
        {%- if section.settings.brand_description != blank -%}
          <p class="styledrop-footer__brand-text">
            {{ section.settings.brand_description }}
          </p>
        {%- endif -%}
      </div>

      {%- comment -%} Shop Column {%- endcomment -%}
      {%- if section.settings.menu_shop != blank -%}
        <div>
          <h4 class="styledrop-footer__column-title">
            {{ section.settings.menu_shop_title | default: "Shop" }}
          </h4>
          <ul class="styledrop-footer__col-links">
            {%- for link in linklists[section.settings.menu_shop].links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="styledrop-footer__link"
                >
                  {{ link.title }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {%- comment -%} Support Column {%- endcomment -%}
      {%- if section.settings.menu_support != blank -%}
        <div>
          <h4 class="styledrop-footer__column-title">
            {{ section.settings.menu_support_title | default: "Support" }}
          </h4>
          <ul class="styledrop-footer__col-links">
            {%- for link in linklists[section.settings.menu_support].links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="styledrop-footer__link"
                >
                  {{ link.title }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {%- comment -%} Quick Links Column {%- endcomment -%}
      {%- if section.settings.menu_quick != blank -%}
        <div>
          <h4 class="styledrop-footer__column-title">
            {{ section.settings.menu_quick_title | default: "Quick Links" }}
          </h4>
          <ul class="styledrop-footer__col-links">
            {%- for link in linklists[section.settings.menu_quick].links -%}
              <li>
                <a
                  href="{{ link.url }}"
                  class="styledrop-footer__link"
                >
                  {{ link.title }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Footer Bottom - Copyright {%- endcomment -%}
    <div class="styledrop-footer__bottom">
      <p>
        {%- if section.settings.copyright_text != blank -%}
          {{ section.settings.copyright_text }}
        {%- else -%}
          © {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
        {%- endif -%}
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "StyleDrop - Footer",
  "tag": "section",
  "class": "section-footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand Section"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo",
      "info": "Upload your logo (recommended: 150x64px)"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand Description",
      "default": "Curated fashion from 200+ brands, delivered to your door. Setting the pace of global style."
    },
    {
      "type": "header",
      "content": "Shop Column"
    },
    {
      "type": "text",
      "id": "menu_shop_title",
      "label": "Shop Column Title",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "menu_shop",
      "label": "Shop Menu",
      "info": "Select the menu for the Shop column"
    },
    {
      "type": "header",
      "content": "Support Column"
    },
    {
      "type": "text",
      "id": "menu_support_title",
      "label": "Support Column Title",
      "default": "Support"
    },
    {
      "type": "link_list",
      "id": "menu_support",
      "label": "Support Menu",
      "info": "Select the menu for the Support column"
    },
    {
      "type": "header",
      "content": "Quick Links Column"
    },
    {
      "type": "text",
      "id": "menu_quick_title",
      "label": "Quick Links Column Title",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "menu_quick",
      "label": "Quick Links Menu",
      "info": "Select the menu for the Quick Links column"
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "© 2026 StyleDrop. All rights reserved.",
      "info": "Leave blank to auto-generate with current year and shop name"
    }
  ]
}
{% endschema %}
