{% comment %}
  StyleDrop Main Collection Template
  Converted from: src/pages/Collection.tsx
  
  Features:
  - Breadcrumb navigation
  - Filter sidebar (desktop) / filter modal (mobile)
  - Collection filters bar (sort, view toggle)
  - Product grid
  - Pagination
  
  This template displays all collection pages
{% endcomment %}

{{ 'styledrop-collection.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Fallback to /collections/all when this section is rendered
  outside a native collection context in the editor.
{%- endcomment -%}
{%- assign source_collection = collection -%}
{%- if source_collection == blank or source_collection.products_count == blank -%}
  {%- assign source_collection = collections['all'] -%}
{%- endif -%}

<div class="styledrop-collection">
  {%- comment -%} Top header bar (breadcrumb + title like React) {%- endcomment -%}
  <div class="styledrop-collection__top">
    <div class="container styledrop-collection__top-inner">
      <div class="styledrop-collection__breadcrumb">
        <svg class="styledrop-collection__breadcrumb-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        <a href="{{ routes.root_url }}" class="styledrop-collection__breadcrumb-link">Home</a>
        <span class="styledrop-collection__breadcrumb-sep">/</span>
        <span class="styledrop-collection__breadcrumb-current">{{ source_collection.title | default: 'All Products' }}</span>
      </div>

      <div class="styledrop-collection__header">
        <div class="styledrop-collection__header-left">
          <span class="styledrop-collection__badge">{{ section.settings.badge_text }}</span>
          <h1 class="styledrop-collection__title">
            {{ section.settings.title_line_1 }}
            <span class="styledrop-collection__title-accent">{{ section.settings.title_line_2 }}</span>
          </h1>
        </div>

        <div class="styledrop-collection__header-right">
          {% render 'collection-filters', collection: source_collection, product_count: source_collection.products_count %}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Main content area (sidebar + grid) {%- endcomment -%}
  <div class="styledrop-collection__content">
    <div class="container">
      <div class="styledrop-collection__layout">
        <aside class="styledrop-collection__sidebar">
          {% render 'filter-sidebar', collection: source_collection %}
        </aside>

        <div class="styledrop-collection__products">
          <div class="product-grid-container styledrop-collection__product-grid sd-grid--grid">
            {%- comment -%}
              Avoid Shopify paginate errors in section context:
              Render a safe slice of collection products (matches React "no pagination" layout).
            {%- endcomment -%}
            {%- assign products_limit = section.settings.products_per_page | default: 24 -%}
            {%- assign products_to_render = source_collection.products | slice: 0, products_limit -%}
            {% render 'product-grid', products: products_to_render, columns: section.settings.columns_desktop %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{%- comment -%} Mobile Filter Sidebar container (toggled by snippets JS) {%- endcomment -%}
<div class="styledrop-collection__mobile-overlay styledrop-filter-sidebar-mobile sd-sidebar--closed">
  <div class="styledrop-collection__mobile-panel">
    {% render 'filter-sidebar', collection: source_collection %}
  </div>
</div>

{% schema %}
{
  "name": "Main Collection",
  "tag": "section",
  "class": "section-collection",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "TRENDING COLLECTION"
    },
    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title line 1",
      "default": "SHOP WHAT'S "
    },
    {
      "type": "text",
      "id": "title_line_2",
      "label": "Title line 2 (accent)",
      "default": "TRENDING"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    { "name": "Main Collection" }
  ]
}
{% endschema %}
