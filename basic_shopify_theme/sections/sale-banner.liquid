{% comment %}
  StyleDrop Sale Banner Section
  Converted from: src/sections/SaleBanner.tsx
  
  Features:
  - Full-width promotional banner
  - Background image with overlay
  - Configurable title, subtitle, button
  - Responsive height
  - Centered content
  
  Settings:
  - Image
  - Title
  - Subtitle
  - Button text and link
{% endcomment %}

{{ 'styledrop-sale-banner.css' | asset_url | stylesheet_tag }}

<section class="styledrop-sale-banner">
  {%- comment -%} Background Image {%- endcomment -%}
  {%- if section.settings.banner_image != blank -%}
    <img
      src="{{ section.settings.banner_image | image_url: width: 1600 }}"
      alt="{{ section.settings.title }}"
      class="styledrop-sale-banner__img"
      width="1600"
      height="280"
      loading="lazy"
    />
  {%- else -%}
    <div class="styledrop-sale-banner__placeholder"></div>
  {%- endif -%}

  {%- comment -%} Overlay with Content {%- endcomment -%}
  <div class="styledrop-sale-banner__overlay">
    <div class="styledrop-sale-banner__content">
      {%- comment -%} Title {%- endcomment -%}
      <h2 class="styledrop-sale-banner__title">
        {{ section.settings.title | default: "SALE — UP TO 50% OFF" }}
      </h2>

      {%- comment -%} Subtitle {%- endcomment -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="styledrop-sale-banner__subtitle">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}

      {%- comment -%} CTA Button {%- endcomment -%}
      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_link | default: '/collections/all' }}">
          <span class="styledrop-sale-banner__cta">
            {{ section.settings.button_text }}
          </span>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "StyleDrop - Sale Banner",
  "tag": "section",
  "class": "section-sale-banner",
  "settings": [
    {
      "type": "header",
      "content": "Banner Settings"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "SALE — UP TO 50% OFF"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Limited time · While stocks last"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP SALE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "StyleDrop - Sale Banner"
    }
  ]
}
{% endschema %}
