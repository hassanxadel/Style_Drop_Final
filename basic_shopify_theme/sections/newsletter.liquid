{% comment %}
  StyleDrop Newsletter Section
  Converted from: src/sections/NewsletterSection.tsx
  
  Features:
  - Email signup with Shopify customer API
  - Dark background with large "DROP" text
  - Success/error messages
  - Privacy notice
  - Responsive layout
  
  Settings:
  - Heading text
  - Description
  - Button text
  - Success message
{% endcomment %}

{{ 'styledrop-newsletter.css' | asset_url | stylesheet_tag }}

<section class="styledrop-newsletter">
  <div class="container">
    <div
      class="styledrop-newsletter__card"
      style="
        --sd-nl-card-padding-mobile: {{ section.settings.card_padding_mobile }}px;
        --sd-nl-card-padding-desktop: {{ section.settings.card_padding_desktop }}px;
        --sd-nl-drop-size-mobile: {{ section.settings.drop_size_mobile }}px;
        --sd-nl-drop-size-desktop: {{ section.settings.drop_size_desktop }}px;
        --sd-nl-badge-icon-size-mobile: {{ section.settings.badge_icon_size_mobile }}px;
        --sd-nl-badge-icon-size-desktop: {{ section.settings.badge_icon_size_desktop }}px;
        --sd-nl-badge-text-size-mobile: {{ section.settings.badge_text_size_mobile }}px;
        --sd-nl-badge-text-size-desktop: {{ section.settings.badge_text_size_desktop }}px;
        --sd-nl-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
        --sd-nl-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
        --sd-nl-description-size-mobile: {{ section.settings.description_size_mobile }}px;
        --sd-nl-description-size-desktop: {{ section.settings.description_size_desktop }}px;
        --sd-nl-input-font-size-mobile: {{ section.settings.input_font_size_mobile }}px;
        --sd-nl-input-font-size-desktop: {{ section.settings.input_font_size_desktop }}px;
        --sd-nl-input-px-mobile: {{ section.settings.input_padding_x_mobile }}px;
        --sd-nl-input-px-desktop: {{ section.settings.input_padding_x_desktop }}px;
        --sd-nl-input-py-mobile: {{ section.settings.input_padding_y_mobile }}px;
        --sd-nl-input-py-desktop: {{ section.settings.input_padding_y_desktop }}px;
        --sd-nl-button-font-size-mobile: {{ section.settings.button_font_size_mobile }}px;
        --sd-nl-button-font-size-desktop: {{ section.settings.button_font_size_desktop }}px;
        --sd-nl-button-px-mobile: {{ section.settings.button_padding_x_mobile }}px;
        --sd-nl-button-px-desktop: {{ section.settings.button_padding_x_desktop }}px;
        --sd-nl-button-py-mobile: {{ section.settings.button_padding_y_mobile }}px;
        --sd-nl-button-py-desktop: {{ section.settings.button_padding_y_desktop }}px;
        --sd-nl-privacy-size-mobile: {{ section.settings.privacy_size_mobile }}px;
        --sd-nl-privacy-size-desktop: {{ section.settings.privacy_size_desktop }}px;
        --sd-nl-message-size-mobile: {{ section.settings.message_size_mobile }}px;
        --sd-nl-message-size-desktop: {{ section.settings.message_size_desktop }}px;
      "
    >
      {%- comment -%} Large "DROP" Background Text {%- endcomment -%}
      <div class="styledrop-newsletter__drop-word">
        <span class="styledrop-newsletter__drop-word-text">
          DROP
        </span>
      </div>

      {%- comment -%} Content {%- endcomment -%}
      <div class="styledrop-newsletter__content">
        {%- comment -%} Badge {%- endcomment -%}
        <div class="styledrop-newsletter__badge">
          <svg class="styledrop-newsletter__badge-icon" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/>
          </svg>
          <span class="styledrop-newsletter__badge-text">
            {{ section.settings.badge_text | default: "DROP INSIDER" }}
          </span>
        </div>

        {%- comment -%} Heading {%- endcomment -%}
        <h2 class="styledrop-newsletter__heading">
          {{ section.settings.heading | default: "BE FIRST TO KNOW<br>EVERY DROP." }}
        </h2>

        {%- comment -%} Description {%- endcomment -%}
        <p class="styledrop-newsletter__description">
          {{ section.settings.description | default: "Join 50K+ shoppers who get early access to new drops, exclusive deals, and style inspo — before anyone else." }}
        </p>

        {%- comment -%} Email Signup Form {%- endcomment -%}
        {%- form 'customer', id: 'NewsletterForm', class: 'styledrop-newsletter__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          
          {%- comment -%} Email Input {%- endcomment -%}
          <input
            type="email"
            name="contact[email]"
            id="NewsletterForm--{{ section.id }}"
            value="{{ form.email }}"
            placeholder="{{ section.settings.input_placeholder | default: 'your@email.com' }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            required
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="Newsletter-error--{{ section.id }}"
            {% elsif form.posted_successfully? %}
              aria-describedby="Newsletter-success--{{ section.id }}"
            {% endif %}
            class="styledrop-newsletter__input"
          />

          {%- comment -%} Submit Button {%- endcomment -%}
          <button 
            type="submit"
            name="commit"
            class="styledrop-newsletter__submit"
          >
            {{ section.settings.button_text | default: "GET EARLY ACCESS →" }}
          </button>
        {%- endform -%}

        {%- comment -%} Success Message {%- endcomment -%}
        {%- if form.posted_successfully? -%}
          <p
            id="Newsletter-success--{{ section.id }}"
            class="styledrop-newsletter__success"
          >
            ✓ {{ section.settings.success_message | default: "Thanks for subscribing! Check your email for a welcome offer." }}
          </p>
        {%- endif -%}

        {%- comment -%} Error Message {%- endcomment -%}
        {%- if form.errors -%}
          <p
            id="Newsletter-error--{{ section.id }}"
            class="styledrop-newsletter__error"
          >
            {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
          </p>
        {%- endif -%}

        {%- comment -%} Privacy Notice {%- endcomment -%}
        <p class="styledrop-newsletter__privacy">
          {{ section.settings.privacy_text | default: "No spam, ever. Unsubscribe anytime. We respect your inbox." }}
        </p>
      </div>
    </div>
  </div>
</section>

