{% comment %}
  StyleDrop Newsletter Section
  Converted from: src/sections/NewsletterSection.tsx
  
  Features:
  - Email signup with Shopify customer API
  - Dark background with large "DROP" text
  - Success/error messages
  - Privacy notice
  - Responsive layout
  
  Settings:
  - Heading text
  - Description
  - Button text
  - Success message
{% endcomment %}

{{ 'styledrop-newsletter.css' | asset_url | stylesheet_tag }}

<section class="styledrop-newsletter">
  <div class="container">
    <div class="styledrop-newsletter__card">
      {%- comment -%} Large "DROP" Background Text {%- endcomment -%}
      <div class="styledrop-newsletter__drop-word">
        <span class="styledrop-newsletter__drop-word-text">
          DROP
        </span>
      </div>

      {%- comment -%} Content {%- endcomment -%}
      <div class="styledrop-newsletter__content">
        {%- comment -%} Badge {%- endcomment -%}
        <div class="styledrop-newsletter__badge">
          <svg class="styledrop-newsletter__badge-icon" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/>
          </svg>
          <span class="styledrop-newsletter__badge-text">
            {{ section.settings.badge_text | default: "DROP INSIDER" }}
          </span>
        </div>

        {%- comment -%} Heading {%- endcomment -%}
        <h2 class="styledrop-newsletter__heading">
          {{ section.settings.heading | default: "BE FIRST TO KNOW<br>EVERY DROP." }}
        </h2>

        {%- comment -%} Description {%- endcomment -%}
        <p class="styledrop-newsletter__description">
          {{ section.settings.description | default: "Join 50K+ shoppers who get early access to new drops, exclusive deals, and style inspo — before anyone else." }}
        </p>

        {%- comment -%} Email Signup Form {%- endcomment -%}
        {%- form 'customer', id: 'NewsletterForm', class: 'styledrop-newsletter__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          
          {%- comment -%} Email Input {%- endcomment -%}
          <input
            type="email"
            name="contact[email]"
            id="NewsletterForm--{{ section.id }}"
            value="{{ form.email }}"
            placeholder="{{ section.settings.input_placeholder | default: 'your@email.com' }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            required
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="Newsletter-error--{{ section.id }}"
            {% elsif form.posted_successfully? %}
              aria-describedby="Newsletter-success--{{ section.id }}"
            {% endif %}
            class="styledrop-newsletter__input"
          />

          {%- comment -%} Submit Button {%- endcomment -%}
          <button 
            type="submit"
            name="commit"
            class="styledrop-newsletter__submit"
          >
            {{ section.settings.button_text | default: "GET EARLY ACCESS →" }}
          </button>
        {%- endform -%}

        {%- comment -%} Success Message {%- endcomment -%}
        {%- if form.posted_successfully? -%}
          <p
            id="Newsletter-success--{{ section.id }}"
            class="styledrop-newsletter__success"
          >
            ✓ {{ section.settings.success_message | default: "Thanks for subscribing! Check your email for a welcome offer." }}
          </p>
        {%- endif -%}

        {%- comment -%} Error Message {%- endcomment -%}
        {%- if form.errors -%}
          <p
            id="Newsletter-error--{{ section.id }}"
            class="styledrop-newsletter__error"
          >
            {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
          </p>
        {%- endif -%}

        {%- comment -%} Privacy Notice {%- endcomment -%}
        <p class="styledrop-newsletter__privacy">
          {{ section.settings.privacy_text | default: "No spam, ever. Unsubscribe anytime. We respect your inbox." }}
        </p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "StyleDrop - Newsletter",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "DROP INSIDER"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "BE FIRST TO KNOW<br>EVERY DROP.",
      "info": "Use <br> for line breaks"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Join 50K+ shoppers who get early access to new drops, exclusive deals, and style inspo — before anyone else."
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input Placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "GET EARLY ACCESS →"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "Thanks for subscribing! Check your email for a welcome offer."
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy Notice",
      "default": "No spam, ever. Unsubscribe anytime. We respect your inbox."
    }
  ],
  "presets": [
    {
      "name": "StyleDrop - Newsletter"
    }
  ]
}
{% endschema %}
