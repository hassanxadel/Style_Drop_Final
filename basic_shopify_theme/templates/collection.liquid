{% comment %}
  StyleDrop Main Collection Template
  Converted from: src/pages/Collection.tsx
  
  Features:
  - Breadcrumb navigation
  - Filter sidebar (desktop) / filter modal (mobile)
  - Collection filters bar (sort, view toggle)
  - Product grid
  - Pagination
  
  This template displays all collection pages
{% endcomment %}

<link rel="stylesheet" href="{{ 'style-drop-custom.css' | asset_url }}">

<div class="bg-background min-h-screen py-8">
  <div class="container px-4 md:px-8">
    {%- comment -%} Breadcrumb Navigation {%- endcomment -%}
    <nav class="flex items-center gap-2 text-sm mb-6">
      <a href="{{ routes.root_url }}" class="text-muted-foreground hover:text-foreground transition-colors">
        Home
      </a>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted-foreground">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
      <span class="text-foreground font-medium">{{ collection.title }}</span>
    </nav>

    {%- comment -%} Collection Header {%- endcomment -%}
    <div class="mb-8">
      <h1 class="text-4xl md:text-5xl font-display font-normal mb-2">
        {{ collection.title }}
      </h1>
      {%- if collection.description != blank -%}
        <p class="text-muted-foreground max-w-2xl">
          {{ collection.description }}
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} Main Content: Sidebar + Products {%- endcomment -%}
    <div class="flex gap-8">
      {%- comment -%} Desktop Sidebar {%- endcomment -%}
      <aside class="hidden md:block w-64 shrink-0">
        {% render 'filter-sidebar', collection: collection %}
      </aside>

      {%- comment -%} Products Section {%- endcomment -%}
      <div class="flex-1">
        {%- comment -%} Collection Filters Bar {%- endcomment -%}
        {% render 'collection-filters', collection: collection, product_count: collection.products_count %}

        {%- comment -%} Product Grid {%- endcomment -%}
        <div class="product-grid-container">
          {% render 'product-grid', products: collection.products, columns: 3 %}
        </div>

        {%- comment -%} Pagination {%- endcomment -%}
        {%- if paginate.pages > 1 -%}
          <div class="mt-12 flex items-center justify-center gap-2">
            {%- if paginate.previous -%}
              <a
                href="{{ paginate.previous.url }}"
                class="w-10 h-10 flex items-center justify-center border border-border rounded-lg hover:bg-muted transition-colors"
                aria-label="Previous page"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
              </a>
            {%- endif -%}

            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a
                  href="{{ part.url }}"
                  class="w-10 h-10 flex items-center justify-center border border-border rounded-lg hover:bg-muted transition-colors text-sm font-medium"
                >
                  {{ part.title }}
                </a>
              {%- else -%}
                <span class="w-10 h-10 flex items-center justify-center bg-primary text-primary-foreground rounded-lg text-sm font-medium">
                  {{ part.title }}
                </span>
              {%- endif -%}
            {%- endfor -%}

            {%- if paginate.next -%}
              <a
                href="{{ paginate.next.url }}"
                class="w-10 h-10 flex items-center justify-center border border-border rounded-lg hover:bg-muted transition-colors"
                aria-label="Next page"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{%- comment -%} Mobile Filter Sidebar (Overlay) {%- endcomment -%}
<div class="md:hidden filter-sidebar-mobile fixed inset-0 z-50 bg-black/50 hidden" onclick="if(event.target === this) toggleMobileFilters()">
  <div class="absolute right-0 top-0 h-full w-full max-w-sm bg-background overflow-y-auto p-6">
    {% render 'filter-sidebar', collection: collection %}
  </div>
</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-collection"
}
{% endschema %}
