{% comment %}
  StyleDrop 404 Not Found Template
  Converted from: src/pages/NotFound.tsx
  Valgara Pattern: All Tailwind stripped. styledrop-404__* BEM classes only.
{% endcomment %}

{{ 'styledrop-404.css' | asset_url | stylesheet_tag }}

<div class="styledrop-404">
  <h1 class="styledrop-404__number">404</h1>
  <h2 class="styledrop-404__title">PAGE NOT FOUND</h2>
  <p class="styledrop-404__message">
    The page you're looking for doesn't exist or has been moved.
  </p>
  <a href="{{ routes.root_url }}" class="styledrop-404__cta">Back to Home</a>
</div>

{% schema %}
{
  "name": "404 Not Found",
  "tag": "section",
  "class": "section-404"
}
{% endschema %}
