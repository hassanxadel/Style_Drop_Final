{% comment %}
  StyleDrop Brands Listing Page Template
  Converted from: src/pages/Brands.tsx
{% endcomment %}

{{ 'styledrop-brands.css' | asset_url | stylesheet_tag }}

<div class="styledrop-brands">
  <div class="container">
    <div class="styledrop-brands__header">
      <h1 class="styledrop-brands__title">ALL BRANDS</h1>
      <p class="styledrop-brands__subtitle">Discover our curated collection of premium brands from around the world</p>
    </div>

    <div class="styledrop-brands__grid">
      {%- assign all_vendors = '' -%}
      {%- assign vendor_count = 0 -%}
      {%- for product in collections.all.products limit: 200 -%}
        {%- unless all_vendors contains product.vendor -%}
          {%- assign all_vendors = all_vendors | append: product.vendor | append: ',' -%}
          {%- assign vendor_slug = product.vendor | handleize -%}
          <a href="/collections/{{ vendor_slug }}" class="styledrop-brands__card">
            <div class="styledrop-brands__card-logo">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 80 }}" alt="{{ product.vendor }}" class="styledrop-brands__card-img" width="80" height="80" loading="lazy"/>
              {%- else -%}
                <span class="styledrop-brands__card-initial">{{ product.vendor | slice: 0 }}</span>
              {%- endif -%}
            </div>
            <p class="styledrop-brands__card-name">{{ product.vendor | upcase }}</p>
            <p class="styledrop-brands__card-note">Premium Fashion</p>
          </a>
          {%- assign vendor_count = vendor_count | plus: 1 -%}
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</div>
