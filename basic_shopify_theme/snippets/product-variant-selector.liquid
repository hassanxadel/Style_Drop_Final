{% comment %}
  Product Variant Selector - Color & Size Selection
  
  Converts React variant selectors to Shopify Liquid
  Source: ProductDetails.tsx (lines 263-317)
  
  Features:
  - Color selector with swatches
  - Size selector with buttons
  - Size guide link
  - Find Your Best Size button (triggers modal)
  - Variant change handling
  
  Usage:
  {% render 'product-variant-selector', product: product %}
{% endcomment %}

{%- comment -%} Get available variants {%- endcomment -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- comment -%} Color Selection {%- endcomment -%}
{%- if product.options contains 'Color' or product.options contains 'color' -%}
  {%- assign color_option_index = 0 -%}
  {%- for option in product.options_with_values -%}
    {%- if option.name == 'Color' or option.name == 'color' -%}
      {%- assign color_option_index = forloop.index0 -%}
      
      <div class="mb-6">
        <label class="text-sm font-semibold mb-3 block">
          Color: 
          <span class="text-muted-foreground font-normal" id="selected-color">
            {{ current_variant.options[color_option_index] }}
          </span>
        </label>
        
        <div class="flex gap-2 flex-wrap">
          {%- for value in option.values -%}
            {%- comment -%} Get color hex from metafields if available {%- endcomment -%}
            {%- assign color_key = value | handle -%}
            {%- assign color_hex = product.metafields.colors[color_key] | default: '#cccccc' -%}
            
            <button
              type="button"
              class="color-swatch w-10 h-10 rounded-full border-2 transition-all hover:scale-110
                     {% if current_variant.options[color_option_index] == value %}border-primary ring-2 ring-primary ring-offset-2{% else %}border-border{% endif %}"
              style="background-color: {{ color_hex }};"
              data-color="{{ value }}"
              data-option-index="{{ color_option_index | plus: 1 }}"
              aria-label="{{ value }}"
              title="{{ value }}"
            >
              {%- comment -%} Hidden checkmark for selected state {%- endcomment -%}
              {% if current_variant.options[color_option_index] == value %}
                <svg class="w-4 h-4 text-white mx-auto" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              {% endif %}
            </button>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%} Size Selection {%- endcomment -%}
{%- if product.options contains 'Size' or product.options contains 'size' -%}
  {%- assign size_option_index = 0 -%}
  {%- for option in product.options_with_values -%}
    {%- if option.name == 'Size' or option.name == 'size' -%}
      {%- assign size_option_index = forloop.index0 -%}
      
      <div class="mb-6">
        {%- comment -%} Size Label with Links {%- endcomment -%}
        <div class="flex items-center justify-between mb-3">
          <label class="text-sm font-semibold">Size:</label>
          <div class="flex items-center gap-2">
            <button 
              type="button"
              class="text-xs text-accent hover:underline"
              onclick="openSizeGuide()"
            >
              Size Guide
            </button>
            <span class="text-xs text-muted-foreground">|</span>
            <button
              type="button"
              class="text-xs text-accent hover:underline flex items-center gap-1"
              onclick="openSizePredictor()"
            >
              {%- comment -%} Zap Icon SVG {%- endcomment -%}
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/>
              </svg>
              Find Your Best Size
            </button>
          </div>
        </div>
        
        {%- comment -%} Size Buttons {%- endcomment -%}
        <div class="flex gap-3 flex-wrap">
          {%- for value in option.values -%}
            {%- comment -%} Check if this size is available {%- endcomment -%}
            {%- assign size_available = false -%}
            {%- for variant in product.variants -%}
              {%- if variant.options[size_option_index] == value and variant.available -%}
                {%- assign size_available = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            
            <button
              type="button"
              class="size-button px-5 py-2 border rounded-full text-xs font-semibold tracking-[0.12em] transition-all
                     {% if current_variant.options[size_option_index] == value %}
                       bg-[#0D0D0D] text-white border-[#0D0D0D]
                     {% elsif size_available %}
                       border-border text-[#0D0D0D] hover:border-[#0D0D0D]
                     {% else %}
                       border-border text-muted-foreground opacity-50 cursor-not-allowed
                     {% endif %}"
              data-size="{{ value }}"
              data-option-index="{{ size_option_index | plus: 1 }}"
              {% unless size_available %}disabled{% endunless %}
              aria-label="Size {{ value }}"
            >
              {{ value }}
            </button>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%} Hidden variant selector for form submission {%- endcomment -%}
<select
  name="id"
  id="product-variant-id"
  class="hidden"
  aria-label="Product variant"
>
  {%- for variant in product.variants -%}
    <option
      value="{{ variant.id }}"
      {% if variant == current_variant %}selected{% endif %}
      {% unless variant.available %}disabled{% endunless %}
    >
      {{ variant.title }} - {{ variant.price | money }}
    </option>
  {%- endfor -%}
</select>

{%- comment -%} JavaScript for Variant Selection {%- endcomment -%}
<script>
  (function() {
    const product = {{ product | json }};
    let selectedOptions = {
      {% for option in product.options_with_values %}
        {% assign option_index = forloop.index %}
        option{{ option_index }}: "{{ current_variant.options[forloop.index0] }}"{% unless forloop.last %},{% endunless %}
      {% endfor %}
    };

    // Color swatch click handler
    document.querySelectorAll('.color-swatch').forEach(button => {
      button.addEventListener('click', function() {
        const color = this.dataset.color;
        const optionIndex = this.dataset.optionIndex;
        selectedOptions[`option${optionIndex}`] = color;
        
        // Update selected color display
        document.getElementById('selected-color').textContent = color;
        
        // Update active state
        document.querySelectorAll('.color-swatch').forEach(btn => {
          btn.classList.remove('border-primary', 'ring-2', 'ring-primary', 'ring-offset-2');
          btn.classList.add('border-border');
        });
        this.classList.remove('border-border');
        this.classList.add('border-primary', 'ring-2', 'ring-primary', 'ring-offset-2');
        
        updateVariant();
      });
    });

    // Size button click handler
    document.querySelectorAll('.size-button:not([disabled])').forEach(button => {
      button.addEventListener('click', function() {
        const size = this.dataset.size;
        const optionIndex = this.dataset.optionIndex;
        selectedOptions[`option${optionIndex}`] = size;
        
        // Update active state
        document.querySelectorAll('.size-button').forEach(btn => {
          btn.classList.remove('bg-[#0D0D0D]', 'text-white', 'border-[#0D0D0D]');
          btn.classList.add('border-border', 'text-[#0D0D0D]');
        });
        this.classList.remove('border-border', 'text-[#0D0D0D]');
        this.classList.add('bg-[#0D0D0D]', 'text-white', 'border-[#0D0D0D]');
        
        updateVariant();
      });
    });

    // Update variant based on selected options
    function updateVariant() {
      // Find matching variant
      const matchingVariant = product.variants.find(variant => {
        return variant.options.every((option, index) => {
          return option === selectedOptions[`option${index + 1}`];
        });
      });

      if (matchingVariant) {
        // Update hidden select
        document.getElementById('product-variant-id').value = matchingVariant.id;
        
        // Update price
        const priceElement = document.getElementById('product-price');
        if (priceElement) {
          priceElement.textContent = formatMoney(matchingVariant.price);
        }
        
        // Update URL without reload
        const url = new URL(window.location);
        url.searchParams.set('variant', matchingVariant.id);
        window.history.replaceState({}, '', url);
        
        // Trigger custom event for other components to listen
        document.dispatchEvent(new CustomEvent('variant:change', {
          detail: { variant: matchingVariant }
        }));
      }
    }

    // Simple money formatter (customize based on your currency settings)
    function formatMoney(cents) {
      return 'EGP ' + (cents / 100).toFixed(2);
    }
  })();

  // Size Guide modal function (to be implemented)
  function openSizeGuide() {
    // Open size guide modal
    console.log('Open size guide modal');
    // You can trigger a modal/drawer here
  }

  // Size Predictor modal function (to be implemented)
  function openSizePredictor() {
    // Open size predictor modal
    console.log('Open size predictor modal');
    // You can trigger your size predictor modal here
  }
</script>

{% comment %}
  CONVERSION NOTES:
  
  React → Liquid Mappings:
  - useState(selectedColor) → JavaScript selectedOptions object
  - useState(selectedSize) → JavaScript selectedOptions object
  - product.colors.map() → {% for option in product.options_with_values %}
  - product.sizes.map() → {% for value in option.values %}
  - onClick handlers → addEventListener
  - className conditions → {% if %} with class assignment
  
  Shopify Features Used:
  - {{ product.options }} - Product option names
  - {{ product.options_with_values }} - Options with all values
  - {{ product.variants }} - All product variants
  - {{ current_variant.options }} - Selected variant options
  - product.metafields.colors - Color hex codes (optional)
  
  Required Metafields (Optional):
  For color swatches, add metafield namespace: colors
  - Format: colors.black = "#000000"
  - Format: colors.white = "#FFFFFF"
  - Format: colors.red = "#DC2626"
  
  Variant Selection Logic:
  1. User clicks color → Updates selectedOptions
  2. User clicks size → Updates selectedOptions
  3. System finds matching variant
  4. Updates hidden select, price, URL
  5. Triggers custom event for other components
  
  Size Availability:
  - Loops through all variants to check if size is in stock
  - Disables button if no available variants with that size
  - Grays out unavailable sizes
  
  Optional Enhancements:
  1. Add swipe gesture for mobile color selection
  2. Show color name on hover
  3. Add "Out of Stock" indicator
  4. Add "Notify Me" button for out of stock variants
  5. Add size recommendation based on previous purchases
{% endcomment %}
