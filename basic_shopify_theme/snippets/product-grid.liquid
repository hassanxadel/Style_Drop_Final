{% comment %}
  StyleDrop Product Grid Snippet
  Converted from: src/components/ProductGrid.tsx
  
  Responsive grid layout for displaying products
  
  Usage:
  {% render 'product-grid', products: collection.products, columns: 3 %}
{% endcomment %}

{%- assign grid_columns = columns | default: 3 -%}
{%- assign grid_modifier = 'styledrop-product-grid__grid--cols-2-md3' -%}
{%- if grid_columns == 2 -%}
  {%- assign grid_modifier = 'styledrop-product-grid__grid--cols-2-md2' -%}
{%- elsif grid_columns == 4 -%}
  {%- assign grid_modifier = 'styledrop-product-grid__grid--cols-2-md4' -%}
{%- endif -%}

{{ 'styledrop-product-card.css' | asset_url | stylesheet_tag }}

{{ 'styledrop-product-grid.css' | asset_url | stylesheet_tag }}

<div class="styledrop-product-grid__grid {{ grid_modifier }}">
  {%- for product in products -%}
    {% render 'product-card', product: product %}
  {%- else -%}
    <p class="styledrop-product-grid__empty">
      No products found.
    </p>
  {%- endfor -%}
</div>
