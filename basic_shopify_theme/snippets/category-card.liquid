{% comment %}
  StyleDrop Category Card Snippet
  Converted from: src/components/CategoryCard.tsx

  Features:
  - Category image with hover zoom
  - Gradient overlay
  - Category name display
  - Flexible grid span (small / tall / wide)

  Usage:
  {% render 'category-card',
    category_name: 'WOMEN',
    category_url: '/collections/women',
    category_image: section.settings.image,
    grid_span: 'tall'
  %}
{% endcomment %}

{{ 'styledrop-category-card.css' | asset_url | stylesheet_tag }}

<a
  href="{{ category_url | default: '/collections/all' }}"
  class="
    styledrop-category-card
    {%- liquid
      assign desktop_span = grid_span_desktop | default: grid_span | default: 'small'
      assign mobile_span = grid_span_mobile | default: grid_span | default: 'small'

      if desktop_span == 'normal'
        assign desktop_span = 'small'
      endif
      if mobile_span == 'normal'
        assign mobile_span = 'small'
      endif
    -%}
    {%- if desktop_span == 'tall' -%}
      styledrop-category-card--tall-desktop
    {%- elsif desktop_span == 'wide' -%}
      styledrop-category-card--wide-desktop
    {%- endif -%}
    {%- if mobile_span == 'tall' -%}
      styledrop-category-card--tall-mobile
    {%- elsif mobile_span == 'wide' -%}
      styledrop-category-card--wide-mobile
    {%- endif -%}
  "
>
  {%- comment -%} Category Image {%- endcomment -%}
  {%- if category_image != blank -%}
    <img
      src="{{ category_image | image_url: width: 800 }}"
      alt="{{ category_name }}"
      class="styledrop-category-card__img"
      width="800"
      height="600"
      loading="lazy"
    />
  {%- else -%}
    <div class="styledrop-category-card__placeholder"></div>
  {%- endif -%}

  {%- comment -%} Gradient Overlay {%- endcomment -%}
  <div class="styledrop-category-card__overlay"></div>

  {%- comment -%} Category Name {%- endcomment -%}
  <span class="styledrop-category-card__name">
    {{ category_name }}
  </span>
</a>
