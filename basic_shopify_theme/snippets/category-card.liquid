{% comment %}
  StyleDrop Category Card Snippet
  Converted from: src/components/CategoryCard.tsx
  
  Features:
  - Category image with hover zoom
  - Gradient overlay
  - Category name display
  - Flexible grid span
  
  Usage:
  {% render 'category-card', 
    category_name: 'WOMEN',
    category_url: '/collections/women',
    category_image: section.settings.image,
    grid_span: 'col-span-1 row-span-2'
  %}
{% endcomment %}

<a
  href="{{ category_url | default: '/collections/all' }}"
  class="relative rounded-lg overflow-hidden cursor-pointer group {{ grid_span | default: 'col-span-1' }}"
>
  {%- comment -%} Category Image {%- endcomment -%}
  {%- if category_image != blank -%}
    <img
      src="{{ category_image | image_url: width: 800 }}"
      alt="{{ category_name }}"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  {%- else -%}
    <div class="w-full h-full bg-gray-300"></div>
  {%- endif -%}

  {%- comment -%} Gradient Overlay {%- endcomment -%}
  <div class="absolute inset-0 bg-gradient-to-t from-primary/70 to-transparent"></div>

  {%- comment -%} Category Name {%- endcomment -%}
  <span class="absolute bottom-4 left-4 font-display text-2xl text-primary-foreground">
    {{ category_name }}
  </span>
</a>
