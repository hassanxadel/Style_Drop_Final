{% comment %}
  Button Snippet — sd-button.liquid
  Converted from: src/components/ui/button.tsx
  Valgara Pattern: No Tailwind. styledrop-btn--* BEM modifiers only.

  Usage:
  {% render 'sd-button', label: 'Checkout', variant: 'default', size: 'default' %}
  {% render 'sd-button', label: 'Delete', variant: 'destructive' %}
  {% render 'sd-button', label: 'Cancel', variant: 'outline', href: '/cart' %}
  {% render 'sd-button', label: 'Save', variant: 'secondary', size: 'sm' %}
  {% render 'sd-button', label: 'More', variant: 'ghost' %}
  {% render 'sd-button', label: 'Terms', variant: 'link', href: '/pages/terms' %}

  Params:
    label:    Button text (required)
    variant:  'default' | 'destructive' | 'outline' | 'secondary' | 'ghost' | 'link'
    size:     'default' | 'sm' | 'lg' | 'icon'
    href:     If set, renders as <a> instead of <button>
    type:     Button type attribute (default: 'button')
    name:     Button name attribute
    disabled: Boolean — adds disabled attribute and style
    class:    Extra classes to append (optional)
{% endcomment %}

{{ 'styledrop-button.css' | asset_url | stylesheet_tag }}

{%- assign btn_variant = variant | default: 'default' -%}
{%- assign btn_size    = size    | default: 'default' -%}
{%- assign btn_class   = 'styledrop-btn styledrop-btn--' | append: btn_variant | append: ' styledrop-btn--size-' | append: btn_size -%}
{%- if class != blank -%}
  {%- assign btn_class = btn_class | append: ' ' | append: class -%}
{%- endif -%}

{%- if href != blank -%}
  <a href="{{ href }}" class="{{ btn_class }}" {% if disabled %}aria-disabled="true"{% endif %}>
    {{ label }}
  </a>
{%- else -%}
  <button
    type="{{ type | default: 'button' }}"
    class="{{ btn_class }}"
    {% if name != blank %}name="{{ name }}"{% endif %}
    {% if disabled %}disabled{% endif %}
  >
    {{ label }}
  </button>
{%- endif -%}
