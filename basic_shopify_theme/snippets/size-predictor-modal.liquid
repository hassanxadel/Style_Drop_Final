{% comment %}
  Size Predictor Modal
  
  Converts React SizePredictor to Shopify Liquid
  Source: src/components/SizePredictor.tsx
  
  Features:
  - Smart size recommendation based on measurements
  - Category toggle (Tops / Pants)
  - BMI-based calculation logic
  - Responsive modal design
  - Pure JavaScript (no dependencies)
  
  Usage:
  Add to product template:
  {% render 'size-predictor-modal' %}
  
  Trigger from anywhere:
  <button onclick="openSizePredictor()">Find Your Best Size</button>
{% endcomment %}

{%- comment -%} Modal HTML Structure {%- endcomment -%}
{{ 'styledrop-size-predictor-modal.css' | asset_url | stylesheet_tag }}

<div id="size-predictor-modal" class="hidden styledrop-size-predictor-modal">
  {%- comment -%} Backdrop {%- endcomment -%}
  <div class="styledrop-size-predictor-modal__backdrop" onclick="closeSizePredictor()"></div>

  {%- comment -%} Modal Container {%- endcomment -%}
  <div class="styledrop-size-predictor-modal__panel">
    
    {%- comment -%} Header {%- endcomment -%}
    <div class="styledrop-size-predictor-modal__header">
      <div class="styledrop-size-predictor-modal__header-left">
        <div class="styledrop-size-predictor-modal__header-icon">
          {%- comment -%} Zap Icon {%- endcomment -%}
          <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/>
          </svg>
        </div>
        <div>
          <h2 class="styledrop-size-predictor-modal__title">Find Your Perfect Size</h2>
          <p class="styledrop-size-predictor-modal__subtitle">Get personalized size recommendation</p>
        </div>
      </div>
      <button
        onclick="closeSizePredictor()"
        class="styledrop-size-predictor-modal__close-btn"
        aria-label="Close"
      >
        {%- comment -%} X Icon {%- endcomment -%}
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    {%- comment -%} Content {%- endcomment -%}
    <div class="styledrop-size-predictor-modal__content">
      
      {%- comment -%} Category Toggle {%- endcomment -%}
      <div class="styledrop-size-predictor-modal__section">
        <label class="styledrop-size-predictor-modal__label">Product Category</label>
        <div class="styledrop-size-predictor-modal__category-row">
          <button
            id="category-tops"
            onclick="switchCategory('tops')"
            class="styledrop-size-predictor-modal__category-btn styledrop-size-predictor-modal__category-btn--active"
          >
            TOPS
          </button>
          <button
            id="category-pants"
            onclick="switchCategory('pants')"
            class="styledrop-size-predictor-modal__category-btn"
          >
            PANTS
          </button>
        </div>
      </div>

      {%- comment -%} Input Fields {%- endcomment -%}
      {%- comment -%} Height {%- endcomment -%}
      <div class="styledrop-size-predictor-modal__section">
        <label for="sp-height" class="styledrop-size-predictor-modal__label">
          Height <span style="color: var(--sd-accent);">*</span>
        </label>
        <div class="styledrop-size-predictor-modal__input-wrap">
          <input
            id="sp-height"
            type="number"
            placeholder="170"
            class="styledrop-size-predictor-modal__input"
          />
          <span class="styledrop-size-predictor-modal__unit">cm</span>
        </div>
      </div>

      {%- comment -%} Weight {%- endcomment -%}
      <div class="styledrop-size-predictor-modal__section">
        <label for="sp-weight" class="styledrop-size-predictor-modal__label">
          Weight <span style="color: var(--sd-accent);">*</span>
        </label>
        <div class="styledrop-size-predictor-modal__input-wrap">
          <input
            id="sp-weight"
            type="number"
            placeholder="70"
            class="styledrop-size-predictor-modal__input"
          />
          <span class="styledrop-size-predictor-modal__unit">kg</span>
        </div>
      </div>

      {%- comment -%} Shoulder Width (Tops only) {%- endcomment -%}
      <div id="shoulder-field" class="styledrop-size-predictor-modal__section">
        <label for="sp-shoulder" class="styledrop-size-predictor-modal__label">
          Shoulder Width <span class="styledrop-size-predictor-modal__label-optional">(optional)</span>
        </label>
        <div class="styledrop-size-predictor-modal__input-wrap">
          <input
            id="sp-shoulder"
            type="number"
            placeholder="44"
            class="styledrop-size-predictor-modal__input"
          />
          <span class="styledrop-size-predictor-modal__unit">cm</span>
        </div>
      </div>

      {%- comment -%} Waist Size (Pants only) {%- endcomment -%}
      <div id="waist-field" class="styledrop-size-predictor-modal__section hidden">
        <label for="sp-waist" class="styledrop-size-predictor-modal__label">
          Waist Size <span class="styledrop-size-predictor-modal__label-optional">(optional)</span>
        </label>
        <div class="styledrop-size-predictor-modal__input-wrap">
          <input
            id="sp-waist"
            type="number"
            placeholder="86"
            class="styledrop-size-predictor-modal__input"
          />
          <span class="styledrop-size-predictor-modal__unit">cm</span>
        </div>
      </div>

      {%- comment -%} Result Display {%- endcomment -%}
      <div id="size-result" class="hidden styledrop-size-predictor-modal__result">
        <div class="styledrop-size-predictor-modal__result-top">
          <div class="styledrop-size-predictor-modal__result-icon">
            {%- comment -%} TrendingUp Icon {%- endcomment -%}
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          </div>
          <div>
            <p class="styledrop-size-predictor-modal__result-badge">Recommended Size</p>
            <p id="recommended-size" class="styledrop-size-predictor-modal__result-size"></p>
          </div>
        </div>
        <p class="styledrop-size-predictor-modal__result-text">
          Based on your measurements, we recommend size <strong id="recommended-size-text"></strong>. 
          This is an estimate - individual fit may vary by brand and style.
        </p>
      </div>
    </div>

    {%- comment -%} Footer Actions {%- endcomment -%}
    <div class="styledrop-size-predictor-modal__footer">
      <div id="initial-buttons" class="styledrop-size-predictor-modal__footer-btns">
        <button
          onclick="closeSizePredictor()"
          class="styledrop-size-predictor-modal__btn"
        >
          Cancel
        </button>
        <button
          onclick="calculateSize()"
          class="styledrop-size-predictor-modal__btn styledrop-size-predictor-modal__btn--primary"
        >
          <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"/>
          </svg>
          Calculate Size
        </button>
      </div>
      
      <div id="result-buttons" class="hidden styledrop-size-predictor-modal__footer-btns">
        <button
          onclick="resetCalculator()"
          class="styledrop-size-predictor-modal__btn"
        >
          Try Again
        </button>
        <button
          onclick="closeSizePredictor()"
          class="styledrop-size-predictor-modal__btn styledrop-size-predictor-modal__btn--primary"
        >
          Got It!
        </button>
      </div>
    </div>
  </div>
</div>

{%- comment -%} JavaScript for Size Predictor {%- endcomment -%}
<script>
  // Size calculation logic (portable, no dependencies)
  function calculateSizeRecommendation(category, height, weight, shoulderWidth, waistSize) {
    const bmi = weight / ((height / 100) ** 2);
    
    if (category === 'tops') {
      if (height < 165 && weight < 55 && (shoulderWidth || 0) < 40) return 'XS';
      if (height < 170 && weight < 65 && bmi < 23) return 'S';
      if (height > 178 || weight > 80 || bmi > 26) return 'L';
      if (height > 185 || weight > 90 || (shoulderWidth || 0) > 48) return 'XL';
      return 'M';
    } else {
      if (height < 165 && (waistSize || 0) < 76 && weight < 55) return 'XS';
      if ((waistSize || 0) < 81 && bmi < 23 && height < 175) return 'S';
      if ((waistSize || 0) > 91 || weight > 85 || bmi > 26) return 'L';
      if ((waistSize || 0) > 101 || weight > 95 || height > 190) return 'XL';
      return 'M';
    }
  }

  let currentCategory = 'tops';

  function openSizePredictor() {
    document.getElementById('size-predictor-modal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeSizePredictor() {
    document.getElementById('size-predictor-modal').classList.add('hidden');
    document.body.style.overflow = 'unset';
    resetCalculator();
  }

  function switchCategory(category) {
    currentCategory = category;
    
    // Update button states
    if (category === 'tops') {
      document.getElementById('category-tops').classList.add('styledrop-size-predictor-modal__category-btn--active');
      document.getElementById('category-pants').classList.remove('styledrop-size-predictor-modal__category-btn--active');
      document.getElementById('shoulder-field').classList.remove('hidden');
      document.getElementById('waist-field').classList.add('hidden');
    } else {
      document.getElementById('category-pants').classList.add('styledrop-size-predictor-modal__category-btn--active');
      document.getElementById('category-tops').classList.remove('styledrop-size-predictor-modal__category-btn--active');
      document.getElementById('shoulder-field').classList.add('hidden');
      document.getElementById('waist-field').classList.remove('hidden');
    }
    
    // Reset inputs
    document.getElementById('sp-height').value = '';
    document.getElementById('sp-weight').value = '';
    document.getElementById('sp-shoulder').value = '';
    document.getElementById('sp-waist').value = '';
    hideResult();
  }

  function calculateSize() {
    const height = parseFloat(document.getElementById('sp-height').value);
    const weight = parseFloat(document.getElementById('sp-weight').value);
    const shoulderWidth = parseFloat(document.getElementById('sp-shoulder').value) || 0;
    const waistSize = parseFloat(document.getElementById('sp-waist').value) || 0;

    // Validation
    if (!height || !weight) {
      alert('Please fill in all required fields (Height and Weight)');
      return;
    }

    // Calculate
    const size = calculateSizeRecommendation(
      currentCategory,
      height,
      weight,
      shoulderWidth,
      waistSize
    );

    // Display result
    document.getElementById('recommended-size').textContent = size;
    document.getElementById('recommended-size-text').textContent = size;
    document.getElementById('size-result').classList.remove('hidden');
    document.getElementById('initial-buttons').classList.add('hidden');
    document.getElementById('result-buttons').classList.remove('hidden');
    document.getElementById('result-buttons').style.display = 'flex';
  }

  function resetCalculator() {
    document.getElementById('sp-height').value = '';
    document.getElementById('sp-weight').value = '';
    document.getElementById('sp-shoulder').value = '';
    document.getElementById('sp-waist').value = '';
    hideResult();
  }

  function hideResult() {
    document.getElementById('size-result').classList.add('hidden');
    document.getElementById('initial-buttons').classList.remove('hidden');
    document.getElementById('initial-buttons').style.display = 'flex';
    document.getElementById('result-buttons').classList.add('hidden');
  }

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !document.getElementById('size-predictor-modal').classList.contains('hidden')) {
      closeSizePredictor();
    }
  });
</script>

{% comment %}
  CONVERSION NOTES:
  
  React → Pure JavaScript:
  - useState hooks → global variables
  - React components → HTML + vanilla JS
  - onClick → onclick attribute
  - className conditions → direct class manipulation
  - Conditional rendering → classList.add/remove('hidden')
  
  Calculation Logic:
  - Exact same BMI-based algorithm
  - No dependencies required
  - Portable to any Shopify theme
  - Can be easily customized
  
  Modal Behavior:
  - Opens with openSizePredictor()
  - Closes on backdrop click, X button, or Escape key
  - Prevents body scroll when open
  - Responsive design (mobile optimized)
  
  Integration:
  1. Include this snippet in product template
  2. Add trigger buttons where needed:
     <button onclick="openSizePredictor()">Find Size</button>
  3. Already integrated in variant-selector snippet
  
  Customization:
  - Adjust size ranges in calculateSizeRecommendation()
  - Change BMI thresholds for different fit preferences
  - Add more measurement fields if needed
  - Customize styling via Tailwind classes
  
  Testing:
  - Test with various height/weight combinations
  - Verify correct size recommendations
  - Check mobile responsiveness
  - Ensure proper modal behavior
{% endcomment %}
