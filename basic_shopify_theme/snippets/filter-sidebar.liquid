{% comment %}
  StyleDrop Filter Sidebar Snippet
  Converted from: src/components/FilterSidebar.tsx

  Features:
  - Category filters
  - Brand filters (from vendors)
  - Price range filters
  - Size filters
  - Color filters
  - Mobile responsive with close button

  Usage:
  {% render 'filter-sidebar', collection: collection %}
{% endcomment %}

{{ 'styledrop-filter-sidebar.css' | asset_url | stylesheet_tag }}

<div class="styledrop-filter-sidebar">

  {%- comment -%} Mobile Close Button {%- endcomment -%}
  <div class="styledrop-filter-sidebar__mobile-header">
    <h3 class="styledrop-filter-sidebar__mobile-title">Filters</h3>
    <button
      type="button"
      class="styledrop-filter-sidebar__close-btn"
      onclick="sdCloseFilterSidebar()"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  {%- comment -%} Categories {%- endcomment -%}
  <div class="styledrop-filter-sidebar__group">
    <h3 class="styledrop-filter-sidebar__group-title" onclick="sdToggleFilterSection(this)">
      CATEGORY
      <svg class="styledrop-filter-sidebar__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </h3>
    <div class="styledrop-filter-sidebar__options">
      {%- for link in linklists['main-menu'].links -%}
        {%- if link.type == 'collection_link' -%}
          <label class="styledrop-filter-sidebar__label">
            <input
              type="checkbox"
              name="category"
              value="{{ link.object.handle }}"
              class="styledrop-filter-sidebar__checkbox"
              {% if collection.handle == link.object.handle %}checked{% endif %}
              onchange="sdApplyFilters()"
            />
            <span class="styledrop-filter-sidebar__label-text">
              {{ link.title }} ({{ link.object.products_count }})
            </span>
          </label>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Price Range {%- endcomment -%}
  <div class="styledrop-filter-sidebar__group styledrop-filter-sidebar__group--bordered">
    <h3 class="styledrop-filter-sidebar__group-title" onclick="sdToggleFilterSection(this)">
      PRICE RANGE
      <svg class="styledrop-filter-sidebar__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </h3>
    <div class="styledrop-filter-sidebar__options">
      {%- assign price_ranges = 'Under EGP 500|0-500,EGP 500 - 1,000|500-1000,EGP 1,000 - 2,000|1000-2000,EGP 2,000 - 5,000|2000-5000,Over EGP 5,000|5000+' | split: ',' -%}
      {%- for range in price_ranges -%}
        {%- assign parts = range | split: '|' -%}
        <label class="styledrop-filter-sidebar__label">
          <input type="checkbox" name="price" value="{{ parts[1] }}" class="styledrop-filter-sidebar__checkbox" onchange="sdApplyFilters()" />
          <span class="styledrop-filter-sidebar__label-text">{{ parts[0] }}</span>
        </label>
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Brands {%- endcomment -%}
  <div class="styledrop-filter-sidebar__group styledrop-filter-sidebar__group--bordered">
    <h3 class="styledrop-filter-sidebar__group-title" onclick="sdToggleFilterSection(this)">
      BRAND
      <svg class="styledrop-filter-sidebar__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </h3>
    <div class="styledrop-filter-sidebar__options styledrop-filter-sidebar__options--scroll">
      {%- assign all_vendors = '' | split: '' -%}
      {%- for product in collection.products -%}
        {%- unless all_vendors contains product.vendor -%}
          {%- assign all_vendors = all_vendors | append: product.vendor | append: ',' | split: ',' -%}
        {%- endunless -%}
      {%- endfor -%}
      {%- for vendor in all_vendors -%}
        <label class="styledrop-filter-sidebar__label">
          <input type="checkbox" name="brand" value="{{ vendor | handleize }}" class="styledrop-filter-sidebar__checkbox" onchange="sdApplyFilters()" />
          <span class="styledrop-filter-sidebar__label-text">{{ vendor }}</span>
        </label>
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Sizes {%- endcomment -%}
  <div class="styledrop-filter-sidebar__group styledrop-filter-sidebar__group--bordered">
    <h3 class="styledrop-filter-sidebar__group-title" onclick="sdToggleFilterSection(this)">
      SIZE
      <svg class="styledrop-filter-sidebar__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </h3>
    <div class="styledrop-filter-sidebar__size-options">
      {%- assign sizes = 'XS,S,M,L,XL,XXL' | split: ',' -%}
      {%- for size in sizes -%}
        <label class="styledrop-filter-sidebar__size-label">
          <input type="checkbox" name="size" value="{{ size }}" class="styledrop-filter-sidebar__size-input" onchange="sdApplyFilters()" />
          <span class="styledrop-filter-sidebar__size-btn">{{ size }}</span>
        </label>
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Colors {%- endcomment -%}
  <div class="styledrop-filter-sidebar__group styledrop-filter-sidebar__group--bordered">
    <h3 class="styledrop-filter-sidebar__group-title" onclick="sdToggleFilterSection(this)">
      COLOR
      <svg class="styledrop-filter-sidebar__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </h3>
    <div class="styledrop-filter-sidebar__color-options">
      {%- assign color_swatches = 'black:#000000,white:#FFFFFF,beige:#D4C5B9,brown:#92400E,blue:#2563EB,green:#059669,red:#DC2626' | split: ',' -%}
      {%- for swatch in color_swatches -%}
        {%- assign swatch_parts = swatch | split: ':' -%}
        <label class="styledrop-filter-sidebar__color-label">
          <input type="checkbox" name="color" value="{{ swatch_parts[0] }}" class="styledrop-filter-sidebar__color-input" onchange="sdApplyFilters()" />
          <span
            class="styledrop-filter-sidebar__color-swatch"
            style="background-color: {{ swatch_parts[1] }};"
            title="{{ swatch_parts[0] | capitalize }}"
          ></span>
        </label>
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Clear All {%- endcomment -%}
  <button
    type="button"
    class="styledrop-filter-sidebar__clear-btn"
    onclick="sdClearAllFilters()"
  >
    Clear All Filters
  </button>
</div>

<script>
function sdToggleFilterSection(titleEl) {
  const options = titleEl.nextElementSibling;
  const chevron = titleEl.querySelector('.styledrop-filter-sidebar__chevron');
  const isHidden = options.style.display === 'none';
  options.style.display = isHidden ? '' : 'none';
  chevron.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(-90deg)';
}

function sdApplyFilters() {
  const params = new URLSearchParams(window.location.search);
  ['category', 'price', 'brand', 'size', 'color'].forEach(function(name) {
    const vals = Array.from(document.querySelectorAll('.styledrop-filter-sidebar input[name="' + name + '"]:checked')).map(function(el) { return el.value; });
    if (vals.length) params.set(name, vals.join(','));
    else params.delete(name);
  });
  window.location.search = params.toString();
}

function sdClearAllFilters() {
  document.querySelectorAll('.styledrop-filter-sidebar input[type="checkbox"]').forEach(function(el) { el.checked = false; });
  sdApplyFilters();
}

// Valgara-compliant close: uses sd-sidebar--closed BEM modifier, not 'hidden'
function sdCloseFilterSidebar() {
  const sidebar = document.querySelector('.styledrop-filter-sidebar-mobile');
  if (sidebar) sidebar.classList.add('sd-sidebar--closed');
}
</script>
