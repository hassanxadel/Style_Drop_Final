{% comment %}
  StyleDrop Product Card Snippet
  Converted from: src/components/ProductCard.tsx
  
  Features:
  - Product image with hover zoom
  - Badge support (sale, new, out of stock)
  - Wishlist button (top-right)
  - Quick add to cart button (bottom-right)
  - Color swatches
  - Pricing with strikethrough for sales
  
  Usage:
  {% render 'product-card', product: product %}
{% endcomment %}

<a
  href="{{ product.url }}"
  class="styledrop-product-card"
>
  {%- comment -%} Product Image Container {%- endcomment -%}
  <div class="styledrop-product-card__media">
    {%- comment -%} Main Product Image {%- endcomment -%}
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.title | escape }}"
        class="styledrop-product-card__img"
        loading="lazy"
        width="600"
        height="800"
      />
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'styledrop-product-card__img' }}
    {%- endif -%}

    {%- comment -%} Product Badge - Sale/New/Out of Stock {%- endcomment -%}
    {%- assign badge_text = '' -%}
    {%- assign badge_class = '' -%}
    {%- assign badge_modifier = '' -%}
    
    {%- if product.available == false -%}
      {%- assign badge_text = 'OUT OF STOCK' -%}
      {%- assign badge_modifier = 'styledrop-product-card__badge--oos' -%}
    {%- elsif product.tags contains 'new' -%}
      {%- assign badge_text = 'NEW' -%}
      {%- assign badge_modifier = 'styledrop-product-card__badge--new' -%}
    {%- elsif product.compare_at_price > product.price -%}
      {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
      {%- assign badge_text = savings | append: '% OFF' -%}
      {%- assign badge_modifier = 'styledrop-product-card__badge--sale' -%}
    {%- endif -%}

    {%- if badge_text != '' -%}
      <span
        class="styledrop-product-card__badge {{ badge_modifier }}"
        style="display: inline-block;"
      >
        {{ badge_text }}
      </span>
    {%- endif -%}

    {%- comment -%} Wishlist Button - Top Right {%- endcomment -%}
    <button
      type="button"
      class="styledrop-product-card__wishlist wishlist-toggle"
      aria-label="Add to wishlist"
      data-product-handle="{{ product.handle }}"
      onclick="toggleWishlist('{{ product.handle }}'); event.preventDefault();"
    >
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="styledrop-product-card__wishlist-icon">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    </button>

    {%- comment -%} Add to Cart Button - Bottom Right {%- endcomment -%}
    {%- assign quick_add_mode = quick_add | default: 'standard' -%}
    {%- if product.available and quick_add_mode != 'none' -%}
      <button
        type="button"
        class="styledrop-product-card__quick-add quick-add-btn"
        aria-label="Quick add to cart"
        data-product-id="{{ product.selected_or_first_available_variant.id }}"
        onclick="quickAddToCart({{ product.selected_or_first_available_variant.id }}); event.preventDefault();"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
      </button>
    {%- endif -%}

    {%- comment -%} Out of Stock Overlay {%- endcomment -%}
    {%- unless product.available -%}
      <div class="styledrop-product-card__overlay">
        <span class="styledrop-product-card__overlay-pill">
          OUT OF STOCK
        </span>
      </div>
    {%- endunless -%}
  </div>

  {%- comment -%} Product Info {%- endcomment -%}
  <div class="styledrop-product-card__info">
    {%- comment -%} Brand Name {%- endcomment -%}
    <p class="styledrop-product-card__brand">
      {{ product.vendor }}
    </p>

    {%- comment -%} Product Name {%- endcomment -%}
    <p class="styledrop-product-card__title">
      {{ product.title }}
    </p>

    {%- comment -%} Color Swatches (from product options) {%- endcomment -%}
    {%- if product.options_with_values.size > 0 -%}
      <div class="styledrop-product-card__swatches">
        {%- for option in product.options_with_values -%}
          {%- if option.name == 'Color' or option.name == 'Colour' -%}
            {%- for value in option.values limit: 5 -%}
              {%- assign color_value = value | downcase -%}
              {%- assign color_hex = '#000000' -%}
              
              {%- case color_value -%}
                {%- when 'black' -%}{%- assign color_hex = '#000000' -%}
                {%- when 'white' -%}{%- assign color_hex = '#FFFFFF' -%}
                {%- when 'red' -%}{%- assign color_hex = '#DC2626' -%}
                {%- when 'blue' -%}{%- assign color_hex = '#2563EB' -%}
                {%- when 'green' -%}{%- assign color_hex = '#059669' -%}
                {%- when 'beige' -%}{%- assign color_hex = '#D4C5B9' -%}
                {%- when 'brown' -%}{%- assign color_hex = '#92400E' -%}
                {%- when 'grey' or 'gray' -%}{%- assign color_hex = '#6B7280' -%}
                {%- else -%}{%- assign color_hex = '#9CA3AF' -%}
              {%- endcase -%}
              
              <span
                class="styledrop-product-card__swatch"
                style="background-color: {{ color_hex }};"
                title="{{ value }}"
              ></span>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Pricing {%- endcomment -%}
    <div class="styledrop-product-card__price-row">
      {%- comment -%} Current Price {%- endcomment -%}
      <p class="styledrop-product-card__price">
        {{ product.price | money }}
      </p>

      {%- comment -%} Original Price (if on sale) {%- endcomment -%}
      {%- if product.compare_at_price > product.price -%}
        <p class="styledrop-product-card__compare">
          {{ product.compare_at_price | money }}
        </p>
      {%- endif -%}
    </div>
  </div>
</a>

<script>
// Quick Add to Cart
function quickAddToCart(variantId) {
  fetch('/cart/add.js', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      id: variantId,
      quantity: 1
    })
  })
  .then(response => response.json())
  .then(data => {
    // Refresh cart count
    fetch('/cart.js')
      .then(res => res.json())
      .then(cart => {
        // Update cart badge
        const badge = document.querySelector('[aria-label="Cart"] span');
        if (badge) badge.textContent = cart.item_count;
      });
    
    // Show success message (optional)
    alert('Product added to cart!');
  })
  .catch(error => {
    console.error('Error:', error);
    alert('Failed to add product to cart');
  });
}

// Wishlist toggle
function toggleWishlist(productHandle) {
  let wishlist = JSON.parse(localStorage.getItem('wishlist') || '[]');
  
  if (wishlist.includes(productHandle)) {
    wishlist = wishlist.filter(h => h !== productHandle);
  } else {
    wishlist.push(productHandle);
  }
  
  localStorage.setItem('wishlist', JSON.stringify(wishlist));
  
  // Update UI (optional)
  console.log('Wishlist updated:', wishlist);
}
</script>
