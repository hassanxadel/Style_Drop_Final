{% comment %}
  StyleDrop Collection Filters Section
  Converted from: src/components/CollectionFilters.tsx

  Top bar with view toggle, sorting, and filter button

  Usage:
  {% render 'collection-filters', collection: collection, product_count: collection.products_count %}
{% endcomment %}

{{ 'styledrop-collection-filters.css' | asset_url | stylesheet_tag }}

<div class="styledrop-collection-filters">

  {%- comment -%} Left: Product Count & View Toggle {%- endcomment -%}
  <div class="styledrop-collection-filters__left">
    <p class="styledrop-collection-filters__count">
      <span class="styledrop-collection-filters__count-num">{{ product_count | default: 0 }}</span>
      product{{ product_count | default: 0 | pluralize: '', 's' }}
    </p>

    {%- comment -%} View Toggle (Grid/List) — desktop only {%- endcomment -%}
    <div class="styledrop-collection-filters__view-toggle">
      <button
        type="button"
        class="styledrop-collection-filters__view-btn styledrop-collection-filters__view-btn--active"
        data-view="grid"
        aria-label="Grid view"
        onclick="sdToggleView('grid')"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7"></rect>
          <rect x="14" y="3" width="7" height="7"></rect>
          <rect x="14" y="14" width="7" height="7"></rect>
          <rect x="3" y="14" width="7" height="7"></rect>
        </svg>
      </button>
      <button
        type="button"
        class="styledrop-collection-filters__view-btn"
        data-view="list"
        aria-label="List view"
        onclick="sdToggleView('list')"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7"></rect>
          <rect x="3" y="14" width="7" height="7"></rect>
          <rect x="14" y="4" width="7" height="6"></rect>
          <rect x="14" y="14" width="7" height="6"></rect>
        </svg>
      </button>
    </div>
  </div>

  {%- comment -%} Right: Sort & Filter {%- endcomment -%}
  <div class="styledrop-collection-filters__right">

    {%- comment -%} Sort Dropdown {%- endcomment -%}
    <div class="styledrop-collection-filters__sort-wrap">
      <select
        class="styledrop-collection-filters__sort-select"
        onchange="sdHandleSort(this.value)"
      >
        <option value="">Sort by</option>
        <option value="manual">Featured</option>
        <option value="best-selling">Best Selling</option>
        <option value="title-ascending">Alphabetically, A-Z</option>
        <option value="title-descending">Alphabetically, Z-A</option>
        <option value="price-ascending">Price, Low to High</option>
        <option value="price-descending">Price, High to Low</option>
        <option value="created-ascending">Date, Old to New</option>
        <option value="created-descending">Date, New to Old</option>
      </select>
      <svg class="styledrop-collection-filters__sort-caret" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>

    {%- comment -%} Filter Button — Mobile only {%- endcomment -%}
    <button
      type="button"
      class="styledrop-collection-filters__filter-btn"
      onclick="sdToggleMobileFilters()"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
      </svg>
      Filters
    </button>
  </div>
</div>

<script>
function sdHandleSort(sortValue) {
  if (!sortValue) return;
  const params = new URLSearchParams(window.location.search);
  params.set('sort_by', sortValue);
  window.location.search = params.toString();
}

// Valgara-compliant: uses BEM modifiers, not Tailwind grid-cols-* class names
function sdToggleView(viewType) {
  document.querySelectorAll('.styledrop-collection-filters__view-btn').forEach(function(btn) {
    btn.classList.remove('styledrop-collection-filters__view-btn--active');
  });
  const activeBtn = document.querySelector('[data-view="' + viewType + '"]');
  if (activeBtn) activeBtn.classList.add('styledrop-collection-filters__view-btn--active');

  const grid = document.querySelector('.product-grid-container');
  if (grid) {
    if (viewType === 'list') {
      grid.classList.remove('sd-grid--grid');
      grid.classList.add('sd-grid--list');
    } else {
      grid.classList.remove('sd-grid--list');
      grid.classList.add('sd-grid--grid');
    }
  }
  localStorage.setItem('sdPreferredView', viewType);
}

function sdToggleMobileFilters() {
  const sidebar = document.querySelector('.styledrop-filter-sidebar-mobile');
  if (sidebar) sidebar.classList.toggle('sd-sidebar--closed');
}

document.addEventListener('DOMContentLoaded', function() {
  const savedView = localStorage.getItem('sdPreferredView') || 'grid';
  sdToggleView(savedView);

  const params = new URLSearchParams(window.location.search);
  const sortBy = params.get('sort_by');
  if (sortBy) {
    const select = document.querySelector('.styledrop-collection-filters__sort-select');
    if (select) select.value = sortBy;
  }
});
</script>
