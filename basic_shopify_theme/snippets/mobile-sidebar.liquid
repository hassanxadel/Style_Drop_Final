{% comment %}
  StyleDrop Mobile Sidebar Snippet
  Converted from: src/components/MobileSidebar.tsx

  Features:
  - Slide-in navigation from left
  - Logo at top
  - Navigation links (with Sale link highlighted)
  - Close button
  - Promo footer
  - Backdrop overlay

  Usage:
  {% render 'mobile-sidebar', menu: 'main-menu', logo: section.settings.logo %}
{% endcomment %}

{{ 'styledrop-mobile-sidebar.css' | asset_url | stylesheet_tag }}

{%- comment -%} Backdrop Overlay — initial state controlled by sd-sidebar-backdrop--hidden (styledrop-header.css) {%- endcomment -%}
<div
  id="mobile-sidebar-backdrop"
  class="sd-mobile-sidebar__backdrop sd-sidebar-backdrop--hidden"
></div>

{%- comment -%} Sidebar — initial closed state controlled by sd-sidebar--closed (styledrop-header.css) {%- endcomment -%}
<div
  id="mobile-sidebar"
  class="sd-mobile-sidebar sd-sidebar--closed"
>
  {%- comment -%} Sidebar Header {%- endcomment -%}
  <div class="sd-mobile-sidebar__header">
    {%- comment -%} Logo {%- endcomment -%}
    <a
      href="{{ routes.root_url }}"
      class="sd-mobile-sidebar__logo"
      onclick="toggleMobileSidebar()"
    >
      {%- if logo != blank -%}
        <img
          src="{{ logo | image_url: width: 150 }}"
          alt="{{ shop.name }}"
          class="sd-mobile-sidebar__logo-img"
          width="150"
          height="64"
        />
      {%- else -%}
        <span class="sd-mobile-sidebar__logo-text">
          {{ shop.name }}
        </span>
      {%- endif -%}
    </a>

    {%- comment -%} Close Button {%- endcomment -%}
    <button
      onclick="toggleMobileSidebar()"
      class="sd-mobile-sidebar__close-btn"
      aria-label="Close menu"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  {%- comment -%} Navigation Links {%- endcomment -%}
  <nav class="sd-mobile-sidebar__nav">
    {%- if menu != blank -%}
      <ul class="sd-mobile-sidebar__nav-list">
        {%- for link in linklists[menu].links -%}
          <li>
            <a
              href="{{ link.url }}"
              class="sd-mobile-sidebar__nav-link{% if link.title == 'Sale' %} sd-mobile-sidebar__nav-link--sale{% endif %}"
              onclick="toggleMobileSidebar()"
            >
              {{ link.title }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </nav>

  {%- comment -%} Footer Info {%- endcomment -%}
  <div class="sd-mobile-sidebar__footer">
    <p>🚚 Free delivery over EGP 975</p>
    <p>💖 New drops every Friday</p>
  </div>
</div>
