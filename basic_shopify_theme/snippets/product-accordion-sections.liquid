</div>

{%- comment -%} JavaScript for Accordion Functionality {%- endcomment -%}
<script>
  (function() {
    // Get all accordion toggles
    const accordionToggles = document.querySelectorAll('.accordion-toggle');

    accordionToggles.forEach(toggle => {
      toggle.addEventListener('click', function() {
        const accordionName = this.dataset.accordion;
        const content = this.nextElementSibling;
        const icon = this.querySelector('.accordion-icon');
        const isExpanded = this.getAttribute('aria-expanded') === 'true';

        // Close all other accordions (optional - remove if you want multiple open)
        accordionToggles.forEach(otherToggle => {
          if (otherToggle !== toggle) {
            const otherContent = otherToggle.nextElementSibling;
            const otherIcon = otherToggle.querySelector('.accordion-icon');
            
            otherToggle.setAttribute('aria-expanded', 'false');
            otherContent.classList.add('hidden');
            otherIcon.classList.remove('styledrop-product-accordion__icon--open');
          }
        });

        // Toggle current accordion
        if (isExpanded) {
          // Close
          this.setAttribute('aria-expanded', 'false');
          content.classList.add('hidden');
        icon.classList.remove('styledrop-product-accordion__icon--open');
        } else {
          // Open
          this.setAttribute('aria-expanded', 'true');
          content.classList.remove('hidden');
        icon.classList.add('styledrop-product-accordion__icon--open');
        }
      });
    });

    // Optional: Open first accordion by default
    // accordionToggles[0]?.click();
  })();
</script>

{% comment %}
  CONVERSION NOTES:
  
  React → Liquid Mappings:
  - useState(openAccordion) → JavaScript aria-expanded attribute
  - accordionSections.map() → Multiple hardcoded sections
  - onClick handlers → addEventListener
  - Conditional rendering → classList.toggle('hidden')
  - ChevronDown rotation → CSS class toggle
  
  Shopify Features Used:
  - product.metafields.custom.* - Custom content fields
  - Accessible ARIA attributes (aria-expanded, aria-controls)
  - Semantic HTML structure
  
  Accordion Behavior:
  - Single accordion open at a time (can be changed)
  - Smooth rotation animation on icon
  - Hover effect on headers
  - Keyboard accessible
  
  Optional Metafields:
  Add these metafields to your products for custom content:
  1. custom.size_guide (multi_line_text_field)
  2. custom.shipping_info (multi_line_text_field)
  3. custom.fabric_care (multi_line_text_field)
  4. custom.material (single_line_text_field)
  5. custom.faq (multi_line_text_field)
  6. custom.return_policy (multi_line_text_field)
  
  Default Content:
  - If metafields are empty, shows default content
  - Can be customized per product type
  - Fallback to generic information
  
  Optional Enhancements:
  1. Allow multiple accordions open simultaneously
  2. Add smooth slide animation with max-height
  3. Add schema markup for FAQ section
  4. Link size guide to separate page/modal
  5. Add icons to each section header
  6. Store accordion state in localStorage
  7. Add print-friendly styles
{% endcomment %}
