{% comment %}
  Product Accordion Sections
  
  Converts React accordion to Shopify Liquid
  Source: ProductDetails.tsx (lines 62-68, 379-400)
  
  Sections:
  - Size Guide
  - Shipping Information
  - Fabric & Care
  - FAQ
  - Return Policy
  
  Usage:
  {% render 'product-accordion-sections', product: product %}
{% endcomment %}

{%- comment -%} Accordion Container {%- endcomment -%}
{{ 'styledrop-product-accordion.css' | asset_url | stylesheet_tag }}

<div class="styledrop-product-accordion">
  
  {%- comment -%} Section 1: Size Guide {%- endcomment -%}
  <div class="styledrop-product-accordion__item">
    <button
      type="button"
      class="accordion-toggle styledrop-product-accordion__toggle"
      data-accordion="size-guide"
      aria-expanded="false"
      aria-controls="size-guide-content"
    >
      <span>Size Guide</span>
      {%- comment -%} ChevronDown Icon {%- endcomment -%}
      <svg 
        class="accordion-icon styledrop-product-accordion__icon" 
        fill="none" 
        stroke="currentColor" 
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>
    <div 
      id="size-guide-content" 
      class="accordion-content styledrop-product-accordion__content hidden"
      aria-labelledby="size-guide"
    >
      {%- if product.metafields.custom.size_guide != blank -%}
        {{ product.metafields.custom.size_guide }}
      {%- else -%}
        <p>Size guide content will be displayed here. Measurements for each size available.</p>
        <p class="mt-2">Please refer to our size chart for accurate measurements.</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Section 2: Shipping Information {%- endcomment -%}
  <div class="styledrop-product-accordion__item">
    <button
      type="button"
      class="accordion-toggle styledrop-product-accordion__toggle"
      data-accordion="shipping"
      aria-expanded="false"
      aria-controls="shipping-content"
    >
      <span>Shipping Information</span>
      <svg 
        class="accordion-icon styledrop-product-accordion__icon" 
