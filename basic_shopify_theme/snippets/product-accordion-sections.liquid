        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>
    <div 
      id="shipping-content" 
      class="accordion-content styledrop-product-accordion__content hidden"
    >
      {%- if product.metafields.custom.shipping_info != blank -%}
        {{ product.metafields.custom.shipping_info }}
      {%- else -%}
        <p>Free shipping on orders over EGP 975.</p>
        <p class="mt-2">Same-day delivery available in select areas.</p>
        <p class="mt-2">Standard shipping takes 2-5 business days.</p>
      {%- endif -%}
