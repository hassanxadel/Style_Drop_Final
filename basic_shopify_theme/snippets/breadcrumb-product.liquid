{% comment %}
  Breadcrumb Navigation for Product Pages
  Converted from: src/pages/ProductDetails.tsx (lines 73-84)
{% endcomment %}

{{ 'styledrop-breadcrumb.css' | asset_url | stylesheet_tag }}

<div class="styledrop-breadcrumb__bar">
  <div class="container">
    <nav class="styledrop-breadcrumb" aria-label="Breadcrumb">

      <svg class="styledrop-breadcrumb__chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>

      <a href="{{ routes.root_url }}" class="styledrop-breadcrumb__link">Home</a>
      <span class="styledrop-breadcrumb__sep" aria-hidden="true">/</span>

      {%- if product.vendor != blank -%}
        <a href="{{ routes.collections_url }}/vendors?q={{ product.vendor | url_encode }}" class="styledrop-breadcrumb__link">
          {{ product.vendor }}
        </a>
        <span class="styledrop-breadcrumb__sep" aria-hidden="true">/</span>
      {%- endif -%}

      <span class="styledrop-breadcrumb__current" aria-current="page">
        {{ product.title }}
      </span>

    </nav>
  </div>
</div>
