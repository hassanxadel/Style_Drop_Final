{% comment %}
  Related Products Section ("Complete the Look")
  Converted from: src/pages/ProductDetails.tsx (Complete the Look section)
  Valgara Pattern: All Tailwind stripped. styledrop-related-products__* BEM classes only.

  Features:
  - Black card design with red "Add to Cart" buttons
  - Shopify Recommendations API with collection fallback
  - Mobile: horizontal scroll (85% card width, snap)
  - Desktop: 4-column grid
  - Wishlist toggle, product badges (Sale/New/Hot), Quick add to cart

  Usage:
  {% render 'related-products-section', product: product, collection_handle: 'all' %}
{% endcomment %}

{{ 'styledrop-related-products.css' | asset_url | stylesheet_tag }}

{%- liquid
  if recommendations.performed and recommendations.products_count > 0
    assign use_recommendations = true
  else
    assign use_recommendations = false
    assign fallback_collection = collections[collection_handle].products
  endif

  assign products_available = false
  if use_recommendations and recommendations.products_count > 0
    assign products_available = true
  elsif fallback_collection.size > 1
    assign products_available = true
  endif
-%}

{%- if products_available -%}
<div class="styledrop-related-products">
  <div class="styledrop-related-products__inner container">
    <div class="styledrop-related-products__card">

      {%- comment -%} Header {%- endcomment -%}
      <div class="styledrop-related-products__header">
        <div>
          <span class="styledrop-related-products__badge">RELATED PRODUCTS</span>
          <h2 class="styledrop-related-products__heading">
            COMPLETE <span class="styledrop-related-products__heading-accent">THE</span> LOOK
          </h2>
        </div>
        <a href="{{ routes.all_products_collection_url }}" class="styledrop-related-products__view-all">
          View all <span aria-hidden="true">→</span>
        </a>
      </div>

      {%- comment -%} Products Grid {%- endcomment -%}
      <div class="styledrop-related-products__grid">

        {%- if use_recommendations -%}
          {%- for related_product in recommendations.products limit: 4 -%}
            <a href="{{ related_product.url }}" class="styledrop-related-products__product-link">
              <div class="styledrop-related-products__product-card">

                <div class="styledrop-related-products__product-img-wrap">
                  {%- if related_product.featured_image -%}
                    <img
                      src="{{ related_product.featured_image | img_url: '600x' }}"
                      alt="{{ related_product.title }}"
                      class="styledrop-related-products__product-img"
                      width="600" height="800" loading="lazy"
                    />
                  {%- endif -%}

                  <button
                    type="button"
                    class="styledrop-related-products__wishlist-btn wishlist-btn"
                    data-product-id="{{ related_product.id }}"
                    aria-label="Add to wishlist"
                    onclick="event.preventDefault(); sdAddToWishlist({{ related_product.id }});"
                  >
                    <svg class="styledrop-related-products__wishlist-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                  </button>

                  {%- if related_product.tags contains 'sale' or related_product.compare_at_price > related_product.price -%}
                    <span class="styledrop-related-products__badge-overlay styledrop-related-products__badge-overlay--sale">
                      <span class="styledrop-related-products__badge-dot"></span>SALE
                    </span>
                  {%- elsif related_product.tags contains 'new' -%}
                    <span class="styledrop-related-products__badge-overlay styledrop-related-products__badge-overlay--new">
                      <span class="styledrop-related-products__badge-dot"></span>NEW
                    </span>
                  {%- elsif related_product.tags contains 'hot' or related_product.tags contains 'bestseller' -%}
                    <span class="styledrop-related-products__badge-overlay styledrop-related-products__badge-overlay--hot">
                      <span class="styledrop-related-products__badge-dot"></span>HOT
                    </span>
                  {%- endif -%}
                </div>

                <div class="styledrop-related-products__product-info">
                  {%- if related_product.vendor != blank -%}
                    <p class="styledrop-related-products__product-vendor">{{ related_product.vendor }}</p>
                  {%- endif -%}
                  <h3 class="styledrop-related-products__product-title">{{ related_product.title }}</h3>
                  <p class="styledrop-related-products__product-price">
                    {%- if related_product.compare_at_price > related_product.price -%}
                      <span>{{ related_product.price | money }}</span>
                      <span class="styledrop-related-products__product-compare">{{ related_product.compare_at_price | money }}</span>
                    {%- else -%}
                      {{ related_product.price | money }}
                    {%- endif -%}
                  </p>
                  <button
                    type="button"
                    class="styledrop-related-products__add-btn quick-add-btn"
                    data-product-id="{{ related_product.id }}"
                    data-variant-id="{{ related_product.selected_or_first_available_variant.id }}"
                    onclick="event.preventDefault(); sdQuickAdd(this);"
                  >
                    <svg class="styledrop-related-products__cart-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                    </svg>
                    ADD TO CART
                  </button>
                </div>
              </div>
            </a>
          {%- endfor -%}

        {%- else -%}
          {%- assign count = 0 -%}
          {%- for item in fallback_collection -%}
            {%- if item.id != product.id and count < 4 -%}
              {%- assign count = count | plus: 1 -%}
              <a href="{{ item.url }}" class="styledrop-related-products__product-link">
                <div class="styledrop-related-products__product-card">
                  <div class="styledrop-related-products__product-img-wrap">
                    {%- if item.featured_image -%}
                      <img
                        src="{{ item.featured_image | img_url: '600x' }}"
                        alt="{{ item.title }}"
                        class="styledrop-related-products__product-img"
                        width="600" height="800" loading="lazy"
                      />
                    {%- endif -%}

                    <button
                      type="button"
                      class="styledrop-related-products__wishlist-btn wishlist-btn"
                      data-product-id="{{ item.id }}"
                      aria-label="Add to wishlist"
                      onclick="event.preventDefault(); sdAddToWishlist({{ item.id }});"
                    >
                      <svg class="styledrop-related-products__wishlist-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                      </svg>
                    </button>

                    {%- if item.tags contains 'sale' or item.compare_at_price > item.price -%}
                      <span class="styledrop-related-products__badge-overlay styledrop-related-products__badge-overlay--sale">
                        <span class="styledrop-related-products__badge-dot"></span>SALE
                      </span>
                    {%- elsif item.tags contains 'new' -%}
                      <span class="styledrop-related-products__badge-overlay styledrop-related-products__badge-overlay--new">
                        <span class="styledrop-related-products__badge-dot"></span>NEW
                      </span>
                    {%- elsif item.tags contains 'hot' or item.tags contains 'bestseller' -%}
                      <span class="styledrop-related-products__badge-overlay styledrop-related-products__badge-overlay--hot">
                        <span class="styledrop-related-products__badge-dot"></span>HOT
                      </span>
                    {%- endif -%}
                  </div>

                  <div class="styledrop-related-products__product-info">
                    {%- if item.vendor != blank -%}
                      <p class="styledrop-related-products__product-vendor">{{ item.vendor }}</p>
                    {%- endif -%}
                    <h3 class="styledrop-related-products__product-title">{{ item.title }}</h3>
                    <p class="styledrop-related-products__product-price">
                      {%- if item.compare_at_price > item.price -%}
                        <span>{{ item.price | money }}</span>
                        <span class="styledrop-related-products__product-compare">{{ item.compare_at_price | money }}</span>
                      {%- else -%}
                        {{ item.price | money }}
                      {%- endif -%}
                    </p>
                    <button
                      type="button"
                      class="styledrop-related-products__add-btn quick-add-btn"
                      data-product-id="{{ item.id }}"
                      data-variant-id="{{ item.selected_or_first_available_variant.id }}"
                      onclick="event.preventDefault(); sdQuickAdd(this);"
                    >
                      <svg class="styledrop-related-products__cart-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                      </svg>
                      ADD TO CART
                    </button>
                  </div>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

      </div>

      {%- comment -%} Mobile Swipe Indicator {%- endcomment -%}
      <div class="styledrop-related-products__swipe-hint">
        <span class="styledrop-related-products__swipe-text">Swipe for more</span>
        <svg class="styledrop-related-products__swipe-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </div>

    </div>
  </div>
</div>
{%- endif -%}

<script>
(function() {
  function sdQuickAdd(button) {
    const variantId = button.dataset.variantId;
    const originalHTML = button.innerHTML;
    button.disabled = true;
    button.textContent = '...';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(r => r.json())
    .then(data => {
      document.dispatchEvent(new CustomEvent('cart:add', { detail: data }));
      button.disabled = false;
      button.innerHTML = originalHTML;
    })
    .catch(() => {
      button.disabled = false;
      button.innerHTML = originalHTML;
    });
  }

  function sdAddToWishlist(productId) {
    const wishlist = JSON.parse(localStorage.getItem('sdWishlist') || '[]');
    if (!wishlist.includes(String(productId))) wishlist.push(String(productId));
    localStorage.setItem('sdWishlist', JSON.stringify(wishlist));
    const btn = document.querySelector('.wishlist-btn[data-product-id="' + productId + '"]');
    if (btn) btn.querySelector('svg').setAttribute('fill', 'currentColor');
  }

  window.sdQuickAdd = sdQuickAdd;
  window.sdAddToWishlist = sdAddToWishlist;
})();
</script>
