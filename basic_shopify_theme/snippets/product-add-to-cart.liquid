{% comment %}
  Quantity Selector & Add to Cart
  
  Converts React quantity selector and cart button to Shopify Liquid
  Source: ProductDetails.tsx (lines 319-377)
  
  Features:
  - Quantity selector with +/- buttons
  - Add to Cart button with icon
  - Wishlist/Save button
  - Product features (shipping, returns, checkout)
  
  Usage:
  {% render 'product-add-to-cart', product: product %}
{% endcomment %}

{%- form 'product', product, id: 'product-form', class: 'product-form' -%}
  
  {%- comment -%} Quantity Selector + Buttons Row {%- endcomment -%}
  <div class="flex items-center gap-3 mb-6">
    
    {%- comment -%} Quantity Selector {%- endcomment -%}
    <div class="flex items-center justify-between bg-white border border-border rounded-full px-6 py-3 shadow-sm flex-none w-[40%] max-w-xs">
      <button
        type="button"
        class="quantity-minus w-6 h-6 flex items-center justify-center hover:bg-muted rounded-full transition-colors"
        aria-label="Decrease quantity"
      >
        {%- comment -%} Minus Icon SVG {%- endcomment -%}
        <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M20 12H4"/>
        </svg>
      </button>
      
      <input
        type="number"
        name="quantity"
        id="quantity"
        value="1"
        min="1"
        class="quantity-input min-w-[2rem] text-center font-semibold text-sm bg-transparent border-none outline-none"
        aria-label="Product quantity"
      />
      
      <button
        type="button"
        class="quantity-plus w-6 h-6 flex items-center justify-center hover:bg-muted rounded-full transition-colors"
        aria-label="Increase quantity"
      >
        {%- comment -%} Plus Icon SVG {%- endcomment -%}
        <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"/>
        </svg>
      </button>
    </div>

    {%- comment -%} Add to Cart Button + Wishlist {%- endcomment -%}
    <div class="flex flex-1 items-center gap-3">
      {%- comment -%} Add to Cart Button {%- endcomment -%}
      <button
        type="submit"
        name="add"
        class="add-to-cart-button flex-1 h-12 bg-accent text-white rounded-full font-condensed text-sm tracking-[0.18em] uppercase flex items-center justify-center gap-2 shadow-md hover:bg-accent/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        {% unless product.available %}disabled{% endunless %}
      >
        {%- comment -%} Shopping Bag Icon SVG {%- endcomment -%}
        <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
        <span class="add-to-cart-text">
          {% if product.available %}ADD TO CART{% else %}SOLD OUT{% endif %}
        </span>
      </button>

      {%- comment -%} Wishlist Button {%- endcomment -%}
      <button
        type="button"
        class="wishlist-button w-11 h-11 border border-border rounded-full flex items-center justify-center hover:border-[#0D0D0D] hover:text-[#0D0D0D] transition-colors"
        aria-label="Add to wishlist"
        data-product-id="{{ product.id }}"
      >
        {%- comment -%} Heart Icon SVG {%- endcomment -%}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
      </button>
    </div>
  </div>

{%- endform -%}

{%- comment -%} Product Features - Square Cards {%- endcomment -%}
