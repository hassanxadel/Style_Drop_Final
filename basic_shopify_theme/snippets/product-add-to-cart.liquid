{% comment %}
  StyleDrop Product Purchase Actions
  Converted from: src/components/ProductDetails.tsx (lines 319-377)

  Features:
  - Quantity selector with +/- controls
  - Add to Cart button (Shopify product form)
  - Wishlist / save button (localStorage)
  - "Find My Size" trigger → opens SizePredictor modal
  - Product Feature cards (shipping, returns, checkout)
  - All styles scoped to styledrop-product-purchase__* BEM

  Usage:
  {% render 'product-add-to-cart', product: product %}
{% endcomment %}

{{ 'styledrop-product-add-to-cart.css' | asset_url | stylesheet_tag }}

{%- form 'product', product, id: 'product-form', class: 'styledrop-product-purchase__form' -%}

  {%- comment -%} Quantity + Actions row {%- endcomment -%}
  <div class="styledrop-product-purchase__qty-row">

    {%- comment -%} Quantity Selector {%- endcomment -%}
    <div class="styledrop-product-purchase__qty">
      <button
        type="button"
        class="quantity-minus styledrop-product-purchase__qty-btn"
        aria-label="Decrease quantity"
      >
        <svg class="styledrop-product-purchase__qty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M20 12H4"/>
        </svg>
      </button>

      <input
        type="number"
        name="quantity"
        id="quantity"
        value="1"
        min="1"
        class="quantity-input styledrop-product-purchase__qty-input"
        aria-label="Product quantity"
      />

      <button
        type="button"
        class="quantity-plus styledrop-product-purchase__qty-btn"
        aria-label="Increase quantity"
      >
        <svg class="styledrop-product-purchase__qty-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"/>
        </svg>
      </button>
    </div>

    {%- comment -%} Add to Cart + Wishlist {%- endcomment -%}
    <div class="styledrop-product-purchase__actions">

      {%- comment -%} Add to Cart Button {%- endcomment -%}
      <button
        type="submit"
        name="add"
        class="add-to-cart-button styledrop-product-purchase__add-to-cart{% unless product.available %} styledrop-product-purchase__add-to-cart--sold-out{% endunless %}"
        {% unless product.available %}disabled{% endunless %}
      >
        <svg class="styledrop-product-purchase__cart-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
        <span class="add-to-cart-text">
          {%- if product.available -%}ADD TO CART{%- else -%}SOLD OUT{%- endif -%}
        </span>
      </button>

      {%- comment -%} Wishlist Button {%- endcomment -%}
      <button
        type="button"
        class="wishlist-button styledrop-product-purchase__wishlist"
        aria-label="Add to wishlist"
        data-product-id="{{ product.id }}"
      >
        <svg class="styledrop-product-purchase__wishlist-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
      </button>
    </div>
  </div>

{%- endform -%}

{%- comment -%} Size Predictor Trigger — wires into size-predictor-modal.liquid {%- endcomment -%}
<button
  type="button"
  class="styledrop-product-purchase__size-predictor-trigger"
  onclick="openSizePredictor()"
  aria-haspopup="dialog"
>
  <svg class="styledrop-product-purchase__size-predictor-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a1 1 0 001-1V6a1 1 0 00-1-1H4a1 1 0 00-1 1v12a1 1 0 001 1z"/>
  </svg>
  Find My Size
</button>

{%- comment -%} SizePredictor Modal — includes its own CSS and JS {%- endcomment -%}
{% render 'size-predictor-modal' %}

{%- comment -%} Product Feature Cards {%- endcomment -%}
<div class="styledrop-product-purchase__features">

  <div class="styledrop-product-purchase__feature-card">
    <svg class="styledrop-product-purchase__feature-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/>
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0h4m10-1a1 1 0 001 1h1a2 2 0 104 0h-6"/>
    </svg>
    <span class="styledrop-product-purchase__feature-text">Free shipping over<br />EGP 975</span>
  </div>

  <div class="styledrop-product-purchase__feature-card">
    <svg class="styledrop-product-purchase__feature-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
    </svg>
    <span class="styledrop-product-purchase__feature-text">Free returns,<br />30 days</span>
  </div>

  <div class="styledrop-product-purchase__feature-card">
    <svg class="styledrop-product-purchase__feature-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
    </svg>
    <span class="styledrop-product-purchase__feature-text">Secure<br />checkout</span>
  </div>

</div>

<script>
(function() {
  const quantityInput = document.getElementById('quantity');
  const minusButton = document.querySelector('.quantity-minus');
  const plusButton = document.querySelector('.quantity-plus');

  // Quantity controls
  minusButton?.addEventListener('click', function() {
    const val = parseInt(quantityInput.value) || 1;
    if (val > 1) quantityInput.value = val - 1;
  });

  plusButton?.addEventListener('click', function() {
    const val = parseInt(quantityInput.value) || 1;
    quantityInput.value = val + 1;
  });

  quantityInput?.addEventListener('change', function() {
    const val = parseInt(this.value) || 1;
    if (val < 1) this.value = 1;
  });

  // Wishlist toggle — Valgara-compliant: uses BEM modifier, NOT Tailwind class
  const wishlistBtn = document.querySelector('.wishlist-button');
  if (wishlistBtn) {
    const productId = wishlistBtn.dataset.productId;
    // Restore saved state from localStorage
    const saved = JSON.parse(localStorage.getItem('sdWishlist') || '[]');
    if (saved.includes(productId)) {
      wishlistBtn.classList.add('styledrop-product-purchase__wishlist--active');
      wishlistBtn.querySelector('svg').setAttribute('fill', 'currentColor');
    }

    wishlistBtn.addEventListener('click', function() {
      const wishlist = JSON.parse(localStorage.getItem('sdWishlist') || '[]');
      const isActive = this.classList.contains('styledrop-product-purchase__wishlist--active');
      const svg = this.querySelector('svg');

      if (isActive) {
        this.classList.remove('styledrop-product-purchase__wishlist--active');
        svg.setAttribute('fill', 'none');
        const idx = wishlist.indexOf(productId);
        if (idx > -1) wishlist.splice(idx, 1);
      } else {
        // Valgara-compliant: BEM modifier controls color, NOT classList.add('text-accent')
        this.classList.add('styledrop-product-purchase__wishlist--active');
        svg.setAttribute('fill', 'currentColor');
        if (!wishlist.includes(productId)) wishlist.push(productId);
      }
      localStorage.setItem('sdWishlist', JSON.stringify(wishlist));
    });
  }
})();
</script>
