      })
      .catch(error => {
        console.error('Error adding to cart:', error);
      });
      */
    });

    // Wishlist button functionality
    document.querySelector('.wishlist-button')?.addEventListener('click', function() {
      const productId = this.dataset.productId;
      // Implement wishlist functionality
      console.log('Add to wishlist:', productId);
      
      // Toggle heart fill (visual feedback)
      const svg = this.querySelector('svg');
      if (svg.getAttribute('fill') === 'none') {
        svg.setAttribute('fill', 'currentColor');
        this.classList.add('text-accent');
      } else {
        svg.setAttribute('fill', 'none');
        this.classList.remove('text-accent');
      }
    });
  })();
</script>

{% comment %}
  CONVERSION NOTES:
  
  React → Liquid Mappings:
  - useState(quantity) → HTML input with JavaScript
  - onClick handlers → addEventListener
  - <button> with onClick → <button type="submit"> in form
  - Shopping bag component → SVG icon
  - Heart component → SVG icon
  
  Shopify Features Used:
  - {% form 'product' %} - Shopify product form tag
  - name="add" - Add to cart action
  - name="quantity" - Quantity field
  - product.available - Check if product is in stock
  - /cart/add.js - Shopify AJAX cart API
  
  Form Submission:
  - Default: Page reload with cart update
  - Optional: AJAX submission (commented in JavaScript)
  
  Quantity Controls:
  - Minimum: 1
  - Maximum: No limit (can add inventory check)
  - Manual input: Validates on change
  
  Add to Cart Button States:
  - Available: "ADD TO CART" (clickable)
  - Sold Out: "SOLD OUT" (disabled)
  - Loading: Can add spinner (optional)
  
  Wishlist Functionality:
  - Basic toggle implementation included
  - Can integrate with Shopify wishlist apps
  - Can use localStorage for guest users
  - Can use customer metafields for logged-in users
  
  Optional Enhancements:
  1. Add loading spinner on submit
  2. Show success notification after add
  3. Implement sticky add-to-cart bar on scroll
  4. Add inventory check for max quantity
  5. Show "Low stock" warning
  6. Add "Buy Now" button for direct checkout
  7. Integrate with wishlist app (Swym, Wishlist Plus, etc.)
{% endcomment %}
