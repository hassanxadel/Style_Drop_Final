  <div class="flex flex-col items-center justify-center gap-3 px-3 py-4 bg-white rounded-2xl border border-border shadow-sm text-center">
    <div>
      {%- comment -%} Shield Icon SVG {%- endcomment -%}
      <svg class="w-[18px] h-[18px] text-accent mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
